<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProS - Dashboard</title>

    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link rel="stylesheet" type="text/css" href="/vendor/css/daterangepicker.css" />
</head>

<body
    class="font-theme flex flex-col h-full overflow-x-hidden text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300 text-left rtl:text-right">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content">

            <%- include('../partials/header') %>

                <div class="px-4 lg:px-8 pt-4 pb-4 flex flex-col sm:flex-row sm:items-center">
                    <div class="flex-grow mb-3 sm:mb-0">
                        <h2 class="text-xl font-semibold text-black dark:text-white">
                            Bem-vindo<%= (locals.user && locals.user.nome) ? " " +
                                locals.user.nome.split(' ')[0] : "" %>!
                </h2>
                <p class="text-sm text-zinc-500 dark:text-zinc-400">
                    Confira o resumo das operações e contratos.
                </p>
            </div>
            <div class="flex flex-col">
                <small class="text-muted block mb-1">Dados do período</small>
                <div class="inline-flex w-auto max-w-xs dark:bg-zinc-900 items-center gap-1 cursor-pointer text-sm" id="reportrange">
                    <span class="icon-[lucide--calendar-days]"></span>
                    <span></span><span class="icon-[lucide--chevron-down]"></span>
                </div>
            </div>
        </div>

        <div class="content lg:px-4 flex-grow relative">

            <div class="px-4 mb-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                
                <div class="rounded-xl flex items-center gap-4 bg-white dark:bg-zinc-900 shadow-card p-4 overflow-hidden border-l-4 border-blue-500">
                    <div class="shrink-0 flex items-center justify-center size-12 rounded-lg bg-blue-500/10 text-blue-500">
                        <span class="icon-[lucide--building-2] text-2xl"></span>
                    </div>
                    <div class="flex-grow">
                        <h4 class="text-2xl font-bold text-zinc-800 dark:text-white"><%= locals.dash ? locals.dash.totalClientes : ' 0' %>
                                </h4>
                                <p class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Empresas</p>
                    </div>
                </div>

                <div
                    class="rounded-xl flex items-center gap-4 bg-white dark:bg-zinc-900 shadow-card p-4 overflow-hidden border-l-4 border-emerald-500">
                    <div
                        class="shrink-0 flex items-center justify-center size-12 rounded-lg bg-emerald-500/10 text-emerald-500">
                        <span class="icon-[lucide--users] text-2xl"></span>
                    </div>
                    <div class="flex-grow">
                        <h4 class="text-2xl font-bold text-zinc-800 dark:text-white">
                            <%= locals.dash ? locals.dash.totalFuncionarios : '0' %>
                        </h4>
                        <p class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Vidas Atendidas</p>
                    </div>
                </div>

                <div
                    class="rounded-xl flex items-center gap-4 bg-white dark:bg-zinc-900 shadow-card p-4 overflow-hidden border-l-4 border-purple-500">
                    <div
                        class="shrink-0 flex items-center justify-center size-12 rounded-lg bg-purple-500/10 text-purple-500">
                        <span class="icon-[lucide--briefcase-business] text-2xl"></span>
                    </div>
                    <div class="flex-grow">
                        <h4 class="text-2xl font-bold text-zinc-800 dark:text-white">
                            <%= locals.dash ? locals.dash.totalContratos : '0' %>
                        </h4>
                        <p class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Total de OS</p>
                    </div>
                </div>

                <div
                    class="rounded-xl flex items-center gap-4 bg-white dark:bg-zinc-900 shadow-card p-4 overflow-hidden border-l-4 border-amber-500">
                    <div
                        class="shrink-0 flex items-center justify-center size-12 rounded-lg bg-amber-500/10 text-amber-500">
                        <span class="icon-[lucide--hand-coins] text-2xl"></span>
                    </div>
                    <div class="flex-grow overflow-hidden">
                        <h4 class="text-xl font-bold text-zinc-800 dark:text-white truncate"
                            title="<%= locals.dash ? Number(locals.dash.totalFomento).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) : 'R$ 0,00' %>">
                            <%= locals.dash ? Number(locals.dash.totalFomento).toLocaleString('pt-BR', {
                                style: 'currency' , currency: 'BRL' }) : 'R$ 0,00' %>
                        </h4>
                        <p class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Total Fomento</p>
                    </div>
                </div>
                </div>

                <div class="px-4 grid grid-cols-1 lg:grid-cols-12 mb-4 gap-4">

                    <div class="lg:col-span-4">
                        <div
                            class="rounded-xl bg-white dark:bg-zinc-900 shadow-card overflow-hidden h-full flex flex-col">
                            <div
                                class="flex items-center justify-between p-4 border-b border-zinc-100 dark:border-zinc-800">
                                <h5 class="text-lg font-bold text-zinc-800 dark:text-white">Perfil de Clientes</h5>
                            </div>
                            <div dir="ltr" class="p-4 flex-grow flex items-center justify-center">
                                <div id="chart_perfil_clientes" class="w-full h-72"></div>
                            </div>
                        </div>
                    </div>

                    <div class="lg:col-span-8">
                        <div
                            class="rounded-xl bg-white dark:bg-zinc-900 shadow-card overflow-hidden h-full flex flex-col mb-4">
                            <div class="p-4 pb-0 flex items-center justify-between">
                                <div class="flex-grow">
                                    <h5 class="text-lg font-bold text-zinc-800 dark:text-white">Faturamento de Contratos
                                    </h5>
                                    <p class="text-sm text-zinc-500">Valores das OS geradas no período selecionado</p>
                                </div>
                            </div>
                            <div class="p-4 flex-grow" dir="ltr">
                                <div id="chart_faturamento" class="h-64 w-full"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="px-4 grid grid-cols-1 gap-4 mb-4">
                    <div class="rounded-xl bg-white dark:bg-zinc-900 shadow-card overflow-hidden">
                        <div
                            class="flex items-center justify-between p-4 pb-2 border-b border-zinc-100 dark:border-zinc-800">
                            <h5 class="text-lg font-bold text-zinc-800 dark:text-white">Últimos Contratos (OS)</h5>
                            <a href="/ordem-servico"
                                class="btn btn-sm bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700 text-zinc-700 dark:text-zinc-300">Ver
                                Todas</a>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="table-default w-full text-left">
                                <thead class="bg-zinc-50 dark:bg-zinc-800/50">
                                    <tr>
                                        <th class="px-4 py-3 text-sm font-semibold text-zinc-500">Contrato Nº</th>
                                        <th class="px-4 py-3 text-sm font-semibold text-zinc-500">Cliente</th>
                                        <th class="px-4 py-3 text-sm font-semibold text-zinc-500">Valor Total</th>
                                        <th class="px-4 py-3 text-sm font-semibold text-zinc-500">Data</th>
                                        <th class="px-4 py-3 text-sm font-semibold text-zinc-500">Status</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-zinc-100 dark:divide-zinc-800">
                                    <% if (locals.ultimasOS && locals.ultimasOS.length> 0) { %>
                                        <% locals.ultimasOS.forEach(os=> { %>
                                            <tr class="hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors">
                                                <td class="px-4 py-3 font-semibold text-primary"><a
                                                        href="/ordem-servico/ver/<%= os.id_ordem_servico %>">#<%=
                                                            os.contrato_numero %></a></td>
                                                <td class="px-4 py-3 text-zinc-800 dark:text-zinc-200 font-medium">
                                                    <%= os.nome_empresa %>
                                                </td>
                                                <td class="px-4 py-3">
                                                    <%= Number(os.valor_total_contrato).toLocaleString('pt-BR', {
                                                        style: 'currency' , currency: 'BRL' }) %>
                                                </td>
                                                <td class="px-4 py-3 text-zinc-500">
                                                    <%= new Date(os.data_abertura).toLocaleDateString('pt-BR') %>
                                                </td>
                                                <td class="px-4 py-3">
                                                    <% if(os.status==='Concluída' ) { %>
                                                        <span
                                                            class="badge bg-green-500/10 text-green-500">Concluída</span>
                                                        <% } else if(os.status==='Em Andamento' ) { %>
                                                            <span class="badge bg-amber-500/10 text-amber-500">Em
                                                                Andamento</span>
                                                            <% } else { %>
                                                                <span class="badge bg-blue-500/10 text-blue-500">
                                                                    <%= os.status %>
                                                                </span>
                                                                <% } %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="5"
                                                            class="px-4 py-8 text-center text-zinc-400 italic">Nenhum
                                                            contrato recente encontrado.</td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                </div>

                <%- include('../partials/footer') %>

        </main>

        <script id="dash-data" type="application/json">
        <%- locals.dash ? JSON.stringify(locals.dash) : '{}' %>
        </script>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>
        <script src="/vendor/js/moment.min.js"></script>
        <script src="/vendor/js/daterangepicker.js"></script>
        <script src="/vendor/js/echarts.min.js"></script>
        <script src="/vendor/js/sweetalert2.all.min.js"></script>

        <script>
            $(document).ready(function () {

                // ==========================================
                // CONFIGURAÇÃO DO CALENDÁRIO COM REFRESH
                // ==========================================
                const urlParams = new URLSearchParams(window.location.search);
                var start = urlParams.get('start') ? moment(urlParams.get('start')) : moment().startOf('month');
                var end = urlParams.get('end') ? moment(urlParams.get('end')) : moment().endOf('month');

                function cb(start, end) {
                    $('#reportrange span').html(start.format('DD/MM/YYYY') + ' - ' + end.format('DD/MM/YYYY'));
                }

                $('#reportrange').daterangepicker({
                    startDate: start,
                    endDate: end,
                    locale: {
                        format: 'DD/MM/YYYY', separator: ' - ', applyLabel: 'Aplicar', cancelLabel: 'Cancelar',
                        customRangeLabel: 'Personalizado', daysOfWeek: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'],
                        monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro']
                    },
                    ranges: {
                        'Hoje': [moment(), moment()],
                        'Ontem': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
                        'Últimos 7 dias': [moment().subtract(6, 'days'), moment()],
                        'Últimos 30 dias': [moment().subtract(29, 'days'), moment()],
                        'Este mês': [moment().startOf('month'), moment().endOf('month')],
                        'Mês passado': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
                    }
                }, cb);
                cb(start, end);

                $('#reportrange').on('apply.daterangepicker', function (ev, picker) {
                    const dataInicio = picker.startDate.format('YYYY-MM-DD');
                    const dataFim = picker.endDate.format('YYYY-MM-DD');
                    window.location.href = `${window.location.pathname}?start=${dataInicio}&end=${dataFim}`;
                });

                // ==========================================
                // MONTAGEM DOS GRÁFICOS
                // ==========================================
                let dashData = {};
                try {
                    const raw = document.getElementById('dash-data').textContent;
                    if (raw) dashData = JSON.parse(raw);
                } catch (e) { }

                const textColor = document.documentElement.classList.contains('dark') ? '#a1a1aa' : '#52525b';
                const gridColor = document.documentElement.classList.contains('dark') ? '#27272a' : '#e4e4e7';

                // GRÁFICO DE PIZZA (PIZZA GRANDE, SEM TEXTO EXTRUDADO)
                const chartPerfil = echarts.init(document.getElementById('chart_perfil_clientes'));
                const qtdEmpresas = dashData.qtdEmpresasComuns || 0;
                const qtdIndustrias = dashData.qtdIndustrias || 0;

                const optionPerfil = {
                    tooltip: {
                        trigger: 'item',
                        formatter: '{b}: {c} ({d}%)' // Tooltip exibe todas as infos quando passar o mouse
                    },
                    legend: { top: 'bottom', textStyle: { color: textColor } },
                    color: ['#3b82f6', '#f59e0b'],
                    series: [
                        {
                            name: 'Perfil',
                            type: 'pie',
                            radius: ['40%', '70%'], // Voltou a ser a pizza grandona e bonita
                            avoidLabelOverlap: false,
                            itemStyle: {
                                borderRadius: 10,
                                borderColor: document.documentElement.classList.contains('dark') ? '#18181b' : '#fff',
                                borderWidth: 2
                            },
                            label: {
                                show: false, // Esconde os textos cortados do lado de fora
                                position: 'center'
                            },
                            emphasis: {
                                label: {
                                    show: true,
                                    fontSize: '20',
                                    fontWeight: 'bold',
                                    color: textColor,
                                    formatter: '{d}%' // Ao focar, mostra só a % no meio!
                                }
                            },
                            labelLine: {
                                show: false // Tira a linha preta
                            },
                            data: [
                                { value: qtdEmpresas, name: 'Comércio/Serviços' },
                                { value: qtdIndustrias, name: 'Indústrias' }
                            ]
                        }
                    ]
                };
                chartPerfil.setOption(optionPerfil);

                // GRÁFICO DE BARRAS
                const chartFaturamento = echarts.init(document.getElementById('chart_faturamento'));
                const meses = dashData.mesesLabel || ['Sem dados'];
                const valores = dashData.valoresFaturamento || [0];

                const optionFaturamento = {
                    tooltip: {
                        trigger: 'axis',
                        valueFormatter: (value) => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value)
                    },
                    grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },
                    xAxis: {
                        type: 'category',
                        data: meses,
                        axisLabel: { color: textColor },
                        axisLine: { lineStyle: { color: gridColor } }
                    },
                    yAxis: {
                        type: 'value',
                        axisLabel: { color: textColor },
                        splitLine: { lineStyle: { color: gridColor, type: 'dashed' } }
                    },
                    series: [
                        {
                            data: valores,
                            type: 'bar',
                            barWidth: '40%',
                            itemStyle: { color: '#0AA34A', borderRadius: [4, 4, 0, 0] }
                        }
                    ]
                };
                chartFaturamento.setOption(optionFaturamento);

                window.addEventListener('resize', function () {
                    chartPerfil.resize();
                    chartFaturamento.resize();
                });
            });
        </script>

        <script>
            // ALERTA DE BOAS-VINDAS
            document.addEventListener("DOMContentLoaded", function () {
                if (!sessionStorage.getItem("boasVindasExibidas")) {

                    const userName = "<%= (locals.user && (locals.user.nome || locals.user.nome_completo)) ? (locals.user.nome || locals.user.nome_completo).split(' ')[0] : '' %>";
                    const welcomeMessage = userName ? `Bom te ver por aqui, ${userName}!` : 'Bom te ver por aqui!';

                    Swal.fire({
                        icon: 'success',
                        title: 'Seu login foi bem-sucedido!',
                        text: welcomeMessage,
                        position: 'center',
                        backdrop: true,
                        showConfirmButton: false,
                        showCloseButton: true,
                        timer: 3000,
                        timerProgressBar: true,
                        customClass: {
                            closeButton: '!text-xl !top-0 !end-0 !mt-1 !me-1'
                        }
                    });

                    sessionStorage.setItem("boasVindasExibidas", "true");
                }
            });
        </script>
</body>

</html>