<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pesquisa de Clima Organizacional - <%= empresa.nome_empresa %>
    </title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link rel="stylesheet" href="/css/style.css" />

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* Estilo para os botões de resposta ficarem bons no celular */
        .radio-card {
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 1rem 0.5rem;
            border: 2px solid #e5e7eb;
            border-radius: 0.75rem;
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            background: white;
            height: 100%;
            color: #4b5563;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .radio-card:hover {
            border-color: #93c5fd;
            background-color: #eff6ff;
        }

        .radio-input:checked+.radio-card {
            border-color: #2563eb;
            background-color: #eff6ff;
            color: #1d4ed8;
            font-weight: 700;
            box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.1);
        }

        /* Container da Pergunta */
        .question-box {
            background: #ffffff;
            border: 1px solid #f3f4f6;
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
        }
    </style>
</head>

<body class="bg-zinc-100 min-h-screen text-zinc-800 antialiased selection:bg-blue-200">

    <header class="bg-white border-b border-zinc-200 sticky top-0 z-10 shadow-sm">
        <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
            <div>
                <h1 class="font-bold text-lg text-blue-900 leading-tight">Pesquisa de Clima</h1>
                <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mt-0.5">
                    <%= empresa.nome_empresa %>
                </p>
            </div>
            <div class="size-10 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                    <polyline points="14 2 14 8 20 8" />
                </svg>
            </div>
        </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-8">

        <div class="mb-8 text-center sm:text-left">
            <h2 class="text-2xl font-black text-zinc-800 mb-2">Checklist Trabalhador (NR-01)</h2>
            <p class="text-zinc-600">Por favor, responda com sinceridade. Seus dados individuais são confidenciais e
                serão usados apenas para a avaliação geral da empresa.</p>
        </div>

        <form id="formPublico" onsubmit="enviarResposta(event)">
            <input type="hidden" id="id_cliente" value="<%= empresa.id_cliente %>">
            <input type="hidden" id="id_unidade" value="<%= empresa.id_unidade %>">
            <input type="hidden" id="hora_inicio" value="">

            <div class="question-box border-l-4 border-l-blue-600">
                <label class="block font-bold text-lg text-zinc-800 mb-3" for="setor_cargo">
                    Qual o seu Setor ou Cargo atual? <span class="text-red-500">*</span>
                </label>
                <input type="text" id="setor_cargo"
                    class="w-full bg-zinc-50 border border-zinc-300 text-zinc-900 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all"
                    placeholder="Ex: Manutenção, Administrativo, TI..." required>
            </div>

            <% const perguntasFrequencia=[ {id: 'q1' ,
                texto: 'Com que frequência você tem que fazer suas tarefas de trabalho com muita rapidez?' }, {id: 'q2'
                , texto: 'Com que frequência você tem que trabalhar intensamente?' }, {id: 'q3' ,
                texto: 'Seu trabalho exige demais de você?' }, {id: 'q4' ,
                texto: 'Você tem tempo suficiente para cumprir todas as tarefas de seu trabalho?' }, {id: 'q5' ,
                texto: 'O seu trabalho costuma apresentar exigências contraditórias ou discordantes?' }, {id: 'q6' ,
                texto: 'Você tem possibilidade de aprender coisas novas em seu trabalho?' }, {id: 'q7' ,
                texto: 'Seu trabalho exige muita habilidade ou conhecimento especializado?' }, {id: 'q8' ,
                texto: 'Seu trabalho exige que você tome iniciativas?' }, {id: 'q9' ,
                texto: 'No seu trabalho, você tem que repetir muitas vezes as mesmas tarefas?' }, {id: 'q10' ,
                texto: 'Você pode escolher COMO fazer seu trabalho?' }, {id: 'q11' ,
                texto: 'Você pode escolher O QUE fazer no seu trabalho?' } ]; const perguntasConcordancia=[ {id: 'q12' ,
                texto: 'Existe um ambiente calmo e agradável onde trabalho.' }, {id: 'q13' ,
                texto: 'No trabalho, nos relacionamos bem uns com os outros.' }, {id: 'q14' ,
                texto: 'Eu posso contar com o apoio dos meus colegas de trabalho.' }, {id: 'q15' ,
                texto: 'Se eu não estiver num bom dia, meus colegas compreendem.' }, {id: 'q16' ,
                texto: 'No trabalho, me relaciono bem com meus chefes.' }, {id: 'q17' ,
                texto: 'Eu gosto de trabalhar com meus colegas.' } ]; %>

                <h3 class="font-bold text-xl text-zinc-800 mt-10 mb-4 px-2">Parte 1: Demandas e Controle</h3>

                <% perguntasFrequencia.forEach((p, idx)=> { %>
                    <div class="question-box">
                        <p class="font-bold text-zinc-800 mb-4 text-[1.05rem] leading-snug">
                            <span class="text-blue-600 mr-1">
                                <%= idx + 1 %>.
                            </span>
                            <%= p.texto %> <span class="text-red-500">*</span>
                        </p>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                            <label class="h-full block">
                                <input type="radio" name="respostas[<%= p.id %>]" value="Frequentemente"
                                    class="hidden radio-input">
                                <div class="radio-card">Frequentemente</div>
                            </label>
                            <label class="h-full block">
                                <input type="radio" name="respostas[<%= p.id %>]" value="Às vezes"
                                    class="hidden radio-input">
                                <div class="radio-card">Às vezes</div>
                            </label>
                            <label class="h-full block">
                                <input type="radio" name="respostas[<%= p.id %>]" value="Raramente"
                                    class="hidden radio-input">
                                <div class="radio-card">Raramente</div>
                            </label>
                            <label class="h-full block">
                                <input type="radio" name="respostas[<%= p.id %>]" value="Nunca ou quase nunca"
                                    class="hidden radio-input">
                                <div class="radio-card">Nunca ou<br>quase nunca</div>
                            </label>
                        </div>
                    </div>
                    <% }) %>

                        <h3 class="font-bold text-xl text-zinc-800 mt-10 mb-4 px-2">Parte 2: Apoio Social</h3>

                        <% perguntasConcordancia.forEach((p, idx)=> { %>
                            <div class="question-box">
                                <p class="font-bold text-zinc-800 mb-4 text-[1.05rem] leading-snug">
                                    <span class="text-blue-600 mr-1">
                                        <%= idx + 12 %>.
                                    </span>
                                    <%= p.texto %> <span class="text-red-500">*</span>
                                </p>
                                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                                    <label class="h-full block">
                                        <input type="radio" name="respostas[<%= p.id %>]" value="Concordo Totalmente"
                                            class="hidden radio-input">
                                        <div class="radio-card">Concordo<br>Totalmente</div>
                                    </label>
                                    <label class="h-full block">
                                        <input type="radio" name="respostas[<%= p.id %>]"
                                            value="Concordo mais que discordo" class="hidden radio-input">
                                        <div class="radio-card">Concordo mais<br>que discordo</div>
                                    </label>
                                    <label class="h-full block">
                                        <input type="radio" name="respostas[<%= p.id %>]"
                                            value="Discordo mais que concordo" class="hidden radio-input">
                                        <div class="radio-card">Discordo mais<br>que concordo</div>
                                    </label>
                                    <label class="h-full block">
                                        <input type="radio" name="respostas[<%= p.id %>]" value="Discordo"
                                            class="hidden radio-input">
                                        <div class="radio-card">Discordo</div>
                                    </label>
                                </div>
                            </div>
                            <% }) %>

                                <div class="mt-10 mb-8 sticky bottom-4 z-10">
                                    <button type="submit" id="btnEnviar"
                                        class="w-full bg-primary text-white font-black text-lg h-16 rounded-xl hover:bg-primary-deep transition-colors shadow-xl shadow-primary/30 flex items-center justify-center gap-2">
                                        Enviar Respostas
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="22" y1="2" x2="11" y2="13"></line>
                                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                                        </svg>
                                    </button>
                                </div>

        </form>

        <div id="telaSucesso" class="hidden text-center py-16">
            <div class="size-24 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>
            <h2 class="text-3xl font-black text-zinc-800 mb-3">Tudo Certo!</h2>
            <p class="text-lg text-zinc-600 mb-8">Suas respostas foram salvas com segurança.<br>Muito obrigado pela sua
                participação.</p>

            <div class="flex flex-col sm:flex-row justify-center mt-6">
                <button type="button" onclick="responderNovamente()"
                    class="w-full bg-primary text-white font-black text-lg h-16 rounded-xl hover:bg-primary-deep transition-colors shadow-xl shadow-primary/30 flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <line x1="19" y1="8" x2="19" y2="14"></line>
                        <line x1="22" y1="11" x2="16" y2="11"></line>
                    </svg>
                    Registrar Nova Resposta
                </button>
            </div>

            <p class="text-sm text-zinc-400 mt-6">Se ninguém mais for responder neste aparelho, você já pode fechar esta
                tela.</p>
        </div>

    </main>

    <script src="/vendor/js/sweetalert2.all.min.js"></script>
    <script>
        // Dispara o cronômetro assim que a tela abre
        document.getElementById('hora_inicio').value = new Date().toISOString();

        async function enviarResposta(e) {
            e.preventDefault();

            const btn = document.getElementById('btnEnviar');

            // Coleta as respostas marcadas
            const respostas = {};
            document.querySelectorAll('input[type="radio"]:checked').forEach(radio => {
                const match = radio.name.match(/respostas\[(.*?)\]/);
                if (match) respostas[match[1]] = radio.value;
            });

            // Verifica se as 17 perguntas foram respondidas
            if (Object.keys(respostas).length < 17) {
                return Swal.fire({
                    icon: 'warning',
                    title: 'Atenção!',
                    text: 'Por favor, responda todas as perguntas antes de enviar. Faltam ' + (17 - Object.keys(respostas).length) + ' respostas.',
                    confirmButtonColor: '#2563eb'
                });
            }

            // Se tudo estiver certo, desabilita o botão para evitar duplo envio
            btn.disabled = true;
            btn.innerHTML = '<svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Salvando...';

            const inicio = new Date(document.getElementById('hora_inicio').value);
            const duracao = Math.round((new Date() - inicio) / 1000);

            const payload = {
                id_cliente: document.getElementById('id_cliente').value,
                id_unidade: document.getElementById('id_unidade').value,
                setor_cargo: document.getElementById('setor_cargo').value.trim(),
                duracao_segundos: duracao,
                respostas: respostas
            };

            try {
                const req = await fetch('/checklist-stress/responder/salvar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const res = await req.json();

                if (res.success) {
                    // Esconde o formulário e mostra a tela de sucesso
                    document.getElementById('formPublico').classList.add('hidden');
                    document.querySelector('.mb-8.text-center').classList.add('hidden'); // esconde o texto do topo
                    document.getElementById('telaSucesso').classList.remove('hidden');
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                } else {
                    throw new Error(res.message);
                }
            } catch (err) {
                Swal.fire({
                    icon: 'error',
                    title: 'Ops!',
                    text: err.message || 'Ocorreu um erro ao enviar suas respostas. Tente novamente.',
                    confirmButtonColor: '#2563eb'
                });
                btn.disabled = false;
                btn.innerHTML = `Enviar Respostas 
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>`;
            }
        }

        // Nova função para resetar e responder novamente
        function responderNovamente() {
            // Oculta a tela de sucesso
            document.getElementById('telaSucesso').classList.add('hidden');

            // Exibe novamente o formulário e os textos do cabeçalho
            document.getElementById('formPublico').classList.remove('hidden');
            document.querySelector('.mb-8.text-center').classList.remove('hidden');

            // Reseta (limpa) todos os inputs e marcações de rádio
            document.getElementById('formPublico').reset();

            // Restaura o botão de Enviar (tirando ele do estado de disable/salvando)
            const btn = document.getElementById('btnEnviar');
            btn.disabled = false;
            btn.innerHTML = `Enviar Respostas 
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="22" y1="2" x2="11" y2="13"></line>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                </svg>`;

            // Zera o cronômetro para o novo trabalhador
            document.getElementById('hora_inicio').value = new Date().toISOString();

            // Joga a tela lá pro topo automaticamente
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
</body>

</html>