<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerenciador de Coleta - Checklist Job Stress - ProS</title>

    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.3/css/dataTables.dataTables.css">

    <style>
        .dataTables_info {
            font-size: 0.875rem;
            color: #a1a1aa;
            margin-top: 0.5rem;
        }

        .dataTables_paginate {
            margin-top: 0.5rem;
            font-size: 0.875rem;
        }

        .hover-row:hover {
            background-color: #f4f4f5;
        }

        .dark .hover-row:hover {
            background-color: #27272a;
        }

        table.dataTable.no-footer {
            border-bottom: none !important;
        }

        /* Estilos do Formulário de Coleta Presencial */
        .radio-card {
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 1rem 0.5rem;
            border: 2px solid #e5e7eb;
            border-radius: 0.75rem;
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            background: white;
            height: 100%;
            color: #4b5563;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .dark .radio-card {
            background: #18181b;
            border-color: #27272a;
            color: #a1a1aa;
        }

        .radio-card:hover {
            border-color: #93c5fd;
            background-color: #eff6ff;
        }

        .dark .radio-card:hover {
            border-color: #3b82f6;
            background-color: #1e3a8a;
        }

        .radio-input:checked+.radio-card {
            border-color: #2563eb;
            background-color: #eff6ff;
            color: #1d4ed8;
            font-weight: 700;
            box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.1);
        }

        .dark .radio-input:checked+.radio-card {
            border-color: #3b82f6;
            background-color: #1e3a8a;
            color: #93c5fd;
        }

        .question-box {
            background: #ffffff;
            border: 1px solid #f3f4f6;
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
        }

        .dark .question-box {
            background: #18181b;
            border-color: #27272a;
        }
    </style>
</head>

<body
    class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content relative">
            <%- include('../partials/header') %>

                <% const isContinuacao=clienteSelecionado ? true : false; let nomePreenchido="" ; if (isContinuacao &&
                    clientes) { const cli=clientes.find(c=> c.id_cliente === clienteSelecionado);
                    if (cli) nomePreenchido = cli.nome_empresa;
                    }
                    %>

                    <div class="px-4 lg:px-10 py-6">
                        <h2 class="text-2xl mb-2 text-zinc-800 dark:text-zinc-100 font-bold">Gerenciador de Coleta</h2>
                        <p class="text-sm text-zinc-500">Gere o link e acompanhe os preenchimentos em tempo real.</p>
                    </div>

                    <div class="content flex-grow px-4 lg:px-10 pb-10">
                        <div
                            class="rounded-xl bg-white dark:bg-zinc-900 shadow-sm border border-zinc-200 dark:border-zinc-800 p-6 mb-4">

                            <div class="wizard" data-wizard>
                                <ul
                                    class="nav-horizontal flex flex-nowrap justify-center nav-wizard mb-8 gap-4 md:gap-8 w-full">
                                    <li class="wizard-step nav-link flex items-center gap-3.5 active" id="nav-step-1">
                                        <span
                                            class="wizard-icon shrink-0 size-10 flex items-center justify-center rounded-full">01</span>
                                        <div class="flex-grow whitespace-nowrap hidden sm:block">
                                            <h6 class="mb-0 font-bold text-zinc-800 dark:text-zinc-100 leading-tight">
                                                Configuração</h6>
                                            <p class="text-sm text-zinc-500 mb-0 leading-tight">Vínculo</p>
                                        </div>
                                    </li>
                                    <li class="wizard-step nav-link flex items-center gap-3.5 disabled" id="nav-step-2">
                                        <span
                                            class="wizard-icon shrink-0 size-10 flex items-center justify-center rounded-full">02</span>
                                        <div class="flex-grow whitespace-nowrap hidden sm:block">
                                            <h6 class="mb-0 font-bold text-zinc-800 dark:text-zinc-100 leading-tight">
                                                Painel da Coleta</h6>
                                            <p class="text-sm text-zinc-500 mb-0 leading-tight">Acompanhamento</p>
                                        </div>
                                    </li>
                                    <li class="wizard-step nav-link flex items-center gap-3.5 disabled" id="nav-step-3">
                                        <span
                                            class="wizard-icon shrink-0 size-10 flex items-center justify-center rounded-full">03</span>
                                        <div class="flex-grow whitespace-nowrap hidden sm:block">
                                            <h6 class="mb-0 font-bold text-zinc-800 dark:text-zinc-100 leading-tight">
                                                Formulário</h6>
                                            <p class="text-sm text-zinc-500 mb-0 leading-tight">Preenchimento</p>
                                        </div>
                                    </li>
                                </ul>

                                <div>
                                    <form id="formChecklist" onsubmit="return false;">
                                        <input type="hidden" id="dashboard_id_unidade"
                                            value="<%= user.id_unidade || user.unidade_id %>">

                                        <div id="panel-step-1" class="wizard-panel active show animate-fade-in">
                                            <h5
                                                class="text-[16px] font-bold text-[#1a5293] dark:text-blue-400 mb-5 border-b border-zinc-100 dark:border-zinc-800 pb-2 uppercase tracking-wide">
                                                1. Vínculo da Coleta
                                            </h5>

                                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                                                <div>
                                                    <label
                                                        class="mb-2 block text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                                                        Empresa / Cliente <span class="text-red-500">*</span>
                                                    </label>
                                                    <div class="relative w-full">
                                                        <input type="hidden" name="id_cliente" id="contratante_id"
                                                            value="<%= clienteSelecionado || '' %>" required>
                                                        <input id="contratante_nome" name="contratante_nome" type="text"
                                                            value="<%= nomePreenchido %>"
                                                            class="input h-10 w-full !pe-11 <%= isContinuacao ? 'bg-zinc-100 dark:bg-zinc-800/80 cursor-not-allowed pointer-events-none text-zinc-600 dark:text-zinc-400 font-semibold' : 'bg-white dark:bg-zinc-900 cursor-pointer text-zinc-600 dark:text-zinc-300' %>"
                                                            placeholder="Selecione uma empresa..." readonly required <%-
                                                            !isContinuacao
                                                            ? 'data-bs-toggle="modal" data-bs-target="#modal_contratante"'
                                                            : '' %>>

                                                        <% if(!isContinuacao) { %>
                                                            <button type="button" data-bs-toggle="modal"
                                                                data-bs-target="#modal_contratante"
                                                                class="absolute right-2 top-1/2 -translate-y-1/2 size-8 rounded-md flex items-center justify-center hover:bg-zinc-100 dark:hover:bg-zinc-800 text-zinc-500 hover:text-zinc-900 dark:hover:text-white">
                                                                <span class="icon-[lucide--search] text-lg"></span>
                                                            </button>
                                                            <% } else { %>
                                                                <div
                                                                    class="absolute right-2 top-1/2 -translate-y-1/2 size-8 flex items-center justify-center text-zinc-400 dark:text-zinc-500">
                                                                    <span class="icon-[lucide--lock] text-lg"></span>
                                                                </div>
                                                                <% } %>
                                                    </div>
                                                </div>
                                                <div>
                                                    <label
                                                        class="mb-2 block text-sm font-semibold text-zinc-800 dark:text-zinc-200">Data
                                                        de Abertura</label>
                                                    <input type="date" id="data_aplicacao"
                                                        class="input w-full bg-zinc-100 dark:bg-zinc-800 text-zinc-500 cursor-not-allowed pointer-events-none"
                                                        readonly>
                                                </div>
                                                <div>
                                                    <label
                                                        class="mb-2 block text-sm font-semibold text-zinc-800 dark:text-zinc-200">Responsável
                                                        Técnico</label>
                                                    <input type="text"
                                                        class="input w-full bg-zinc-100 dark:bg-zinc-800 text-zinc-500 cursor-not-allowed pointer-events-none"
                                                        value="<%= (user.nome_completo || user.nome || user.email) %>"
                                                        readonly>
                                                </div>
                                            </div>

                                            <div
                                                class="flex justify-end pt-4 border-t border-zinc-100 dark:border-zinc-800">
                                                <button type="button" onclick="irParaEtapa2()"
                                                    class="btn bg-primary text-white hover:bg-primary-deep h-12 px-8 font-bold shadow-lg shadow-primary/30 w-full sm:w-auto">
                                                    Gerar Painel de Coleta <span
                                                        class="icon-[lucide--arrow-right] ms-2"></span>
                                                </button>
                                            </div>
                                        </div>

                                        <div id="panel-step-2" class="wizard-panel hidden animate-fade-in">

                                            <div class="text-center mb-8 pt-4">
                                                <div
                                                    class="size-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm">
                                                    <span class="icon-[lucide--activity] text-3xl"></span>
                                                </div>
                                                <h3 class="text-2xl font-bold text-zinc-800 dark:text-zinc-100">Painel
                                                    de Coleta Ativo</h3>
                                                <p class="text-zinc-500 max-w-lg mx-auto mt-2">Empresa: <strong
                                                        id="lbl_empresa_painel"
                                                        class="text-zinc-800 dark:text-zinc-200"></strong></p>
                                            </div>

                                            <div
                                                class="rounded-2xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 p-6 md:p-8 mb-8 flex flex-col items-center justify-center text-center shadow-sm">
                                                <h4 class="font-bold text-blue-800 dark:text-blue-400 text-lg mb-4">
                                                    Compartilhar com Funcionários</h4>
                                                <div
                                                    class="flex flex-col sm:flex-row items-center gap-3 w-full max-w-2xl">
                                                    <input type="text" id="link_publico_input"
                                                        class="input flex-grow h-14 text-center sm:text-left bg-white dark:bg-zinc-900 border-blue-200 dark:border-blue-700 text-zinc-800 dark:text-zinc-200 font-mono text-sm"
                                                        readonly>
                                                    <button type="button" onclick="copiarLinkPublico()"
                                                        class="btn bg-blue-600 text-white hover:bg-blue-700 h-14 px-8 font-bold shadow-md w-full sm:w-auto shrink-0 transition-colors">
                                                        <span class="icon-[lucide--copy] me-2 text-xl"></span> Copiar
                                                        Link
                                                    </button>
                                                </div>
                                            </div>

                                            <div
                                                class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-3xl mx-auto mb-8">
                                                <div
                                                    class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded-xl p-6 text-center shadow-sm flex flex-col items-center justify-center">
                                                    <span
                                                        class="text-zinc-500 font-semibold text-sm uppercase tracking-wider mb-2">Total
                                                        de Respostas</span>
                                                    <span class="font-black text-5xl text-primary mb-4"
                                                        id="contador_respostas">0</span>
                                                    <button type="button" onclick="atualizarContagemAoVivo()"
                                                        class="text-sm font-semibold text-primary hover:text-primary-deep flex items-center gap-2 bg-primary/10 px-4 py-2 rounded-lg transition-colors">
                                                        <span class="icon-[lucide--refresh-cw] text-base"
                                                            id="icon_refresh"></span> Atualizar Agora
                                                    </button>
                                                </div>

                                                <div
                                                    class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded-xl p-6 shadow-sm flex flex-col justify-center">
                                                    <h5
                                                        class="text-zinc-800 dark:text-zinc-200 font-bold mb-4 flex items-center gap-2 border-b border-zinc-100 dark:border-zinc-700 pb-3">
                                                        <span class="icon-[lucide--pie-chart] text-primary"></span>
                                                        Divisão por Setores
                                                    </h5>
                                                    <div class="flex-grow overflow-auto max-h-[120px] pe-2"
                                                        id="lista_setores_painel">
                                                        <p class="text-sm text-zinc-500 text-center py-4">Nenhuma
                                                            resposta registrada ainda.</p>
                                                    </div>
                                                </div>
                                            </div>

                                            <div
                                                class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-6 border-t border-zinc-200 dark:border-zinc-800">
                                                <button type="button" onclick="voltarParaLista()"
                                                    class="btn border border-zinc-300 bg-white text-zinc-700 hover:bg-zinc-100 dark:bg-zinc-800 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-700 h-14 px-6 font-bold w-full sm:w-auto shadow-sm transition-colors">
                                                    <span class="icon-[lucide--log-out] me-2 text-lg"></span> Sair
                                                    (Manter Aberta)
                                                </button>

                                                <button type="button" onclick="irParaEtapa3()"
                                                    class="btn bg-primary text-white hover:bg-primary-deep h-14 px-8 font-bold shadow-lg shadow-primary/30 w-full sm:w-auto transition-colors">
                                                    <span class="icon-[lucide--monitor-smartphone] me-2 text-lg"></span>
                                                    Realizar Coleta por Aqui
                                                </button>
                                            </div>
                                        </div>
                                    </form>

                                    <div id="panel-step-3"
                                        class="wizard-panel hidden animate-fade-in max-w-3xl mx-auto">

                                        <div
                                            class="flex items-center justify-between mb-6 border-b border-zinc-200 dark:border-zinc-800 pb-4">
                                            <h3 class="text-xl font-black text-zinc-800 dark:text-zinc-100">Checklist
                                                Trabalhador</h3>
                                            <button type="button" onclick="voltarParaEtapa2()"
                                                class="btn btn-sm bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700 text-zinc-600 dark:text-zinc-300">
                                                <span class="icon-[lucide--arrow-left] me-1"></span> Voltar ao Painel
                                            </button>
                                        </div>

                                        <input type="hidden" id="hora_inicio_presencial" value="">

                                        <form id="formPresencial" onsubmit="enviarRespostaDashboard(event)">
                                            <div class="question-box border-l-4 border-l-primary">
                                                <label
                                                    class="block font-bold text-lg text-zinc-800 dark:text-zinc-100 mb-3"
                                                    for="setor_cargo_dashboard">
                                                    Qual o Setor ou Cargo do Trabalhador? <span
                                                        class="text-red-500">*</span>
                                                </label>
                                                <input type="text" id="setor_cargo_dashboard"
                                                    class="w-full bg-zinc-50 dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-700 text-zinc-900 dark:text-zinc-100 rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                                                    placeholder="Ex: Manutenção, Administrativo..." required>
                                            </div>

                                            <% const perguntasFrequencia=[ {id: 'q1' ,
                                                texto: 'Com que frequência você tem que fazer suas tarefas de trabalho com muita rapidez?'
                                                }, {id: 'q2' ,
                                                texto: 'Com que frequência você tem que trabalhar intensamente?' },
                                                {id: 'q3' , texto: 'Seu trabalho exige demais de você?' }, {id: 'q4' ,
                                                texto: 'Você tem tempo suficiente para cumprir todas as tarefas de seu trabalho?'
                                                }, {id: 'q5' ,
                                                texto: 'O seu trabalho costuma apresentar exigências contraditórias ou discordantes?'
                                                }, {id: 'q6' ,
                                                texto: 'Você tem possibilidade de aprender coisas novas em seu trabalho?'
                                                }, {id: 'q7' ,
                                                texto: 'Seu trabalho exige muita habilidade ou conhecimento especializado?'
                                                }, {id: 'q8' , texto: 'Seu trabalho exige que você tome iniciativas?' },
                                                {id: 'q9' ,
                                                texto: 'No seu trabalho, você tem que repetir muitas vezes as mesmas tarefas?'
                                                }, {id: 'q10' , texto: 'Você pode escolher COMO fazer seu trabalho?' },
                                                {id: 'q11' , texto: 'Você pode escolher O QUE fazer no seu trabalho?' }
                                                ]; const perguntasConcordancia=[ {id: 'q12' ,
                                                texto: 'Existe um ambiente calmo e agradável onde trabalho.' },
                                                {id: 'q13' ,
                                                texto: 'No trabalho, nos relacionamos bem uns com os outros.' },
                                                {id: 'q14' ,
                                                texto: 'Eu posso contar com o apoio dos meus colegas de trabalho.' },
                                                {id: 'q15' ,
                                                texto: 'Se eu não estiver num bom dia, meus colegas compreendem.' },
                                                {id: 'q16' , texto: 'No trabalho, me relaciono bem com meus chefes.' },
                                                {id: 'q17' , texto: 'Eu gosto de trabalhar com meus colegas.' } ]; %>

                                                <h3
                                                    class="font-bold text-lg text-zinc-800 dark:text-zinc-200 mt-8 mb-4 px-2">
                                                    Parte 1: Demandas e Controle</h3>

                                                <% perguntasFrequencia.forEach((p, idx)=> { %>
                                                    <div class="question-box">
                                                        <p
                                                            class="font-bold text-zinc-800 dark:text-zinc-200 mb-4 text-[1.05rem] leading-snug">
                                                            <span class="text-primary mr-1">
                                                                <%= idx + 1 %>.
                                                            </span>
                                                            <%= p.texto %> <span class="text-red-500">*</span>
                                                        </p>
                                                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                                                            <label class="h-full block">
                                                                <input type="radio" name="respostas_dash[<%= p.id %>]"
                                                                    value="Frequentemente" class="hidden radio-input">
                                                                <div class="radio-card">Frequentemente</div>
                                                            </label>
                                                            <label class="h-full block">
                                                                <input type="radio" name="respostas_dash[<%= p.id %>]"
                                                                    value="Às vezes" class="hidden radio-input">
                                                                <div class="radio-card">Às vezes</div>
                                                            </label>
                                                            <label class="h-full block">
                                                                <input type="radio" name="respostas_dash[<%= p.id %>]"
                                                                    value="Raramente" class="hidden radio-input">
                                                                <div class="radio-card">Raramente</div>
                                                            </label>
                                                            <label class="h-full block">
                                                                <input type="radio" name="respostas_dash[<%= p.id %>]"
                                                                    value="Nunca ou quase nunca"
                                                                    class="hidden radio-input">
                                                                <div class="radio-card">Nunca ou<br>quase nunca</div>
                                                            </label>
                                                        </div>
                                                    </div>
                                                    <% }) %>

                                                        <h3
                                                            class="font-bold text-lg text-zinc-800 dark:text-zinc-200 mt-8 mb-4 px-2">
                                                            Parte 2: Apoio Social</h3>

                                                        <% perguntasConcordancia.forEach((p, idx)=> { %>
                                                            <div class="question-box">
                                                                <p
                                                                    class="font-bold text-zinc-800 dark:text-zinc-200 mb-4 text-[1.05rem] leading-snug">
                                                                    <span class="text-primary mr-1">
                                                                        <%= idx + 12 %>.
                                                                    </span>
                                                                    <%= p.texto %> <span class="text-red-500">*</span>
                                                                </p>
                                                                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                                                                    <label class="h-full block">
                                                                        <input type="radio"
                                                                            name="respostas_dash[<%= p.id %>]"
                                                                            value="Concordo Totalmente"
                                                                            class="hidden radio-input">
                                                                        <div class="radio-card">Concordo<br>Totalmente
                                                                        </div>
                                                                    </label>
                                                                    <label class="h-full block">
                                                                        <input type="radio"
                                                                            name="respostas_dash[<%= p.id %>]"
                                                                            value="Concordo mais que discordo"
                                                                            class="hidden radio-input">
                                                                        <div class="radio-card">Concordo mais<br>que
                                                                            discordo</div>
                                                                    </label>
                                                                    <label class="h-full block">
                                                                        <input type="radio"
                                                                            name="respostas_dash[<%= p.id %>]"
                                                                            value="Discordo mais que concordo"
                                                                            class="hidden radio-input">
                                                                        <div class="radio-card">Discordo mais<br>que
                                                                            concordo</div>
                                                                    </label>
                                                                    <label class="h-full block">
                                                                        <input type="radio"
                                                                            name="respostas_dash[<%= p.id %>]"
                                                                            value="Discordo" class="hidden radio-input">
                                                                        <div class="radio-card">Discordo</div>
                                                                    </label>
                                                                </div>
                                                            </div>
                                                            <% }) %>

                                                                <div class="mt-8 mb-4">
                                                                    <button type="submit" id="btnEnviarDashboard"
                                                                        class="w-full bg-primary text-white font-black text-lg h-16 rounded-xl hover:bg-primary-deep transition-colors shadow-xl shadow-primary/30 flex items-center justify-center gap-2">
                                                                        Enviar Respostas <span
                                                                            class="icon-[lucide--send]"></span>
                                                                    </button>
                                                                </div>
                                        </form>

                                        <div id="telaSucessoPresencial"
                                            class="hidden text-center py-16 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl shadow-sm">
                                            <div
                                                class="size-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6">
                                                <span class="icon-[lucide--check-circle] text-4xl"></span>
                                            </div>
                                            <h2 class="text-2xl font-black text-zinc-800 dark:text-zinc-100 mb-2">Salvo
                                                com Sucesso!</h2>
                                            <p class="text-zinc-600 dark:text-zinc-400 mb-8">O questionário deste
                                                trabalhador foi registrado na base de dados.</p>

                                            <div class="flex flex-col sm:flex-row justify-center gap-4 px-6">
                                                <button type="button" onclick="voltarParaEtapa2()"
                                                    class="btn border border-zinc-300 bg-white text-zinc-700 hover:bg-zinc-100 dark:bg-zinc-800 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-700 h-12 px-6 font-bold w-full sm:w-auto shadow-sm">
                                                    <span class="icon-[lucide--pie-chart] me-2"></span> Voltar ao Painel
                                                </button>
                                                <button type="button" onclick="resetarEtapa3()"
                                                    class="btn bg-primary text-white hover:bg-primary-deep h-12 px-6 font-bold shadow-md w-full sm:w-auto">
                                                    <span class="icon-[lucide--user-plus] me-2"></span> Registrar Nova
                                                    Resposta
                                                </button>
                                            </div>
                                        </div>

                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                    <%- include('../partials/footer') %>
        </main>

        <div id="modal_contratante" role="dialog" class="modal fade fixed inset-0 z-[70]" tabindex="-1">
            <div class="modal-dialog pointer-events-none w-full h-full flex items-center justify-center p-4">
                <div
                    class="modal-content pointer-events-auto w-full max-w-[40rem] bg-white dark:bg-zinc-900 rounded-xl shadow-2xl border border-zinc-200 dark:border-zinc-800 flex flex-col max-h-[90vh]">
                    <div class="p-4 border-b border-zinc-200 dark:border-zinc-800 flex items-center justify-between">
                        <h5 class="text-lg font-bold">Selecione a Empresa</h5>
                        <button type="button" class="btn !p-2" data-bs-dismiss="modal" aria-label="Fechar">
                            <span class="icon-[lucide--x] text-lg"></span>
                        </button>
                    </div>
                    <div class="p-4 flex-grow overflow-hidden flex flex-col">
                        <div class="relative mb-3">
                            <input id="contratanteSearch" type="search" class="input !ps-9 w-full"
                                placeholder="Buscar empresa...">
                            <span
                                class="iconify icon-[lucide--search] pointer-events-none absolute start-0 top-0 h-full flex items-center justify-center ms-3 text-muted"></span>
                        </div>
                        <div class="flex-grow overflow-auto">
                            <table id="table_contratante_modal" class="w-full text-left border-collapse">
                                <thead class="border-b border-zinc-200 dark:border-zinc-800">
                                    <tr>
                                        <th class="py-2 text-sm font-semibold text-zinc-500 dark:text-zinc-400">Empresa
                                            / CNPJ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% clientes.forEach((c)=> { %>
                                        <tr class="border-b border-zinc-100 dark:border-zinc-800 cursor-pointer hover-row transition-colors"
                                            data-id="<%= c.id_cliente %>" data-nome="<%= c.nome_empresa %>">
                                            <td class="py-3 px-2">
                                                <div class="font-semibold text-zinc-900 dark:text-white">
                                                    <%= c.nome_empresa %>
                                                </div>
                                                <div class="text-xs text-zinc-400 font-normal">
                                                    <%= c.cnpj %>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>
        <script src="https://cdn.datatables.net/2.3.3/js/dataTables.js"></script>
        <script src="/vendor/js/sweetalert2.all.min.js"></script>

        <script>
            const dadosContinuacaoRaw = `<%- JSON.stringify(dadosContinuacao) %>`;
            const dadosContinuacao = JSON.parse(dadosContinuacaoRaw);
            const isContinuacaoJs = "<%= isContinuacao %>" === "true";

            $(document).ready(function () {
                document.getElementById('data_aplicacao').valueAsDate = new Date();

                const dtContratante = $('#table_contratante_modal').DataTable({
                    dom: 'rtip', paging: true, pageLength: 6, ordering: false, autoWidth: false,
                    language: {
                        emptyTable: "Nenhum registro encontrado", info: "Exibindo _START_ a _END_",
                        infoEmpty: "", infoFiltered: "", zeroRecords: "Nada encontrado",
                        paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    }
                });

                $('#contratanteSearch').on('keyup', function () { dtContratante.search(this.value).draw(); });

                $('#table_contratante_modal tbody').on('click', 'tr', function () {
                    const id = $(this).attr('data-id');
                    const nome = $(this).attr('data-nome');
                    if (id) {
                        $('#contratante_id').val(id);
                        $('#contratante_nome').val(nome);
                        const modalInst = bootstrap.Modal.getInstance(document.getElementById('modal_contratante'));
                        if (modalInst) modalInst.hide();
                    }
                });

                if (isContinuacaoJs) { irParaEtapa2(true); }
            });

            // ================= NAVEGAÇÃO ENTRE PASSOS =================
            function atualizarNav(stepAtivo) {
                document.querySelectorAll('.wizard-step').forEach(el => el.classList.remove('active', 'disabled'));

                if (stepAtivo === 1) {
                    document.getElementById('nav-step-1').classList.add('active');
                    document.getElementById('nav-step-2').classList.add('disabled');
                    document.getElementById('nav-step-3').classList.add('disabled');
                } else if (stepAtivo === 2) {
                    document.getElementById('nav-step-1').classList.add('disabled');
                    document.getElementById('nav-step-2').classList.add('active');
                    document.getElementById('nav-step-3').classList.add('disabled');
                } else {
                    document.getElementById('nav-step-1').classList.add('disabled');
                    document.getElementById('nav-step-2').classList.add('disabled');
                    document.getElementById('nav-step-3').classList.add('active');
                }
            }

            async function irParaEtapa2(isReload = false) {
                const idCliente = $('#contratante_id').val();
                const nomeCliente = $('#contratante_nome').val();
                if (!idCliente) return Swal.fire('Atenção', 'Selecione uma Empresa.', 'warning');

                if (!isReload) {
                    try {
                        const btn = document.querySelector('#panel-step-1 button');
                        const btnHtml = btn.innerHTML;
                        btn.disabled = true;
                        btn.innerHTML = '<span class="icon-[lucide--loader-2] animate-spin me-2"></span> Iniciando...';

                        await fetch('/checklist-stress/iniciar-sessao', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id_cliente: idCliente })
                        });
                        btn.disabled = false;
                        btn.innerHTML = btnHtml;
                    } catch (err) { console.error("Erro ao iniciar sessão", err); }
                }

                document.getElementById('lbl_empresa_painel').innerText = nomeCliente;
                const link = `${window.location.origin}/checklist-stress/responder/${idCliente}`;
                document.getElementById('link_publico_input').value = link;

                document.getElementById('panel-step-1').classList.remove('active', 'show');
                document.getElementById('panel-step-1').classList.add('hidden');
                document.getElementById('panel-step-3').classList.remove('active', 'show');
                document.getElementById('panel-step-3').classList.add('hidden');

                const panel2 = document.getElementById('panel-step-2');
                panel2.classList.remove('hidden');
                setTimeout(() => panel2.classList.add('active', 'show'), 50);

                atualizarNav(2);
                atualizarContagemAoVivo();
            }

            function irParaEtapa3() {
                document.getElementById('panel-step-2').classList.remove('active', 'show');
                document.getElementById('panel-step-2').classList.add('hidden');

                const panel3 = document.getElementById('panel-step-3');
                panel3.classList.remove('hidden');
                setTimeout(() => panel3.classList.add('active', 'show'), 50);

                // Inicia o cronômetro para o preenchimento presencial
                document.getElementById('hora_inicio_presencial').value = new Date().toISOString();

                atualizarNav(3);
            }

            function voltarParaEtapa2() {
                // Se estava na tela de sucesso, reseta ela pra próxima vez
                document.getElementById('telaSucessoPresencial').classList.add('hidden');
                document.getElementById('formPresencial').classList.remove('hidden');
                document.getElementById('formPresencial').reset();

                document.getElementById('panel-step-3').classList.remove('active', 'show');
                document.getElementById('panel-step-3').classList.add('hidden');

                const panel2 = document.getElementById('panel-step-2');
                panel2.classList.remove('hidden');
                setTimeout(() => panel2.classList.add('active', 'show'), 50);

                atualizarNav(2);
                atualizarContagemAoVivo(); // Atualiza o gráfico pois um novo formulário pode ter sido salvo
            }

            function resetarEtapa3() {
                document.getElementById('telaSucessoPresencial').classList.add('hidden');
                document.getElementById('formPresencial').classList.remove('hidden');
                document.getElementById('formPresencial').reset();
                document.getElementById('hora_inicio_presencial').value = new Date().toISOString();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            function voltarParaLista() {
                window.location.href = '/checklist-stress';
            }

            // ================= LÓGICA DO PAINEL (ETAPA 2) =================
            function copiarLinkPublico() {
                const link = document.getElementById('link_publico_input').value;
                navigator.clipboard.writeText(link).then(() => {
                    Swal.fire({
                        icon: 'success', title: 'Link Copiado!',
                        html: `Mande este link no grupo dos funcionários:<br><br><span class="text-xs text-blue-500 font-mono bg-zinc-100 p-2 rounded block break-all mt-2">${link}</span>`,
                        timer: 4000
                    });
                });
            }

            async function atualizarContagemAoVivo() {
                const idCliente = document.getElementById('contratante_id').value;
                const icone = document.getElementById('icon_refresh');
                const containerSetores = document.getElementById('lista_setores_painel');

                icone.classList.add('animate-spin');

                try {
                    const res = await fetch(`/checklist-stress/historico-setores?id_cliente=${idCliente}`);
                    const data = await res.json();

                    if (data.success) {
                        let totalGeral = 0;
                        let htmlSetores = '';

                        if (data.dados.length === 0) {
                            htmlSetores = '<p class="text-sm text-zinc-500 py-2">Nenhuma resposta registrada ainda.</p>';
                        } else {
                            data.dados.forEach(item => {
                                totalGeral += item.total;
                                const nomeSetor = item.setor_cargo || 'Setor não informado';
                                htmlSetores += `
                            <div class="flex justify-between items-center py-2 border-b border-zinc-100 dark:border-zinc-700/50 last:border-0">
                                <span class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 truncate pe-2">${nomeSetor}</span>
                                <span class="bg-primary/10 text-primary px-2.5 py-0.5 rounded-md text-xs font-bold">${item.total}</span>
                            </div>
                        `;
                            });
                        }

                        document.getElementById('contador_respostas').innerText = totalGeral;
                        containerSetores.innerHTML = htmlSetores;
                    }
                } catch (err) {
                    console.error("Erro ao buscar contagem:", err);
                } finally {
                    setTimeout(() => icone.classList.remove('animate-spin'), 500);
                }
            }

            // ================= LÓGICA DO FORMULÁRIO PRESENCIAL (ETAPA 3) =================
            async function enviarRespostaDashboard(e) {
                e.preventDefault();

                const btn = document.getElementById('btnEnviarDashboard');
                const form = document.getElementById('formPresencial');

                // Coleta respostas (repare que usei respostas_dash[] no HTML pra não dar conflito de names)
                const respostas = {};
                form.querySelectorAll('input[type="radio"]:checked').forEach(radio => {
                    const match = radio.name.match(/respostas_dash\[(.*?)\]/);
                    if (match) respostas[match[1]] = radio.value;
                });

                if (Object.keys(respostas).length < 17) {
                    return Swal.fire({
                        icon: 'warning', title: 'Atenção!',
                        text: 'Faltam ' + (17 - Object.keys(respostas).length) + ' respostas para finalizar.',
                        confirmButtonColor: '#1a5293'
                    });
                }

                btn.disabled = true;
                btn.innerHTML = '<span class="icon-[lucide--loader-2] animate-spin me-2"></span> Salvando...';

                const inicio = new Date(document.getElementById('hora_inicio_presencial').value);
                const duracao = Math.round((new Date() - inicio) / 1000);

                const payload = {
                    id_cliente: document.getElementById('contratante_id').value,
                    id_unidade: document.getElementById('dashboard_id_unidade').value,
                    setor_cargo: document.getElementById('setor_cargo_dashboard').value.trim(),
                    duracao_segundos: duracao,
                    respostas: respostas
                };

                try {
                    // Reutilizamos a mesma rota pública! Afinal, ela já tem a trava do ID e funciona perfeitamente.
                    const req = await fetch('/checklist-stress/responder/salvar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const res = await req.json();

                    if (res.success) {
                        form.classList.add('hidden');
                        document.getElementById('telaSucessoPresencial').classList.remove('hidden');
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    } else {
                        throw new Error(res.message);
                    }
                } catch (err) {
                    Swal.fire('Ops!', err.message || 'Ocorreu um erro ao salvar.', 'error');
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = 'Enviar Respostas <span class="icon-[lucide--send]"></span>';
                }
            }
        </script>
</body>

</html>