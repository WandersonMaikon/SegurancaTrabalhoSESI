                                <h5 class="text-xl mb-4 font-bold text-zinc-800">Coleta de Assinaturas</h5>
                                <p class="text-sm text-zinc-500 mb-6">Assine abaixo para validar as informações deste
                                    levantamento.</p>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                    <div class="flex flex-col items-center">
                                        <label class="font-bold text-zinc-700 mb-2">Responsável Técnico
                                            (Avaliador)</label>
                                        <div
                                            class="border-2 border-dashed border-zinc-300 rounded-lg overflow-hidden bg-white">
                                            <canvas id="canvasTecnico" width="400" height="200"
                                                class="touch-none cursor-crosshair"></canvas>
                                        </div>
                                        <button type="button" id="btnLimparTecnico"
                                            class="mt-2 text-sm text-red-500 font-semibold">
                                            <span class="icon-[lucide--eraser]"></span> Limpar Assinatura
                                        </button>
                                    </div>
                                    <div class="flex flex-col items-center">
                                        <label class="font-bold text-zinc-700 mb-2">Responsável da Empresa</label>
                                        <div
                                            class="border-2 border-dashed border-zinc-300 rounded-lg overflow-hidden bg-white">
                                            <canvas id="canvasEmpresa" width="400" height="200"
                                                class="touch-none cursor-crosshair"></canvas>
                                        </div>
                                        <button type="button" id="btnLimparEmpresa"
                                            class="mt-2 text-sm text-red-500 font-semibold">
                                            <span class="icon-[lucide--eraser]"></span> Limpar Assinatura
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="flex justify-between mt-6">
                                <button type="button" class="btn px-5 py-2 rounded-lg border border-zinc-200"
                                    onclick="changeStep(3)">Anterior</button>
                                <button type="submit" id="btnSalvar" class="btn bg-primary text-white h-10 px-4">
                                    <span class="icon-[lucide--save] me-2"></span> Atualizar Levantamento
                                </button>
                            </div>
                        </div>

                        <template id="tpl-epis">
                            <% if(typeof epis !=='undefined' ){ epis.forEach(function(e) { %>
                                <option value="<%= e.id_epi %>">
                                    <%= e.nome_equipamento %> (CA: <%= e.ca %>)
                                </option>
                                <% }); } %>
                        </template>
                        <template id="tpl-epcs">
                            <% if(typeof epcs !=='undefined' ){ epcs.forEach(function(ep) { %>
                                <option value="<%= ep.id_epc %>">
                                    <%= ep.nome %>
                                </option>
                                <% }); } %>
                        </template>
                    </form>
                </div>

                <div class="modal fade" id="modalRiscos" tabindex="-1" aria-labelledby="modalRiscosLabel"
                    aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-xl">
                        <div class="modal-content bg-white dark:bg-zinc-900 border-zinc-200 dark:border-zinc-800">
                            <div
                                class="modal-header border-b border-zinc-100 dark:border-zinc-800 p-4 flex justify-between items-center">
                                <h5 class="modal-title font-bold text-zinc-800 dark:text-zinc-100"
                                    id="modalRiscosLabel">Selecione os Riscos para Adicionar</h5>
                                <button type="button"
                                    class="text-zinc-500 hover:text-zinc-800 dark:hover:text-zinc-200 p-1"
                                    data-bs-dismiss="modal" aria-label="Close">
                                    <span class="icon-[lucide--x] text-2xl"></span>
                                </button>
                            </div>
                            <div class="modal-body p-6">
                                <div class="flex flex-col md:flex-row gap-4 mb-6">
                                    <div class="relative flex-grow">
                                        <input type="text" id="pesquisaRiscoModal" class="input w-full !ps-9"
                                            placeholder="Buscar por código ou nome do risco...">
                                        <span
                                            class="iconify icon-[lucide--search] pointer-events-none absolute start-0 top-0 h-full flex items-center justify-center ms-3 text-muted"></span>
                                    </div>
                                    <select id="filtroGrupoModal"
                                        class="input w-full md:w-64 bg-transparent cursor-pointer">
                                        <option value="">Todos os Grupos</option>
                                        <option value="Físicos">Físicos</option>
                                        <option value="Químicos">Químicos</option>
                                        <option value="Biológicos">Biológicos</option>
                                        <option value="Ergonômicos">Ergonômicos</option>
                                        <option value="Mecânicos">Mecânicos</option>
                                        <option value="Acidentes">Acidentes</option>
                                        <option value="Inespecífico">Inespecífico</option>
                                        <option value="Outros">Outros</option>
                                    </select>
                                </div>
                                <div class="overflow-x-auto">
                                    <table id="tabelaRiscosModal" class="table-default w-full whitespace-nowrap">
                                        <thead>
                                            <tr>
                                                <th class="text-left">Código</th>
                                                <th class="text-left">Grupo</th>
                                                <th class="text-left w-full">Nome do Risco</th>
                                                <th class="text-center">Ação</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <%- include('../partials/footer') %>
        </main>

        <div id="dados-riscos-json" style="display: none;">
            <%- typeof riscosJson !=='undefined' ? riscosJson : '[]' %>
        </div>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>
        <script src="https://cdn.datatables.net/2.3.3/js/dataTables.js"></script>
        <script src="https://cdn.datatables.net/select/3.0.1/js/dataTables.select.js"></script>
        <script src="https://cdn.datatables.net/select/3.0.1/js/select.dataTables.js"></script>
        <script src="/vendor/js/tom-select.complete.min.js"></script>
        <script src="/vendor/js/sweetalert2.all.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>

        <script>
            let padTecnico, padEmpresa;
            let dtRiscosModal; // Variável para a tabela do modal

            // ==========================================
            // DADOS CARREGADOS DO BANCO PARA EDIÇÃO (RISCOS)
            // ==========================================
            let riscosSalvos = [];
            try {
                const divRiscos = document.getElementById('dados-riscos-json');
                if (divRiscos && divRiscos.innerText.trim()) {
                    riscosSalvos = JSON.parse(divRiscos.innerText);
                }
            } catch (e) {
                console.error("Erro ao ler riscos:", e);
            }

            $(document).ready(function () {
                // Inicializa Signatures
                const canvasT = document.getElementById('canvasTecnico');
                const canvasE = document.getElementById('canvasEmpresa');
                padTecnico = new SignaturePad(canvasT, { backgroundColor: 'rgb(255, 255, 255)' });
                padEmpresa = new SignaturePad(canvasE, { backgroundColor: 'rgb(255, 255, 255)' });

                document.getElementById('btnLimparTecnico').addEventListener('click', () => padTecnico.clear());
                document.getElementById('btnLimparEmpresa').addEventListener('click', () => padEmpresa.clear());

                // Carrega imagens de assinatura do banco, se existirem
                const sigTec = `<%= levantamento.assinatura_avaliador || '' %>`;
                if (sigTec.includes('base64')) padTecnico.fromDataURL(sigTec);

                const sigEmp = `<%= levantamento.assinatura_responsavel_empresa || '' %>`;
                if (sigEmp.includes('base64')) padEmpresa.fromDataURL(sigEmp);

                // Mostrar campos "Outros" preenchidos
                document.querySelectorAll('input.input-checkbox:checked').forEach(cb => {
                    const targetId = cb.getAttribute('data-target');
                    if (targetId) {
                        const inputEl = document.getElementById(targetId);
                        if (inputEl) {
                            inputEl.classList.remove('invisible', 'opacity-0');
                        }
                    }
                });

                // Pré-carrega os Riscos Salvos na Interface
                carregarRiscosSalvos();

                // ==========================================
                // INICIALIZA A TABELA DO MODAL DE RISCOS
                // ==========================================
                dtRiscosModal = new DataTable('#tabelaRiscosModal', {
                    data: riscosSalvos, // Usando a mesma base de dados de riscos global
                    pageLength: 5,
                    lengthChange: false,
                    dom: 'lrtip', // Esconde a busca padrão do datatables para usar a nossa customizada
                    columns: [
                        { data: 'codigo_esocial', render: function (data, type, row) { return data || row.codigo_interno || '-'; } },
                        { data: 'tipo_risco' },
                        { data: 'nome_risco', className: 'font-bold' },
                        {
                            data: null,
                            orderable: false,
                            className: 'text-center',
                            render: function (data, type, row) {
                                // Escapa as aspas simples do nome do risco para não quebrar o onclick
                                const nomeLimpo = row.nome_risco.replace(/'/g, "\\'");
                                const cod = row.codigo_esocial || row.codigo_interno || '';
                                return `<button type="button" class="btn bg-primary text-white hover:bg-primary-deep px-3 py-1 text-sm font-semibold rounded-md" onclick="selecionarRiscoParaTela('${row.id_risco}', '${cod}', '${nomeLimpo}', '${row.tipo_risco}')">Adicionar</button>`;
                            }
                        }
                    ],
                    language: {
                        emptyTable: "Nenhum risco encontrado na base de dados.",
                        info: "Mostrando _START_ a _END_ de _TOTAL_ riscos",
                        paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    }
                });

                // Conecta a barra de busca customizada à tabela do modal
                document.getElementById('pesquisaRiscoModal').addEventListener('input', function (e) {
                    dtRiscosModal.search(e.target.value).draw();
                });

                // Conecta o filtro de grupo à tabela do modal (Coluna 1)
                document.getElementById('filtroGrupoModal').addEventListener('change', function (e) {
                    dtRiscosModal.column(1).search(e.target.value).draw();
                });
            });

            // ==========================================
            // FUNÇÃO QUE LIMPA O MODAL AO ABRIR (MÁGICA!)
            // ==========================================
            function limparBuscaRiscos() {
                document.getElementById('pesquisaRiscoModal').value = '';
                document.getElementById('filtroGrupoModal').value = '';
                if (dtRiscosModal) {
                    dtRiscosModal.search('').columns().search('').draw();
                }
            }

            // ==========================================
            // FUNÇÃO PARA MONTAR RISCOS SALVOS NA TELA
            // ==========================================
            function carregarRiscosSalvos() {
                if (!riscosSalvos || riscosSalvos.length === 0) return;

                // SE O SEU SISTEMA TRAZ APENAS OS RISCOS *DESTE* LEVANTAMENTO, ESTA LÓGICA RODA AQUI.
                // COMO NÃO SEI SE `riscosSalvos` É A LISTA GLOBAL OU SÓ A LISTA DELE,
                // O SCRIPT ABAIXO TENTA CARREGAR OS RISCOS QUE JÁ TEM FONTES/TEMPO SALVOS.
                riscosSalvos.forEach(risco => {
                    // Verifica se tem os campos preenchidos. Se tiver, recria na tela.
                    if (risco.fontes_geradoras || risco.tipo_tempo_exposicao) {
                        selecionarRiscoParaTela(risco.id_risco, (risco.codigo_esocial || risco.codigo_interno || ''), risco.nome_risco, risco.tipo_risco);

                        const items = document.querySelectorAll('.risk-item');
                        const lastItem = items[items.length - 1];

                        lastItem.querySelector('.risk-checkbox').checked = true;
                        lastItem.querySelector('.risk-detail').classList.remove('hidden');

                        lastItem.querySelector('.risk-fontes').value = risco.fontes_geradoras || '';
                        lastItem.querySelector('.risk-tempo').value = risco.tipo_tempo_exposicao || '';
                        lastItem.querySelector('.risk-obs').value = risco.observacoes || '';

                        const tomEpi = lastItem.querySelector('.risk-epis').tomselect;
                        if (tomEpi && risco.epis) {
                            risco.epis.forEach(epiId => tomEpi.addItem(epiId));
                        }

                        const tomEpc = lastItem.querySelector('.risk-epcs').tomselect;
                        if (tomEpc && risco.epcs) {
                            risco.epcs.forEach(epcId => tomEpc.addItem(epcId));
                        }
                    }
                });
            }

            // ==========================================
            // FUNÇÕES GERAIS (MANTIDAS DA TELA NOVO)
            // ==========================================
            function changeStep(step) {
                document.querySelectorAll('.step-content').forEach(el => el.classList.remove('active'));
                document.getElementById(`step${step}`).classList.add('active');

                document.querySelectorAll('.nav-link').forEach(el => {
                    el.classList.remove('active');
                    if (el.dataset.step == step) el.classList.add('active');
                });
                window.scrollTo(0, 0);
            }

            function addGesRow() {
                document.getElementById('emptyGes').style.display = 'none';
                const tbody = document.querySelector('#tableGes tbody');
                const row = document.createElement('tr');
                row.className = "hover-row border-b border-zinc-100 dark:border-zinc-800 transition-colors";
                row.innerHTML = `
            <td class="pl-6 pr-2 py-3"><input type="text" class="table-input ges-setor font-medium" placeholder="Ex: Produção"></td>
            <td class="px-2 py-3"><input type="text" class="table-input ges-cargos" placeholder="Ex: Op. Máquina"></td>
            <td class="px-2 py-3"><input type="text" class="table-input ges-excecao" placeholder="-"></td>
            <td class="px-2 py-3"><input type="text" class="table-input ges-obs" placeholder="Opcional"></td>
            <td class="pr-6 pl-2 py-3 text-center">
                <button type="button" onclick="this.closest('tr').remove()" class="text-zinc-400 hover:text-red-500 transition-colors p-1" title="Remover"><span class="icon-[lucide--trash-2]"></span></button>
            </td>`;
                tbody.appendChild(row);
            }

            function addQuimicoRow() {
                document.getElementById('emptyQuimico').style.display = 'none';
                const tbody = document.querySelector('#tableQuimico tbody');
                const row = document.createElement('tr');
                row.className = "hover-row border-b border-zinc-100 dark:border-zinc-800 transition-colors";
                row.innerHTML = `
            <td class="pl-6 pr-2 py-3"><input type="text" class="table-input quim-rotulo font-medium" placeholder="Nome do produto"></td>
            <td class="px-2 py-3">
                <select class="table-input quim-estado cursor-pointer bg-transparent">
                    <option value="Líquido">Líquido</option><option value="Sólido">Sólido</option><option value="Gasoso">Gasoso</option>
                </select>
            </td>
            <td class="px-2 py-3"><input type="text" class="table-input quim-exposicao" placeholder="Ex: Cutânea"></td>
            <td class="px-2 py-3"><input type="text" class="table-input quim-processo" placeholder="Ex: Limpeza/500ml"></td>
            <td class="px-2 py-3"><input type="text" class="table-input quim-obs" placeholder="Opcional"></td>
            <td class="pr-6 pl-2 py-3 text-center">
                <button type="button" onclick="this.closest('tr').remove()" class="text-zinc-400 hover:text-red-500 transition-colors p-1" title="Remover"><span class="icon-[lucide--trash-2]"></span></button>
            </td>`;
                tbody.appendChild(row);
            }

            function toggleAccordion(id) { document.getElementById(id)?.classList.toggle('hidden'); }

            function toggleRiskDetail(checkbox) {
                const detailDiv = checkbox.closest('.risk-item').querySelector('.risk-detail');
                if (checkbox.checked) {
                    detailDiv.classList.remove('hidden');
                    detailDiv.querySelectorAll('select').forEach(s => { if (!s.tomselect) new TomSelect(s, { plugins: ['remove_button'] }); });
                } else { detailDiv.classList.add('hidden'); }
            }

            function handleCheckRadio(clickedCheckbox) {
                const groupName = clickedCheckbox.name;
                const allCheckboxes = document.querySelectorAll(`input[name="${groupName}"]`);
                allCheckboxes.forEach(cb => { if (cb !== clickedCheckbox) cb.checked = false; });

                allCheckboxes.forEach(cb => {
                    const targetId = cb.getAttribute('data-target');
                    if (targetId) {
                        const inputEl = document.getElementById(targetId);
                        if (inputEl) {
                            if (cb.checked) {
                                inputEl.classList.remove('invisible', 'opacity-0');
                                inputEl.focus();
                            } else {
                                inputEl.classList.add('invisible', 'opacity-0');
                                inputEl.value = '';
                            }
                        }
                    }
                });
            }

            function selecionarRiscoParaTela(id_risco, codigo, nome, grupo) {
                // Tenta fechar o Modal se ele estiver aberto usando Bootstrap 5 via CDN
                try {
                    const myModalEl = document.getElementById('modalRiscos');
                    const modalInstance = bootstrap.Modal.getInstance(myModalEl);
                    if (modalInstance) modalInstance.hide();
                } catch (e) { }

                // Normaliza o nome do grupo para criar os blocos e bordas (Físicos, Químicos...)
                const grupoSafe = grupo || 'Indefinido';
                const grupoId = 'grupo_' + grupoSafe.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '_').toLowerCase();
                let containerDinamico = document.getElementById('container_riscos_dinamicos');
                let accordionGrupo = document.getElementById(grupoId);

                if (!accordionGrupo) {
                    accordionGrupo = document.createElement('div');
                    accordionGrupo.id = grupoId;
                    accordionGrupo.className = 'border border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden mt-4';

                    let corBorda = 'border-zinc-500';
                    if (grupoSafe.toLowerCase().includes('físico')) corBorda = 'border-green-500';
                    else if (grupoSafe.toLowerCase().includes('químico')) corBorda = 'border-red-500';
                    else if (grupoSafe.toLowerCase().includes('biológico')) corBorda = 'border-amber-700';
                    else if (grupoSafe.toLowerCase().includes('ergonômico')) corBorda = 'border-yellow-500';
                    else if (grupoSafe.toLowerCase().includes('mecânico') || grupoSafe.toLowerCase().includes('acidente')) corBorda = 'border-sky-500';

                    accordionGrupo.innerHTML = `
                <button type="button" class="w-full text-left p-4 bg-zinc-50 dark:bg-zinc-800 font-bold flex justify-between items-center text-zinc-700 dark:text-zinc-200 hover:bg-zinc-100 transition-colors border-l-4 ${corBorda}" onclick="toggleAccordion('acc_${grupoId}')">
                    ${grupoSafe.toUpperCase()} <span class="icon-[lucide--chevron-down]"></span>
                </button>
                <div id="acc_${grupoId}" class="p-4 bg-white dark:bg-zinc-900 block">
                    <div class="grid grid-cols-1 gap-4 grid-riscos"></div>
                </div>`;
                    containerDinamico.appendChild(accordionGrupo);
                }

                const gridRiscos = accordionGrupo.querySelector('.grid-riscos');

                // Evita inserir duplicado
                if (gridRiscos.querySelector(`[data-id_risco="${id_risco}"]`)) {
                    Swal.fire('Atenção', 'Este risco já foi adicionado!', 'warning');
                    return;
                }

                const optionsEPI = document.getElementById('tpl-epis').innerHTML;
                const optionsEPC = document.getElementById('tpl-epcs').innerHTML;

                const riskItem = document.createElement('div');
                riskItem.className = 'risk-item border border-zinc-100 dark:border-zinc-800 rounded-lg p-4 bg-zinc-50/50 dark:bg-zinc-900/50';

                riskItem.innerHTML = `
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 border-b border-zinc-200 dark:border-zinc-800 pb-3">
                <label class="inline-flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" class="input-checkbox risk-checkbox" data-id_risco="${id_risco}" data-grupo="${grupoSafe}" data-codigo="${codigo}" data-nome="${nome}" onchange="toggleRiskDetail(this)">
                    <span class="font-bold text-zinc-700 dark:text-zinc-200 text-lg">${nome}</span>
                </label>
                <button type="button" onclick="removerRiscoDaTela(this, '${grupoId}')" class="text-red-500 hover:text-red-700 text-sm font-bold flex items-center gap-1 mt-2 sm:mt-0 px-3 py-1 hover:bg-red-50 dark:hover:bg-red-500/10 rounded-md"><span class="icon-[lucide--trash]"></span> Remover</button>
            </div>
            
            <div class="risk-detail hidden grid grid-cols-1 md:grid-cols-2 gap-4">
                <div><label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">Fontes Geradoras</label><input type="text" class="table-input w-full text-sm risk-fontes"></div>
                <div><label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">Tempo/Tipo Exp.</label><input type="text" class="table-input w-full text-sm risk-tempo"></div>
                <div><label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">EPIs Recomendados</label><select class="risk-epis w-full table-input select-plugin" multiple>${optionsEPI}</select></div>
                <div><label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">EPCs Existentes</label><select class="risk-epcs w-full table-input select-plugin" multiple>${optionsEPC}</select></div>
                <div><label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">Anexar Imagem</label><input type="file" accept="image/*" class="table-input risk-imagem"></div>
                <div class="md:col-span-2"><label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">Observações</label><input type="text" class="table-input w-full text-sm risk-obs"></div>
            </div>`;

                gridRiscos.appendChild(riskItem);

                // Inicializa o TomSelect nos novos selects criados
                riskItem.querySelectorAll('select.select-plugin').forEach(s => {
                    if (!s.tomselect) new TomSelect(s, { plugins: ['remove_button'] });
                });

                Swal.fire({
                    toast: true, position: 'top-end', icon: 'success', title: 'Risco adicionado ao formulário',
                    showConfirmButton: false, timer: 1500
                });
            }

            function removerRiscoDaTela(botao, grupoId) {
                const riskItem = botao.closest('.risk-item');
                const gridRiscos = riskItem.parentNode;
                riskItem.remove();
                if (gridRiscos.children.length === 0) document.getElementById(grupoId).remove();
            }

            // ==========================================
            // SUBMIT DE EDIÇÃO (APONTA PARA POST AGORA)
            // ==========================================
            document.getElementById('formLevantamento').addEventListener('submit', async (e) => {
                e.preventDefault();

                const id_levantamento = document.getElementById('id_levantamento').value;

                const assinatura_avaliador = padTecnico.isEmpty() ? '' : padTecnico.toDataURL('image/png');
                const assinatura_responsavel_empresa = padEmpresa.isEmpty() ? '' : padEmpresa.toDataURL('image/png');

                const getRadioVal = (n) => {
                    const c = document.querySelector(`input[name="${n}"]:checked`);
                    if (!c) return null;
                    const t = c.getAttribute('data-target');
                    return { selecionado: c.value, outros: t ? document.getElementById(t).value : '' };
                };

                const gesData = Array.from(document.querySelectorAll('#tableGes tbody tr')).map(tr => ({
                    setor: tr.querySelector('.ges-setor').value, cargos: tr.querySelector('.ges-cargos').value,
                    excecao: tr.querySelector('.ges-excecao').value, obs: tr.querySelector('.ges-obs').value
                })).filter(g => g.setor || g.cargos || g.excecao || g.obs);

                const quimData = Array.from(document.querySelectorAll('#tableQuimico tbody tr')).map(tr => ({
                    rotulo: tr.querySelector('.quim-rotulo').value, estado: tr.querySelector('.quim-estado').value,
                    exposicao: tr.querySelector('.quim-exposicao').value, processo: tr.querySelector('.quim-processo').value,
                    obs: tr.querySelector('.quim-obs').value
                })).filter(q => q.rotulo || q.estado || q.exposicao || q.processo || q.obs);

                const riscosData = [];
                const formDataEnvio = new FormData();
                let indexRisco = 0;

                document.querySelectorAll('.risk-checkbox:checked').forEach(cb => {
                    const item = cb.closest('.risk-item');
                    const sEpi = item.querySelector('.risk-epis');
                    const sEpc = item.querySelector('.risk-epcs');
                    const fileInput = item.querySelector('.risk-imagem');

                    riscosData.push({
                        id_risco: cb.dataset.id_risco, grupo: cb.dataset.grupo, codigo: cb.dataset.codigo, nome: cb.dataset.nome,
                        fontes: item.querySelector('.risk-fontes').value, tempo: item.querySelector('.risk-tempo').value, obs: item.querySelector('.risk-obs').value,
                        epis: sEpi.tomselect ? sEpi.tomselect.getValue() : [], epcs: sEpc.tomselect ? sEpc.tomselect.getValue() : []
                    });

                    if (fileInput && fileInput.files.length > 0) formDataEnvio.append('imagem_' + indexRisco, fileInput.files[0]);
                    indexRisco++;
                });

                const formData = new FormData(e.target);
                const payload = Object.fromEntries(formData.entries());

                Object.assign(payload, {
                    tipo_construcao: getRadioVal('tipo_construcao'), tipo_piso: getRadioVal('tipo_piso'), tipo_paredes: getRadioVal('tipo_paredes'),
                    tipo_forro: getRadioVal('tipo_forro'), tipo_iluminacao: getRadioVal('tipo_iluminacao'), tipo_ventilacao: getRadioVal('tipo_ventilacao'),
                    escadas_tipo: getRadioVal('escadas_tipo'), passarelas_tipo: getRadioVal('passarelas_tipo'),
                    nome_grupo_ges: document.getElementById('nome_grupo_ges').value.trim(),
                    tipo_cobertura: { selecionado: [payload.cobertura_tipo_estrutura, payload.cobertura_tipo_telha].filter(Boolean).join(' - ') || '-' },
                    divisoes_internas_material: { selecionado: payload.divisoes_internas_material || '-' },
                    estruturas_auxiliares: [
                        document.querySelector('input[name="tem_rampas"]:checked')?.value === '1' ? 'Rampas' : null,
                        document.querySelector('input[name="tem_mezaninos"]:checked')?.value === '1' ? 'Mezaninos' : null
                    ].filter(Boolean),
                    ausencia_risco_ambiental: document.querySelector('input[name="ausencia_risco_ambiental"]')?.checked || false,
                    ausencia_risco_ergonomico: document.querySelector('input[name="ausencia_risco_ergonomico"]')?.checked || false,
                    ausencia_risco_mecanico: document.querySelector('input[name="ausencia_risco_mecanico"]')?.checked || false,
                    ausencia_risco_quimico: document.querySelector('input[name="ausencia_risco_quimico"]')?.checked || false,
                    ausencia_risco_biologico: document.querySelector('input[name="ausencia_risco_biologico"]')?.checked || false,
                    trabalho_externo: document.querySelector('input[name="trabalho_externo"]:checked')?.value === '1',
                    possui_climatizacao: document.querySelector('input[name="possui_climatizacao"]:checked')?.value === '1',
                    ges: gesData, quimicos: quimData, riscos: riscosData,
                    assinatura_avaliador, assinatura_responsavel_empresa
                });

                formDataEnvio.append('dados_json', JSON.stringify(payload));

                const btn = document.getElementById('btnSalvar');
                const oldHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="icon-[lucide--loader-2] animate-spin me-2"></span> Atualizando...';

                try {
                    // Rota corrigida para POST
                    const res = await fetch(`/levantamento-perigo/editar/${id_levantamento}`, {
                        method: 'POST',
                        body: formDataEnvio
                    });
                    const result = await res.json();

                    if (result.success) {
                        Swal.fire('Sucesso', 'Levantamento atualizado com sucesso!', 'success').then(() => window.location.href = '/levantamento-perigo');
                    } else {
                        Swal.fire('Erro', result.message, 'error');
                    }
                } catch (err) {
                    Swal.fire('Erro', 'Falha na comunicação com o servidor.', 'error');
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = oldHtml;
                }
            });
        </script>
</body>

</html>