                                                                        value="Outros" class="input-checkbox"
                                                                        data-target="input_iluminacao_outro"
                                                                        onclick="handleCheckRadio(this)"
                                                                        <%=checkInc('tipo_iluminacao', 'Outros' ) %>>
                                                                    <span>Outros</span>
                                                                </label>
                                                                <input type="text" id="input_iluminacao_outro"
                                                                    name="tipo_iluminacao_outro"
                                                                    class="table-input w-40 invisible opacity-0 transition-opacity duration-200">
                                                            </div>
                                                        </div>
                                                    </td>
