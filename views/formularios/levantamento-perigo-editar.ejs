<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Levantamento - ProS</title>

    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/vendor/css/tom-select.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.3/css/dataTables.dataTables.css">

    <style>
        .step-content {
            display: none;
        }

        .step-content.active {
            display: block;
        }

        .hidden {
            display: none !important;
        }

        .table-input {
            width: 100%;
            background: transparent;
            border: none;
            border-bottom: 1px solid #e4e4e7;
            padding: 4px 0;
            outline: none;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }

        .dark .table-input {
            border-bottom-color: #3f3f46;
            color: #e4e4e7;
        }

        .table-input:focus {
            border-bottom-color: var(--primary-color, #0AA34A);
        }

        .hover-row:hover {
            background-color: #f8fafc;
        }

        .dark .hover-row:hover {
            background-color: #18181b;
        }

        .hover-row td .flex-wrap>label,
        .hover-row td .flex-wrap>div {
            margin-right: 2.5rem !important;
            margin-bottom: 0.5rem !important;
        }

        .hover-row td .flex-wrap label span {
            white-space: nowrap;
            padding-right: 0.25rem;
        }
    </style>

    <script>
        (function () {
            try {
                var theme = localStorage.getItem('theme');
                if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }

                var sidebarTheme = localStorage.getItem('sidebarTheme');
                if (sidebarTheme) {
                    document.documentElement.setAttribute('data-sidebar-theme', sidebarTheme);
                } else if (theme === 'dark') {
                    document.documentElement.setAttribute('data-sidebar-theme', 'dark');
                }
            } catch (e) { }
        })();
    </script>
</head>

<body
    class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content">
            <%- include('../partials/header') %>

                <div class="px-4 lg:px-10 py-6">
                    <h2 class="text-2xl mb-4 text-zinc-800 dark:text-zinc-100 font-bold">Editar Levantamento de Perigos
                        #<%= levantamento.id_levantamento %>
                    </h2>

                    <nav
                        class="nav-horizontal nav-underline gap-4 flex flex-nowrap mb-6 overflow-x-auto pb-1 border-b border-zinc-200 dark:border-zinc-700">
                        <a href="#" class="nav-link active whitespace-nowrap" onclick="changeStep(1); return false;"
                            data-step="1"><span class="icon-[lucide--file-text] text-lg"></span> Dados & Ambiente</a>
                        <a href="#" class="nav-link whitespace-nowrap" onclick="changeStep(2); return false;"
                            data-step="2"><span class="icon-[lucide--flask-conical] text-lg"></span> GES & Químicos</a>
                        <a href="#" class="nav-link whitespace-nowrap" onclick="changeStep(3); return false;"
                            data-step="3"><span class="icon-[lucide--alert-triangle] text-lg"></span> Identificação de
                            Perigos</a>
                        <a href="#" class="nav-link whitespace-nowrap" onclick="changeStep(4); return false;"
                            data-step="4"><span class="icon-[lucide--pen-tool] text-lg"></span> Assinaturas</a>
                    </nav>
                </div>

                <div class="content flex-grow px-4 lg:px-10 pb-10">
                    <form id="formLevantamento" class="w-full">
                        <input type="hidden" id="id_levantamento" value="<%= levantamento.id_levantamento %>">

                        <div id="step1" class="step-content active space-y-6">
