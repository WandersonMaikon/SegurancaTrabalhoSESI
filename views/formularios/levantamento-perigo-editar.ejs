                                    <button type="button" data-bs-toggle="modal" data-bs-target="#modalRiscos"
                                        onclick="limparBuscaRiscos()"
                                        class="btn bg-primary text-white hover:bg-primary-deep h-10 px-4">
                                        <span class="icon-[lucide--search] text-lg me-1 leading-none"></span> Adicionar
                                        Risco
                                    </button>
                                </div>

                                <div id="container_riscos_dinamicos" class="space-y-4">
                                </div>


                            </div>
                            <div class="flex justify-between mt-6">
                                <button type="button"
                                    class="btn px-5 py-2 rounded-lg border border-zinc-200 hover:bg-zinc-100 transition-colors font-medium"
                                    onclick="changeStep(2)">Anterior</button>

                                <button type="button"
                                    class="btn bg-primary text-white hover:bg-primary-deep h-10 px-4 shadow-lg shadow-primary/20 transition-colors font-medium"
                                    onclick="changeStep(4)">
                                    Próximo <span class="icon-[lucide--arrow-right] ms-2"></span>
                                </button>
                            </div>
                        </div>

                        <div id="step4" class="step-content space-y-6">
                            <div
                                class="rounded-xl bg-white dark:bg-zinc-900 shadow-card border border-zinc-200 dark:border-zinc-800 p-6">
                                <h5 class="text-xl mb-4 font-bold text-zinc-800 dark:text-zinc-100">Assinaturas
                                    Registradas</h5>
                                <p class="text-sm text-zinc-500 mb-6">As assinaturas deste levantamento estão validadas
                                    e bloqueadas para edição.</p>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                    <div class="flex flex-col items-center">
                                        <label class="font-bold text-zinc-700 dark:text-zinc-300 mb-2">Responsável
                                            Técnico (Avaliador)</label>
                                        <div
                                            class="border-2 border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden bg-white flex items-center justify-center w-[400px] h-[200px]">
                                            <% if (levantamento.assinatura_avaliador) { %>
                                                <img src="<%= levantamento.assinatura_avaliador %>"
                                                    alt="Assinatura Avaliador"
                                                    class="max-w-full max-h-full object-contain pointer-events-none">
                                                <% } else { %>
                                                    <span class="text-zinc-400 italic">Sem assinatura</span>
                                                    <% } %>
                                        </div>
                                    </div>

                                    <div class="flex flex-col items-center">
                                        <label class="font-bold text-zinc-700 dark:text-zinc-300 mb-2">Responsável da
                                            Empresa</label>
                                        <div
                                            class="border-2 border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden bg-white flex items-center justify-center w-[400px] h-[200px]">
                                            <% if (levantamento.assinatura_responsavel_empresa) { %>
                                                <img src="<%= levantamento.assinatura_responsavel_empresa %>"
                                                    alt="Assinatura Empresa"
                                                    class="max-w-full max-h-full object-contain pointer-events-none">
                                                <% } else { %>
                                                    <span class="text-zinc-400 italic">Sem assinatura</span>
                                                    <% } %>
                                        </div>
                                    </div>
                                </div>

                                <input type="hidden" id="assinatura_avaliador_hidden"
                                    value="<%= levantamento.assinatura_avaliador || '' %>">
                                <input type="hidden" id="assinatura_empresa_hidden"
                                    value="<%= levantamento.assinatura_responsavel_empresa || '' %>">
                            </div>

                            <div class="flex justify-between mt-6">
                                <button type="button"
                                    class="btn px-5 py-2 rounded-lg border border-zinc-200 hover:bg-zinc-100 transition-colors font-medium"
                                    onclick="changeStep(3)">Anterior</button>
                                <button type="submit" id="btnSalvar"
                                    class="btn bg-primary text-white hover:bg-primary-deep h-10 px-4 shadow-lg shadow-primary/20 transition-colors font-medium">
                                    <span class="icon-[lucide--save] me-2"></span> Atualizar Levantamento
                                </button>
