                                                                        <%=checkInc('tipo_piso', 'Outros' ) %>>
                                                                    <span>Outros</span>
                                                                </label>
                                                                <input type="text" id="input_piso_outro"
                                                                    name="tipo_piso_outro"
                                                                    class="table-input w-40 invisible opacity-0 transition-opacity duration-200">
                                                            </div>
