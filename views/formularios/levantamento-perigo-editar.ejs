        <div class="modal fade" id="modalRiscos" role="dialog" class="fixed inset-0 z-[70]" tabindex="-1">
            <div class="modal-dialog pointer-events-none w-full h-full flex items-center justify-center p-4">
                <div
                    class="modal-content pointer-events-auto w-full max-w-[40rem] bg-white dark:bg-zinc-900 rounded-xl shadow-2xl border border-zinc-200 dark:border-zinc-800 flex flex-col max-h-[90vh]">
                    <div
                        class="modal-header border-b border-zinc-100 dark:border-zinc-800 p-4 flex justify-between items-center">
                        <h5 class="modal-title font-bold text-zinc-800 dark:text-zinc-100" id="modalRiscosLabel">
                            <span class="icon-[lucide--search] text-blue-600 me-2"></span> Selecione os Riscos para
                            Adicionar
                        </h5>
                        <button type="button"
                            class="btn !p-2 text-zinc-500 hover:text-zinc-800 dark:hover:text-zinc-200"
                            data-bs-dismiss="modal" aria-label="Close">
                            <span class="icon-[lucide--x] text-2xl"></span>
                        </button>
                    </div>
                    <div class="modal-body p-6 flex-grow overflow-hidden flex flex-col">
                        <div class="flex flex-col md:flex-row gap-4 mb-6">
                            <div class="relative flex-grow">
                                <input type="text" id="pesquisaRiscoModal" class="input w-full !ps-9"
                                    placeholder="Buscar por código ou nome do risco..." onkeyup="filtrarRiscosModal()">
                                <span
                                    class="iconify icon-[lucide--search] pointer-events-none absolute start-0 top-0 h-full flex items-center justify-center ms-3 text-muted"></span>
                            </div>
                            <select id="filtroGrupoModal" class="input w-full md:w-64 bg-transparent cursor-pointer">
                                <option value="">Todos os Grupos</option>
                                <option value="Físicos">Físicos</option>
                                <option value="Químicos">Químicos</option>
                                <option value="Biológicos">Biológicos</option>
                                <option value="Ergonômicos">Ergonômicos</option>
                                <option value="Mecânicos">Mecânicos</option>
                                <option value="Acidentes">Acidentes</option>
                                <option value="Inespecífico">Inespecífico</option>
                                <option value="Outros">Outros</option>
                            </select>
                        </div>
                        <div class="overflow-x-auto border border-zinc-100 dark:border-zinc-800 rounded-lg flex-grow">
                            <table id="tabelaRiscosModal" class="table-default w-full whitespace-nowrap">
                                <thead
                                    class="border-b border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-800/50 sticky top-0 z-10">
                                    <tr>
                                        <th
                                            class="py-2 px-3 text-sm font-semibold text-zinc-500 dark:text-zinc-400 text-left w-full">
                                            Nome do Risco</th>
                                        <th
                                            class="py-2 px-3 text-sm font-semibold text-zinc-500 dark:text-zinc-400 text-left">
                                            Grupo</th>
                                        <th
                                            class="py-2 px-3 text-sm font-semibold text-zinc-500 dark:text-zinc-400 text-left">
                                            eSocial</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (typeof todosRiscos !=='undefined' && todosRiscos && todosRiscos.length> 0) {
                                        %>
                                        <% todosRiscos.forEach(function(r) { %>
                                            <% let badgeClass='bg-zinc-100 text-zinc-500' ; let g=r.tipo_risco ||
                                                r.grupo || '' ; if (g==='Físicos' )
                                                badgeClass='bg-green-500/10 text-green-500' ; else if (g==='Químicos' )
                                                badgeClass='bg-red-500/10 text-red-500' ; else if (g==='Biológicos' )
                                                badgeClass='bg-yellow-600/10 text-yellow-600' ; else if
                                                (g==='Ergonômicos' ) badgeClass='bg-yellow-500/10 text-yellow-500' ;
                                                else if (g==='Mecânicos' || g==='Acidentes' )
                                                badgeClass='bg-sky-500/10 text-sky-500' ; else if (g==='Inespecífico' )
                                                badgeClass='bg-purple-500/10 text-purple-500' ; else if
                                                (g==='Associações' || g==='Outros' )
                                                badgeClass='bg-zinc-500/10 text-zinc-500' ; else if
                                                (g==='Ausência de Riscos' ) badgeClass='bg-slate-500/10 text-slate-500'
                                                ; let nomeSeguro=(r.nome_risco || r.nome).replace(/'/g, "\\'" ); let
                                                codigoSeguro=r.codigo_esocial || r.codigo_interno || r.esocial || '' ;
                                                %>
                                                <tr class="border-b border-zinc-100 dark:border-zinc-800 hover-row transition-colors linha-risco cursor-pointer"
                                                    onclick="selecionarRiscoParaTela('<%= r.id_risco %>', '<%= codigoSeguro %>', '<%= nomeSeguro %>', '<%= g %>')">

                                                    <td
                                                        class="py-3 px-3 text-sm font-semibold text-zinc-900 dark:text-white col-nome whitespace-normal break-words max-w-lg">
                                                        <%= r.nome_risco || r.nome %>
                                                    </td>
                                                    <td class="py-3 px-3 col-grupo">
                                                        <span
                                                            class="badge px-2 py-1 rounded text-xs font-semibold <%= badgeClass %>">
                                                            <%= g %>
                                                        </span>
                                                    </td>
                                                    <td class="py-3 px-3 text-sm text-zinc-600 dark:text-zinc-300">
                                                        <%= r.esocial || r.codigo_esocial || '-' %>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="dados-riscos-salvos" style="display: none;">
            <%- (typeof levantamento !=='undefined' && levantamento.riscos) ? (typeof levantamento.riscos==='string' ?
                levantamento.riscos : JSON.stringify(levantamento.riscos)) : '[]' %>
        </div>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>
        <script src="https://cdn.datatables.net/2.3.3/js/dataTables.js"></script>
        <script src="/vendor/js/tom-select.complete.min.js"></script>
        <script src="/vendor/js/sweetalert2.all.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>

        <script>
            let dtRiscosModal;

            $(document).ready(function () {

                document.querySelectorAll('input.input-checkbox:checked').forEach(cb => {
                    const targetId = cb.getAttribute('data-target');
                    if (targetId) {
                        const inputEl = document.getElementById(targetId);
                        if (inputEl) inputEl.classList.remove('invisible', 'opacity-0');
                    }
                });

                // ==========================================
                // INICIALIZA A TABELA DO MODAL DE CLIENTES
                // ==========================================
                const modalEl = document.getElementById('modal_cliente');
                const dtCliente = $('#table_cliente_modal').DataTable({
                    dom: 'rtip', paging: true, pageLength: 6, ordering: false, autoWidth: false,
                    language: {
                        emptyTable: "Nenhum registro encontrado", info: "Exibindo _START_ a _END_ de _TOTAL_",
                        infoEmpty: "Nenhum registro", infoFiltered: "(filtrado de _MAX_)",
                        zeroRecords: "Nada encontrado", paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    }
                });

                $('#clienteSearch').on('keyup', function () { dtCliente.search(this.value).draw(); });

                if (modalEl) {
                    modalEl.addEventListener('shown.bs.modal', function () {
                        dtCliente.columns.adjust().draw();
                        $('#clienteSearch').focus();
                    });
                }

                $('#table_cliente_modal tbody').on('click', 'tr', function () {
                    const id = $(this).attr('data-id');
                    const nome = $(this).attr('data-nome');

                    if (id) {
                        $('#id_cliente').val(id);
                        $('#nome_cliente').val(nome);
                        if (document.activeElement) document.activeElement.blur();

                        const btnFechar = modalEl.querySelector('[data-bs-dismiss="modal"]');
                        if (btnFechar) btnFechar.click();
                        else bootstrap.Modal.getOrCreateInstance(modalEl).hide();

                        setTimeout(() => {
                            document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
                            document.body.classList.remove('modal-open');
                            document.body.style.overflow = '';
                            document.body.style.paddingRight = '';
                        }, 400);
                    }
                });

                // ==========================================
                // INICIALIZA A TABELA DO MODAL DE RISCOS
                // ==========================================
                dtRiscosModal = $('#tabelaRiscosModal').DataTable({
                    dom: 'lrtip',
                    pageLength: 10,
                    lengthChange: false,
                    ordering: false,
                    language: {
                        emptyTable: "Nenhum risco encontrado na base de dados.",
                        info: "Mostrando _START_ a _END_ de _TOTAL_ riscos",
                        paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    }
                });

                document.getElementById('pesquisaRiscoModal').addEventListener('input', function (e) {
                    dtRiscosModal.search(e.target.value).draw();
                });

                document.getElementById('filtroGrupoModal').addEventListener('change', function (e) {
                    dtRiscosModal.column(1).search(e.target.value).draw();
                });

                // CARREGA OS RISCOS PREVIAMENTE SALVOS DO LEVANTAMENTO
                carregarRiscosSalvos();
            });

            // =========================================================================
            // FUNÇÃO PARA MONTAR RISCOS SALVOS NA TELA (CORRIGIDA: MISTURA E ORDEM RESOLVIDAS)
            // =========================================================================
            function carregarRiscosSalvos() {
                console.log("🔍 1. Iniciando o carregamento de riscos...");

                let salvos = [];
                try {
                    const rawData = document.getElementById('dados-riscos-salvos').textContent.trim();

                    if (rawData && rawData !== '[]') {
                        salvos = JSON.parse(rawData);
                        if (typeof salvos === 'string') salvos = JSON.parse(salvos);
                        console.log("✅ 3. JSON convertido com sucesso. Total de riscos:", salvos.length);
                    } else {
                        return;
                    }
                } catch (e) {
                    console.error("❌ ERRO FATAL no JSON.parse:", e);
                    return;
                }

                if (!Array.isArray(salvos) || salvos.length === 0) return;

                salvos.forEach((risco, index) => {
                    const id = risco.id_risco;
                    const codigo = risco.codigo_esocial || risco.codigo_interno || risco.codigo_perigo || '';
                    const nome = risco.nome_risco || risco.descricao_perigo || 'Risco Desconhecido';
                    const grupo = risco.tipo_risco || risco.grupo_perigo || 'Outros';

                    // Desenha o HTML do risco na tela na ordem correta
                    selecionarRiscoParaTela(id, codigo, nome, grupo, true);

                    // A MÁGICA CONTRA A MISTURA: Pega o item pelo ID exato!
                    const checkbox = document.querySelector(`.risk-checkbox[data-id_risco="${id}"]`);

                    if (checkbox) {
                        const currentItem = checkbox.closest('.risk-item');

                        currentItem.querySelector('.risk-checkbox').checked = true;
                        currentItem.querySelector('.risk-detail').classList.remove('hidden');

                        const inFontes = currentItem.querySelector('.risk-fontes');
                        if (inFontes) inFontes.value = risco.fontes || risco.fontes_geradoras || '';

                        const inTempo = currentItem.querySelector('.risk-tempo');
                        if (inTempo) inTempo.value = risco.tempo || risco.tipo_tempo_exposicao || '';

                        const inObs = currentItem.querySelector('.risk-obs');
                        if (inObs) inObs.value = risco.obs || risco.observacoes || '';

                        const tomEpi = currentItem.querySelector('.risk-epis').tomselect;
                        if (tomEpi && risco.epis && risco.epis.length > 0) {
                            risco.epis.forEach(epi => {
                                const epiVal = typeof epi === 'object' ? epi.id_epi : epi;
                                tomEpi.addItem(epiVal);
                            });
                        }

                        const tomEpc = currentItem.querySelector('.risk-epcs').tomselect;
                        if (tomEpc && risco.epcs && risco.epcs.length > 0) {
                            risco.epcs.forEach(epc => {
                                const epcVal = typeof epc === 'object' ? epc.id_epc : epc;
                                tomEpc.addItem(epcVal);
                            });
                        }
                    }
                });

                console.log("\n🏁 5. Finalizado! Todos os riscos foram carregados corretamente em suas caixas.");
            }

            // ==========================================
            // FUNÇÕES GERAIS DA TELA
            // ==========================================
            function changeStep(step) {
                document.querySelectorAll('.step-content').forEach(el => el.classList.remove('active'));
                document.getElementById(`step${step}`).classList.add('active');

                document.querySelectorAll('.nav-link').forEach(el => {
                    el.classList.remove('active');
                    if (el.dataset.step == step) el.classList.add('active');
                });
                window.scrollTo(0, 0);
            }

            function addGesRow() {
                document.getElementById('emptyGes').style.display = 'none';
                const tbody = document.querySelector('#tableGes tbody');
                const row = document.createElement('tr');
                row.className = "hover-row border-b border-zinc-100 dark:border-zinc-800 transition-colors";
                row.innerHTML = `
            <td class="pl-6 pr-2 py-3"><input type="text" class="table-input ges-setor font-medium" placeholder="Ex: Produção"></td>
            <td class="px-2 py-3"><input type="text" class="table-input ges-cargos" placeholder="Ex: Op. Máquina"></td>
            <td class="px-2 py-3"><input type="text" class="table-input ges-excecao" placeholder="-"></td>
            <td class="px-2 py-3"><input type="text" class="table-input ges-obs" placeholder="Opcional"></td>
            <td class="pr-6 pl-2 py-3 text-center">
                <button type="button" onclick="this.closest('tr').remove()" class="text-zinc-400 hover:text-red-500 transition-colors p-1" title="Remover"><span class="icon-[lucide--trash-2]"></span></button>
            </td>`;
                tbody.appendChild(row);
                row.querySelector('input').focus();
            }

            function addQuimicoRow() {
                document.getElementById('emptyQuimico').style.display = 'none';
                const tbody = document.querySelector('#tableQuimico tbody');
                const row = document.createElement('tr');
                row.className = "hover-row border-b border-zinc-100 dark:border-zinc-800 transition-colors";
                row.innerHTML = `
            <td class="pl-6 pr-2 py-3"><input type="text" class="table-input quim-rotulo font-medium" placeholder="Nome do produto"></td>
            <td class="px-2 py-3">
                <select class="table-input quim-estado cursor-pointer bg-transparent">
                    <option value="Líquido">Líquido</option>
                    <option value="Sólido">Sólido</option>
                    <option value="Gasoso">Gasoso</option>
                </select>
            </td>
            <td class="px-2 py-3"><input type="text" class="table-input quim-exposicao" placeholder="Ex: Cutânea"></td>
            <td class="px-2 py-3"><input type="text" class="table-input quim-processo" placeholder="Ex: Limpeza/500ml"></td>
            <td class="px-2 py-3"><input type="text" class="table-input quim-obs" placeholder="Opcional"></td>
            <td class="pr-6 pl-2 py-3 text-center">
                <button type="button" onclick="this.closest('tr').remove()" class="text-zinc-400 hover:text-red-500 transition-colors p-1" title="Remover"><span class="icon-[lucide--trash-2]"></span></button>
            </td>`;
                tbody.appendChild(row);
                row.querySelector('input').focus();
            }

            function toggleAccordion(id) { document.getElementById(id)?.classList.toggle('hidden'); }

            function toggleRiskDetail(checkbox) {
                const detailDiv = checkbox.closest('.risk-item').querySelector('.risk-detail');
                if (checkbox.checked) {
                    detailDiv.classList.remove('hidden');
                    detailDiv.querySelectorAll('select').forEach(s => { if (!s.tomselect) new TomSelect(s, { plugins: ['remove_button'] }); });
                } else { detailDiv.classList.add('hidden'); }
            }

            function handleCheckRadio(clickedCheckbox) {
                const groupName = clickedCheckbox.name;
                const allCheckboxes = document.querySelectorAll(`input[name="${groupName}"]`);
                allCheckboxes.forEach(cb => { if (cb !== clickedCheckbox) cb.checked = false; });

                allCheckboxes.forEach(cb => {
                    const targetId = cb.getAttribute('data-target');
                    if (targetId) {
                        const inputEl = document.getElementById(targetId);
                        if (inputEl) {
                            if (cb.checked) {
                                inputEl.classList.remove('invisible', 'opacity-0');
                                inputEl.focus();
                            } else {
                                inputEl.classList.add('invisible', 'opacity-0');
                                inputEl.value = '';
                            }
                        }
                    }
                });
            }

            // ==========================================
            // SELECIONAR RISCO (RESTAURADO: Com Acordeões agrupadores originais)
            // ==========================================
            function selecionarRiscoParaTela(id_risco, codigo, nome, grupo, isPreload = false) {
                // Tenta fechar o Modal se não for preload
                if (!isPreload) {
                    const modalRiscosEl = document.getElementById('modalRiscos');
                    if (modalRiscosEl) {
                        const btnFechar = modalRiscosEl.querySelector('[data-bs-dismiss="modal"]');
                        if (btnFechar) btnFechar.click();
                    }
                }

                const grupoSafe = grupo || 'Indefinido';
                const grupoId = 'grupo_' + grupoSafe.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '_').toLowerCase();
                let containerDinamico = document.getElementById('container_riscos_dinamicos');
                let accordionGrupo = document.getElementById(grupoId);

                // Cria o grupo (Acordeão) se ele não existir
                if (!accordionGrupo) {
                    accordionGrupo = document.createElement('div');
                    accordionGrupo.id = grupoId;
                    accordionGrupo.className = 'border border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden mt-4';

                    let corBorda = 'border-zinc-500';
                    if (grupoSafe.toLowerCase().includes('físico')) corBorda = 'border-green-500';
                    else if (grupoSafe.toLowerCase().includes('químico')) corBorda = 'border-red-500';
                    else if (grupoSafe.toLowerCase().includes('biológico')) corBorda = 'border-amber-700';
                    else if (grupoSafe.toLowerCase().includes('ergonômico')) corBorda = 'border-yellow-500';
                    else if (grupoSafe.toLowerCase().includes('mecânico') || grupoSafe.toLowerCase().includes('acidente')) corBorda = 'border-sky-500';

                    accordionGrupo.innerHTML = `
                    <button type="button" 
                        class="w-full text-left p-4 bg-zinc-50 dark:bg-zinc-800 font-bold flex justify-between items-center text-zinc-700 dark:text-zinc-200 hover:bg-zinc-100 dark:hover:bg-zinc-700 transition-colors border-l-4 ${corBorda}"
                        onclick="toggleAccordion('acc_${grupoId}')">
                        ${grupoSafe.toUpperCase()} <span class="icon-[lucide--chevron-down]"></span>
                    </button>
                    <div id="acc_${grupoId}" class="p-4 bg-white dark:bg-zinc-900 block">
                        <div class="grid grid-cols-1 gap-4 grid-riscos"></div>
                    </div>
                    `;
                    containerDinamico.appendChild(accordionGrupo);
                }

                const gridRiscos = accordionGrupo.querySelector('.grid-riscos');

                // Impede riscos duplicados
                if (gridRiscos.querySelector(`[data-id_risco="${id_risco}"]`)) {
                    if (!isPreload) Swal.fire('Atenção', 'Este risco já foi adicionado!', 'warning');
                    return;
                }

                const optionsEPI = document.getElementById('tpl-epis').innerHTML;
                const optionsEPC = document.getElementById('tpl-epcs').innerHTML;

                const riskItem = document.createElement('div');
                riskItem.className = 'risk-item border border-zinc-100 dark:border-zinc-800 rounded-lg p-4 bg-zinc-50/50 dark:bg-zinc-900/50';

                riskItem.innerHTML = `
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 border-b border-zinc-200 dark:border-zinc-700 pb-3">
                    <label class="inline-flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" class="input-checkbox risk-checkbox" checked
                            data-id_risco="${id_risco}" data-grupo="${grupoSafe}" data-codigo="${codigo}" data-nome="${nome}" 
                            onchange="toggleRiskDetail(this)">
                        <span class="font-bold text-zinc-700 dark:text-zinc-200 text-lg">${nome}</span>
                    </label>
                    <button type="button" onclick="removerRiscoDaTela(this, '${grupoId}')" class="text-red-500 hover:text-red-700 text-sm font-bold flex items-center gap-1 transition-colors mt-2 sm:mt-0 px-3 py-1 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-md">
                        <span class="icon-[lucide--trash]"></span> Remover
                    </button>
                </div>
        
                <div class="risk-detail grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">Fontes Geradoras</label>
                        <input type="text" placeholder="Ex: Máquina de solda..." class="table-input w-full text-sm risk-fontes">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">Tempo/Tipo Exp.</label>
                        <input type="text" placeholder="Ex: Intermitente..." class="table-input w-full text-sm risk-tempo">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">EPIs Recomendados</label>
                        <select class="risk-epis w-full table-input select-plugin" multiple>${optionsEPI}</select>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">EPCs Existentes</label>
                        <select class="risk-epcs w-full table-input select-plugin" multiple>${optionsEPC}</select>
                    </div>
                    
                    <div>
                        <label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">Anexar Imagem (Opcional)</label>
                        <label class="flex items-center justify-center w-full px-4 py-2 bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 border border-zinc-300 dark:border-zinc-700 rounded cursor-pointer hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors text-sm font-semibold text-center overflow-hidden">
                            <span class="file-name-text truncate pointer-events-none">📸 Selecionar arquivo...</span>
                            <input type="file" accept="image/*" class="hidden risk-imagem" 
                                onchange="this.previousElementSibling.textContent = this.files.length > 0 ? '✅ ' + this.files[0].name : '📸 Selecionar arquivo...'">
                        </label>
                    </div>
                    <div class="md:col-span-2">
                        <label class="text-xs font-bold text-muted uppercase tracking-wider mb-1 block">Observações</label>
                        <input type="text" placeholder="Observações adicionais..." class="table-input w-full text-sm risk-obs">
                    </div>
                </div>
                `;

                gridRiscos.appendChild(riskItem);

                riskItem.querySelectorAll('select.select-plugin').forEach(s => {
                    if (!s.tomselect) new TomSelect(s, { plugins: ['remove_button'] });
                });

                if (!isPreload) {
                    riskItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    Swal.fire({
                        toast: true, position: 'top-end', icon: 'success', title: 'Risco adicionado ao formulário',
                        showConfirmButton: false, timer: 1500
                    });
                }
            }

            // ==========================================
            // REMOVER RISCO DA TELA E DELETAR ACORDEÃO VAZIO
            // ==========================================
            function removerRiscoDaTela(botao, grupoId) {
                const riskItem = botao.closest('.risk-item');
                const gridRiscos = riskItem.parentNode;
                riskItem.remove();

                if (gridRiscos.children.length === 0) {
                    const grupoEl = document.getElementById(grupoId);
                    if (grupoEl) grupoEl.remove();
                }
            }

            function limparBuscaRiscos() {
                document.getElementById('pesquisaRiscoModal').value = '';
                document.getElementById('filtroGrupoModal').value = '';
                if (dtRiscosModal) {
                    dtRiscosModal.search('').columns().search('').draw();
                }
            }

            // ==========================================
            // ENVIO DO FORMULÁRIO (SUBMIT) - INTACTO!
            // ==========================================
            document.getElementById('formLevantamento').addEventListener('submit', async (e) => {
                e.preventDefault();

                const id_levantamento = document.getElementById('id_levantamento').value;

                if (!document.getElementById('id_cliente').value) {
                    Swal.fire('Atenção', 'Selecione um cliente.', 'warning');
                    changeStep(1);
                    return;
                }

                const step1CamposTexto = [
                    { name: 'responsavel_empresa_nome', label: 'Responsável pelas informações' },
                    { name: 'responsavel_empresa_cargo', label: 'Cargo do informante' }
                ];

                for (const campo of step1CamposTexto) {
                    const val = document.querySelector(`input[name="${campo.name}"]`).value.trim();
                    if (!val) {
                        Swal.fire('Atenção', `O campo "${campo.label}" em Dados & Ambiente é obrigatório.`, 'warning');
                        changeStep(1);
                        return;
                    }
                }

                const gesRows = document.querySelectorAll('#tableGes tbody tr');
                let hasValidGes = false;
                gesRows.forEach(tr => {
                    const v2 = tr.querySelector('.ges-setor').value.trim();
                    const v3 = tr.querySelector('.ges-cargos').value.trim();
                    if (v2 || v3) hasValidGes = true;
                });

                if (!hasValidGes) {
                    Swal.fire('Atenção', 'Preencha pelo menos um setor/cargo na aba GES & Químicos.', 'warning');
                    changeStep(2);
                    return;
                }

                const riscosSelecionados = document.querySelectorAll('.risk-checkbox:checked');
                for (let i = 0; i < riscosSelecionados.length; i++) {
                    const cb = riscosSelecionados[i];
                    const item = cb.closest('.risk-item');
                    const nomeRisco = cb.dataset.nome;

                    const fontes = item.querySelector('.risk-fontes').value.trim();
                    const tempo = item.querySelector('.risk-tempo').value.trim();
                    const tomEpi = item.querySelector('.risk-epis').tomselect;
                    const tomEpc = item.querySelector('.risk-epcs').tomselect;
                    const epis = tomEpi ? tomEpi.getValue() : [];
                    const epcs = tomEpc ? tomEpc.getValue() : [];
                }

                const assinatura_avaliador = document.getElementById('assinatura_avaliador_hidden').value;
                const assinatura_responsavel_empresa = document.getElementById('assinatura_empresa_hidden').value;

                if (!assinatura_avaliador || !assinatura_responsavel_empresa) {
                    Swal.fire({
                        title: 'Assinaturas Ausentes',
                        text: 'Este levantamento não possui as assinaturas registradas.',
                        icon: 'warning',
                        confirmButtonColor: '#0AA34A'
                    });
                    changeStep(4);
                    return;
                }

                // ========================================================
                // PROCESSO DE ENVIO (TUDO VALIDADO)
                // ========================================================
                const getRadioVal = (n) => {
                    const c = document.querySelector(`input[name="${n}"]:checked`);
                    if (!c) return null;
                    const t = c.getAttribute('data-target');
                    return { selecionado: c.value, outros: t ? document.getElementById(t).value : '' };
                };

                const gesData = Array.from(document.querySelectorAll('#tableGes tbody tr')).map(tr => ({
                    setor: tr.querySelector('.ges-setor').value,
                    cargos: tr.querySelector('.ges-cargos').value,
                    excecao: tr.querySelector('.ges-excecao').value,
                    obs: tr.querySelector('.ges-obs').value
                })).filter(g => g.setor || g.cargos || g.excecao || g.obs);

                const quimData = Array.from(document.querySelectorAll('#tableQuimico tbody tr')).map(tr => ({
                    rotulo: tr.querySelector('.quim-rotulo').value,
                    estado: tr.querySelector('.quim-estado').value,
                    exposicao: tr.querySelector('.quim-exposicao').value,
                    processo: tr.querySelector('.quim-processo').value,
                    obs: tr.querySelector('.quim-obs').value // <-- ADICIONADO
                })).filter(q => q.rotulo || q.estado || q.exposicao || q.processo || q.obs);

                // ========================================================
                // FUNÇÃO PARA COMPRIMIR IMAGEM (QUALIDADE MELHORADA 0.85 / 1600px)
                // ========================================================
                const comprimirImagem = (file, maxWidth = 1600, maxHeight = 1600, quality = 0.85) => {
                    return new Promise((resolve) => {
                        const reader = new FileReader();
                        reader.readAsDataURL(file);
                        reader.onload = (event) => {
                            const img = new Image();
                            img.src = event.target.result;
                            img.onload = () => {
                                let width = img.width;
                                let height = img.height;

                                if (width > height) {
                                    if (width > maxWidth) {
                                        height = Math.round((height * maxWidth) / width);
                                        width = maxWidth;
                                    }
                                } else {
                                    if (height > maxHeight) {
                                        width = Math.round((width * maxHeight) / height);
                                        height = maxHeight;
                                    }
                                }

                                const canvas = document.createElement('canvas');
                                canvas.width = width;
                                canvas.height = height;
                                const ctx = canvas.getContext('2d');
                                ctx.drawImage(img, 0, 0, width, height);

                                canvas.toBlob((blob) => {
                                    const compressedFile = new File([blob], file.name.replace(/\.[^/.]+$/, ".jpg"), {
                                        type: 'image/jpeg',
                                        lastModified: Date.now()
                                    });
                                    resolve(compressedFile);
                                }, 'image/jpeg', quality);
                            };
                        };
                    });
                };

                const riscosData = [];
                const formDataEnvio = new FormData();
                let indexRisco = 0;

                // MUDANÇA: Usando for...of para suportar o await na compressão da imagem
                const riscosSelecionadosEnvio = document.querySelectorAll('.risk-checkbox:checked');
                for (const cb of riscosSelecionadosEnvio) {
                    const item = cb.closest('.risk-item');
                    const sEpi = item.querySelector('.risk-epis');
                    const sEpc = item.querySelector('.risk-epcs');
                    const fileInput = item.querySelector('.risk-imagem');
                    const imgAntiga = item.querySelector('.risk-imagem-antiga');

                    riscosData.push({
                        id_risco: cb.dataset.id_risco,
                        grupo: cb.dataset.grupo,
                        codigo: cb.dataset.codigo,
                        nome: cb.dataset.nome,
                        fontes: item.querySelector('.risk-fontes').value,
                        tempo: item.querySelector('.risk-tempo').value,
                        obs: item.querySelector('.risk-obs').value,
                        // MANDAMOS A IMAGEM ANTIGA COM TODOS OS NOMES POSSÍVEIS PRO BACKEND NÃO SE PERDER:
                        imagem: imgAntiga ? imgAntiga.value : '',
                        caminho_imagem: imgAntiga ? imgAntiga.value : '',
                        imagem_antiga: imgAntiga ? imgAntiga.value : '',
                        epis: sEpi.tomselect ? sEpi.tomselect.getValue() : [],
                        epcs: sEpc.tomselect ? sEpc.tomselect.getValue() : []
                    });

                    // Se houver arquivo novo selecionado, comprime e anexa!
                    if (fileInput && fileInput.files.length > 0) {
                        const arquivoOriginal = fileInput.files[0];
                        const arquivoComprimido = await comprimirImagem(arquivoOriginal);
                        formDataEnvio.append('imagem_' + indexRisco, arquivoComprimido);
                    }
                    indexRisco++;
                }

                const formData = new FormData(e.target);
                const payload = Object.fromEntries(formData.entries());

                Object.assign(payload, {
                    tipo_construcao: getRadioVal('tipo_construcao'),
                    tipo_piso: getRadioVal('tipo_piso'),
                    tipo_paredes: getRadioVal('tipo_paredes'),
                    tipo_forro: getRadioVal('tipo_forro'),
                    tipo_iluminacao: getRadioVal('tipo_iluminacao'),
                    tipo_ventilacao: getRadioVal('tipo_ventilacao'),
                    escadas_tipo: getRadioVal('escadas_tipo'),
                    passarelas_tipo: getRadioVal('passarelas_tipo'),
                    nome_grupo_ges: document.getElementById('nome_grupo_ges').value.trim(),

                    tipo_cobertura: {
                        selecionado: [payload.cobertura_tipo_estrutura, payload.cobertura_tipo_telha]
                            .filter(Boolean).join(' - ') || '-'
                    },

                    divisoes_internas_material: {
                        selecionado: payload.divisoes_internas_material || '-'
                    },

                    estruturas_auxiliares: [
                        document.querySelector('input[name="tem_rampas"]:checked')?.value === '1' ? 'Rampas' : null,
                        document.querySelector('input[name="tem_mezaninos"]:checked')?.value === '1' ? 'Mezaninos' : null
                    ].filter(Boolean),

                    ausencia_risco_ambiental: document.querySelector('input[name="ausencia_risco_ambiental"]')?.checked || false,
                    ausencia_risco_ergonomico: document.querySelector('input[name="ausencia_risco_ergonomico"]')?.checked || false,
                    ausencia_risco_mecanico: document.querySelector('input[name="ausencia_risco_mecanico"]')?.checked || false,
                    ausencia_risco_quimico: document.querySelector('input[name="ausencia_risco_quimico"]')?.checked || false,
                    ausencia_risco_biologico: document.querySelector('input[name="ausencia_risco_biologico"]')?.checked || false,

                    trabalho_externo: document.querySelector('input[name="trabalho_externo"]:checked')?.value === '1',
                    possui_climatizacao: document.querySelector('input[name="possui_climatizacao"]:checked')?.value === '1',

                    ges: gesData,
                    quimicos: quimData,
                    riscos: riscosData,

                    assinatura_avaliador: assinatura_avaliador,
                    assinatura_responsavel_empresa: assinatura_responsavel_empresa
                });

                formDataEnvio.append('dados_json', JSON.stringify(payload));

                const btn = document.getElementById('btnSalvar');
                const oldHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="icon-[lucide--loader-2] animate-spin me-2"></span> Salvando...';

                try {
                    const res = await fetch(`/levantamento-perigo/editar/${id_levantamento}`, {
                        method: 'POST',
                        body: formDataEnvio
                    });
                    const result = await res.json();

                    if (result.success) {
                        Swal.fire('Sucesso', 'Levantamento atualizado com sucesso!', 'success').then(() => window.location.href = '/levantamento-perigo');
                    } else {
                        Swal.fire('Erro', result.message, 'error');
                    }
                } catch (err) {
                    Swal.fire('Erro', 'Falha na comunicação com o servidor.', 'error');
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = oldHtml;
                }
            });
        </script>
</body>

</html>