<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Levantamento - ProS</title>

    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/vendor/css/tom-select.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.3/css/dataTables.dataTables.css">

    <style>
        .step-content {
            display: none;
        }

        .step-content.active {
            display: block;
        }

        .hidden {
            display: none !important;
        }

        .table-input {
            width: 100%;
            background: transparent;
            border: none;
            border-bottom: 1px solid #e4e4e7;
            padding: 4px 0;
            outline: none;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }

        .dark .table-input {
            border-bottom-color: #3f3f46;
            color: #e4e4e7;
        }

        .table-input:focus {
            border-bottom-color: var(--primary-color, #0AA34A);
        }

        .hover-row:hover {
            background-color: #f8fafc;
        }

        .dark .hover-row:hover {
            background-color: #18181b;
        }

        .hover-row td .flex-wrap>label,
        .hover-row td .flex-wrap>div {
            margin-right: 2.5rem !important;
            margin-bottom: 0.5rem !important;
        }

        .hover-row td .flex-wrap label span {
            white-space: nowrap;
            padding-right: 0.25rem;
        }
    </style>
</head>

<body
    class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content">
            <%- include('../partials/header') %>

                <div class="px-4 lg:px-10 py-6">
                    <h2 class="text-2xl mb-4 text-zinc-800 dark:text-zinc-100 font-bold">Editar Levantamento de Perigos
                        #<%= levantamento.id_levantamento %>
                    </h2>

                    <nav
                        class="nav-horizontal nav-underline gap-4 flex flex-nowrap mb-6 overflow-x-auto pb-1 border-b border-zinc-200 dark:border-zinc-700">
                        <a href="#" class="nav-link active whitespace-nowrap" onclick="changeStep(1); return false;"
                            data-step="1"><span class="icon-[lucide--file-text] text-lg"></span> Dados & Ambiente</a>
                        <a href="#" class="nav-link whitespace-nowrap" onclick="changeStep(2); return false;"
                            data-step="2"><span class="icon-[lucide--flask-conical] text-lg"></span> GES & Químicos</a>
                        <a href="#" class="nav-link whitespace-nowrap" onclick="changeStep(3); return false;"
                            data-step="3"><span class="icon-[lucide--alert-triangle] text-lg"></span> Identificação de
                            Perigos</a>
                        <a href="#" class="nav-link whitespace-nowrap" onclick="changeStep(4); return false;"
                            data-step="4"><span class="icon-[lucide--pen-tool] text-lg"></span> Assinaturas</a>
                    </nav>
                </div>

                <div class="content flex-grow px-4 lg:px-10 pb-10">
                    <form id="formLevantamento" class="w-full">
                        <input type="hidden" id="id_levantamento" value="<%= levantamento.id_levantamento %>">

                        <div id="step1" class="step-content active space-y-6">
                            <div
                                class="rounded-xl bg-white dark:bg-zinc-900 shadow-card border border-zinc-200 dark:border-zinc-800">
                                <div class="p-6 border-b border-zinc-100 dark:border-zinc-800">
                                    <h5 class="text-xl font-bold text-zinc-800 dark:text-zinc-100">Informações Gerais
                                    </h5>
                                </div>
                                <div class="p-6 grid grid-cols-2 md:grid-cols-12 gap-6">
                                    <div class="md:col-span-6">
                                        <label class="mb-2 block">Empresa <span class="text-red-500">*</span></label>
                                        <div class="relative w-full">
                                            <input type="hidden" name="id_cliente" id="id_cliente"
                                                value="<%= levantamento.id_cliente %>" required>
                                            <input id="nome_cliente" type="text"
                                                class="input h-10 w-full !pe-11 bg-white dark:bg-zinc-900 cursor-pointer font-semibold"
                                                placeholder="Clique para selecionar a empresa..." readonly required
                                                value="<%= levantamento.nome_empresa %>" data-bs-toggle="modal"
                                                data-bs-target="#modal_cliente">
                                            <button type="button" data-bs-toggle="modal" data-bs-target="#modal_cliente"
                                                class="absolute right-2 top-1/2 -translate-y-1/2 size-8 flex items-center justify-center text-zinc-500 hover:text-primary">
                                                <span class="icon-[lucide--search] text-lg"></span>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="md:col-span-4">
                                        <label class="mb-2 block font-medium">Data do Levantamento</label>
                                        <input type="date" name="data_levantamento"
                                            class="input h-10 w-full bg-zinc-100 dark:bg-zinc-800 text-zinc-500 cursor-not-allowed text-center"
                                            value="<%= new Date(levantamento.data_levantamento).toISOString().split('T')[0] %>"
                                            readonly>
                                    </div>
                                    <div class="md:col-span-6">
                                        <label class="mb-2 block font-medium">Responsável Técnico</label>
                                        <input type="hidden" name="id_responsavel_tecnico"
                                            value="<%= levantamento.id_responsavel_tecnico %>">
                                        <input type="text"
                                            class="input h-10 w-full bg-zinc-100 dark:bg-zinc-800 font-bold cursor-not-allowed"
                                            value="<%= levantamento.nome_avaliador %>" disabled>
                                    </div>
                                    <div class="md:col-span-8">
                                        <label class="mb-2 block font-medium">Responsável pelas informações</label>
                                        <input type="text" name="responsavel_empresa_nome" class="input h-10 w-full"
                                            value="<%= levantamento.responsavel_empresa_nome || '' %>">
                                    </div>
                                    <div class="md:col-span-4">
                                        <label class="mb-2 block font-medium">Cargo</label>
                                        <input type="text" name="responsavel_empresa_cargo" class="input h-10 w-full"
                                            value="<%= levantamento.responsavel_empresa_cargo || '' %>">
                                    </div>
                                    <div class="md:col-span-6">
                                        <label class="mb-2 block">Existem trabalhadores executando atividades fora da
                                            empresa?</label>
                                        <div class="flex items-center gap-6 mt-1">
                                            <label class="inline-flex items-center gap-2 cursor-pointer">
                                                <input type="radio" name="trabalho_externo" value="1"
                                                    class="input-radio text-primary" <%=levantamento.trabalho_externo
                                                    ? 'checked' : '' %>> <span>Sim</span>
                                            </label>
                                            <label class="inline-flex items-center gap-2 cursor-pointer">
                                                <input type="radio" name="trabalho_externo" value="0"
                                                    class="input-radio text-primary" <%=!levantamento.trabalho_externo
                                                    ? 'checked' : '' %>> <span>Não</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <% // Função auxiliar ajustada para suportar tanto Strings quanto Objetos const
                                checkInc=(campo, valor)=> {
                                const val = levantamento[campo];
                                if (!val) return '';
                                // Se for objeto, converte para string para o .includes funcionar sem quebrar
                                const strVal = typeof val === 'object' ? JSON.stringify(val) : String(val);
                                return strVal.includes(valor) ? 'checked' : '';
                                };

                                // Parse das estruturas auxiliares de forma segura
                                let estrArr = [];
                                if (levantamento.estruturas_auxiliares) {
                                let valEstrutura = levantamento.estruturas_auxiliares;
                                if (typeof valEstrutura === 'string') {
                                try { valEstrutura = JSON.parse(valEstrutura); } catch(e) { valEstrutura = []; }
                                }
                                estrArr = Array.isArray(valEstrutura) ? valEstrutura : [];
                                }

                                // Parse de cobertura a prova de falhas
                                let cobEst = '', cobTel = '';
                                if (levantamento.tipo_cobertura) {
                                let cobVal = levantamento.tipo_cobertura;
                                if (typeof cobVal === 'string') {
                                try { cobVal = JSON.parse(cobVal); } catch(e){}
                                }

                                // Extrai a string de dentro do objeto (se existir)
                                let strCob = (typeof cobVal === 'object' && cobVal !== null) ? cobVal.selecionado :
                                String(cobVal);

                                if (strCob && typeof strCob === 'string') {
                                const pts = strCob.split('-');
                                cobEst = pts[0] ? pts[0].trim() : '';
                                cobTel = pts[1] ? pts[1].trim() : '';
                                }
                                }

                                // Parse de divisões internas a prova de falhas
                                let divMat = '';
                                if (levantamento.divisoes_internas_material) {
                                let divVal = levantamento.divisoes_internas_material;
                                if (typeof divVal === 'string') {
                                try { divVal = JSON.parse(divVal); } catch(e){}
                                }
                                divMat = (typeof divVal === 'object' && divVal !== null) ? (divVal.selecionado || '') :
                                String(divVal);
                                }
                                %>

                                <div
                                    class="rounded-xl bg-white dark:bg-zinc-900 shadow-card border border-zinc-200 dark:border-zinc-800 overflow-hidden">
                                    <div
                                        class="p-6 border-b border-zinc-100 dark:border-zinc-800 bg-zinc-50/50 dark:bg-zinc-900">
                                        <h5 class="text-xl font-bold text-zinc-800 dark:text-zinc-100">Caracterização do
                                            Ambiente</h5>
                                    </div>
                                    <div class="p-6 overflow-x-auto">
                                        <table class="w-full text-left border-collapse">
                                            <tbody class="divide-y divide-zinc-100 dark:divide-zinc-800">
                                                <tr class="hover-row transition-colors">
                                                    <td
                                                        class="py-4 pl-6 pr-4 align-top font-bold text-zinc-700 dark:text-zinc-300">
                                                        Construção</td>
                                                    <td class="py-6 px-4">
                                                        <div class="flex flex-wrap items-center">
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_construcao"
                                                                    value="Alvenaria" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_construcao', 'Alvenaria' ) %>>
                                                                <span>Alvenaria</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_construcao"
                                                                    value="Concreto" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_construcao', 'Concreto' ) %>>
                                                                <span>Concreto</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_construcao"
                                                                    value="Madeira" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_construcao', 'Madeira' ) %>>
                                                                <span>Madeira</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_construcao"
                                                                    value="Metálica" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_construcao', 'Metálica' ) %>>
                                                                <span>Metálica</span>
                                                            </label>
                                                            <div class="flex items-center gap-2">
                                                                <label
                                                                    class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                    <input type="checkbox" name="tipo_construcao"
                                                                        value="Outros" class="input-checkbox"
                                                                        data-target="input_construcao_outro"
                                                                        onclick="handleCheckRadio(this)"
                                                                        <%=checkInc('tipo_construcao', 'Outros' ) %>>
                                                                    <span>Outros</span>
                                                                </label>
                                                                <input type="text" id="input_construcao_outro"
                                                                    name="tipo_construcao_outro"
                                                                    class="table-input w-40 transition-opacity duration-200"
                                                                    placeholder="Especifique">
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>

                                                <tr class="hover-row transition-colors">
                                                    <td
                                                        class="py-4 pl-6 pr-4 align-top font-bold text-zinc-700 dark:text-zinc-300">
                                                        Paredes</td>
                                                    <td class="py-4 px-4">
                                                        <div class="flex flex-wrap items-center">
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_paredes"
                                                                    value="Cerâmico" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_paredes', 'Cerâmico' ) %>>
                                                                <span>Cerâmico</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_paredes"
                                                                    value="Pintura" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_paredes', 'Pintura' ) %>>
                                                                <span>Pintura</span>
                                                            </label>
                                                            <div class="flex items-center gap-2">
                                                                <label
                                                                    class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                    <input type="checkbox" name="tipo_paredes"
                                                                        value="Outros" class="input-checkbox"
                                                                        data-target="input_paredes_outro"
                                                                        onclick="handleCheckRadio(this)"
                                                                        <%=checkInc('tipo_paredes', 'Outros' ) %>>
                                                                    <span>Outros</span>
                                                                </label>
                                                                <input type="text" id="input_paredes_outro"
                                                                    name="tipo_paredes_outro"
                                                                    class="table-input w-40 transition-opacity duration-200"
                                                                    placeholder="Especifique">
                                                            </div>
                                                            <div
                                                                class="flex items-center gap-2 border-l pl-4 ml-2 border-zinc-200">
                                                                <span
                                                                    class="text-sm font-semibold text-zinc-500">Cor:</span>
                                                                <input type="text" name="cor_paredes"
                                                                    class="table-input w-32"
                                                                    value="<%= levantamento.cor_paredes || '' %>">
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>

                                                <tr class="hover-row transition-colors">
                                                    <td
                                                        class="py-4 pl-6 pr-4 align-middle font-bold text-zinc-700 dark:text-zinc-300">
                                                        Divisões Internas</td>
                                                    <td class="py-4 px-4">
                                                        <div class="flex items-center gap-3">
                                                            <span class="text-sm text-zinc-500">Material:</span>
                                                            <input type="text" name="divisoes_internas_material"
                                                                class="table-input max-w-md" value="<%= divMat %>">
                                                        </div>
                                                    </td>
                                                </tr>

                                                <tr class="hover-row transition-colors">
                                                    <td
                                                        class="py-4 pl-6 pr-4 align-top font-bold text-zinc-700 dark:text-zinc-300">
                                                        Piso</td>
                                                    <td class="py-4 px-4">
                                                        <div class="flex flex-wrap items-center">
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_piso"
                                                                    value="Concreto desempenado" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_piso', 'Concreto desempenado' )
                                                                    %>> <span>Concreto Desemp.</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_piso" value="Cerâmico"
                                                                    class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_piso', 'Cerâmico' ) %>>
                                                                <span>Cerâmico</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_piso" value="Pintura"
                                                                    class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_piso', 'Pintura' ) %>>
                                                                <span>Pintura</span>
                                                            </label>
                                                            <div class="flex items-center gap-2">
                                                                <label
                                                                    class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                    <input type="checkbox" name="tipo_piso"
                                                                        value="Outros" class="input-checkbox"
                                                                        data-target="input_piso_outro"
                                                                        onclick="handleCheckRadio(this)"
                                                                        <%=checkInc('tipo_piso', 'Outros' ) %>>
                                                                    <span>Outros</span>
                                                                </label>
                                                                <input type="text" id="input_piso_outro"
                                                                    name="tipo_piso_outro"
                                                                    class="table-input w-40 transition-opacity duration-200">
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>

                                                <tr class="hover-row transition-colors">
                                                    <td
                                                        class="py-4 pl-6 pr-4 align-middle font-bold text-zinc-700 dark:text-zinc-300">
                                                        Cobertura</td>
                                                    <td class="py-4 px-4">
                                                        <div class="flex flex-wrap items-center">
                                                            <div class="flex items-center gap-2 mr-8">
                                                                <span
                                                                    class="text-sm font-semibold text-zinc-500">Estrutura:</span>
                                                                <input type="text" name="cobertura_tipo_estrutura"
                                                                    class="table-input w-40" value="<%= cobEst %>">
                                                            </div>
                                                            <div class="flex items-center gap-2">
                                                                <span
                                                                    class="text-sm font-semibold text-zinc-500">Telha:</span>
                                                                <input type="text" name="cobertura_tipo_telha"
                                                                    class="table-input w-40" value="<%= cobTel %>">
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>

                                                <tr class="hover-row transition-colors">
                                                    <td
                                                        class="py-4 pl-6 pr-4 align-top font-bold text-zinc-700 dark:text-zinc-300">
                                                        Forro</td>
                                                    <td class="py-4 px-4">
                                                        <div class="flex flex-wrap items-center">
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_forro" value="Laje"
                                                                    class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_forro', 'Laje' ) %>>
                                                                <span>Laje</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_forro"
                                                                    value="Forro PVC" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_forro', 'PVC' ) %>>
                                                                <span>PVC</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_forro"
                                                                    value="Forro madeira" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_forro', 'madeira' ) %>>
                                                                <span>Madeira</span>
                                                            </label>
                                                            <div class="flex items-center gap-2">
                                                                <label
                                                                    class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                    <input type="checkbox" name="tipo_forro"
                                                                        value="Outros" class="input-checkbox"
                                                                        data-target="input_forro_outro"
                                                                        onclick="handleCheckRadio(this)"
                                                                        <%=checkInc('tipo_forro', 'Outros' ) %>>
                                                                    <span>Outros</span>
                                                                </label>
                                                                <input type="text" id="input_forro_outro"
                                                                    name="tipo_forro_outro"
                                                                    class="table-input w-40 transition-opacity duration-200">
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>

                                                <tr class="hover-row transition-colors">
                                                    <td
                                                        class="py-4 pl-6 pr-4 align-top font-bold text-zinc-700 dark:text-zinc-300">
                                                        Iluminação</td>
                                                    <td class="py-4 px-4">
                                                        <div class="flex flex-wrap items-center">
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_iluminacao"
                                                                    value="Natural" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_iluminacao', 'Natural' ) %>>
                                                                <span>Natural</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_iluminacao"
                                                                    value="Artificial" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_iluminacao', 'Artificial' ) %>>
                                                                <span>Artificial</span>
                                                            </label>
                                                            <div class="flex items-center gap-2">
                                                                <label
                                                                    class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                    <input type="checkbox" name="tipo_iluminacao"
                                                                        value="Outros" class="input-checkbox"
                                                                        data-target="input_iluminacao_outro"
                                                                        onclick="handleCheckRadio(this)"
                                                                        <%=checkInc('tipo_iluminacao', 'Outros' ) %>>
                                                                    <span>Outros</span>
                                                                </label>
                                                                <input type="text" id="input_iluminacao_outro"
                                                                    name="tipo_iluminacao_outro"
                                                                    class="table-input w-40 transition-opacity duration-200">
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>

                                                <tr class="hover-row transition-colors">
                                                    <td
                                                        class="py-4 pl-6 pr-4 align-top font-bold text-zinc-700 dark:text-zinc-300">
                                                        Ventilação</td>
                                                    <td class="py-4 px-4">
                                                        <div class="flex flex-wrap items-center">
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
