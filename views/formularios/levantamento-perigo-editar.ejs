                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_construcao"
                                                                    value="Alvenaria" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_construcao', 'Alvenaria' ) %>>
                                                                <span>Alvenaria</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_construcao"
                                                                    value="Concreto" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_construcao', 'Concreto' ) %>>
                                                                <span>Concreto</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_construcao"
                                                                    value="Madeira" class="input-checkbox"
                                                                    onclick="handleCheckRadio(this)"
                                                                    <%=checkInc('tipo_construcao', 'Madeira' ) %>>
                                                                <span>Madeira</span>
                                                            </label>
                                                            <label
                                                                class="inline-flex items-center gap-2 cursor-pointer text-zinc-700 hover:text-primary transition-colors">
                                                                <input type="checkbox" name="tipo_construcao"
