<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProS - Perfis de Acesso</title>

    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&amp;display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.3/css/dataTables.dataTables.css">
    <link rel="stylesheet" href="/vendor/css/tom-select.min.css">
</head>

<body
    class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300 text-left rtl:text-right">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content">

            <%- include('../partials/header') %>

                <div class="px-4 lg:px-8 py-4">
                    <h2 class="text-xl mb-2">Perfis de Acesso</h2>
                    <ol class="flex gap-1 items-center text-sm">
                        <li class="flex items-center">
                            <a href="/dashboard"
                                class="text-zinc-400 hover:text-zinc-700 dark:hover:text-white">Dashboard</a>
                        </li>
                        <li class="flex items-center opacity-30 leading-none">
                            <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
                        </li>
                        <li class="flex items-center">
                            <span class="text-zinc-400">Configurações</span>
                        </li>
                        <li class="flex items-center opacity-30 leading-none">
                            <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
                        </li>
                        <li class="flex items-center"><span class="pointer-events-none">Perfis</span></li>
                    </ol>
                </div>

                <div class="content flex-grow lg:px-4">
                    <div class="grid grid-cols-1 px-4">
                        <div class="rounded-xl bg-white dark:bg-zinc-900 shadow-card mb-4">

                            <div
                                class="flex flex-wrap gap-2 items-center p-4 border-b border-zinc-500/10 dark:border-zinc-800">
                                <div class="flex-grow">
                                    <div class="relative">
                                        <input type="search" class="input !ps-9" name="perfilSearch" id="perfilSearch"
                                            placeholder="Buscar perfil">
                                        <span
                                            class="iconify icon-[lucide--search] pointer-events-none absolute start-0 top-0 h-full flex items-center ms-3 text-muted"></span>
                                    </div>
                                </div>

                                <div class="flex items-center flex-wrap justify-end gap-2">

                                    <div class="flex-grow w-56 sm:w-auto">
                                        <select id="statusFilter" class="js-select w-full sm:w-56">
                                            <option value="" selected>Todos</option>
                                            <option value="Ativo">Ativo</option>
                                            <option value="Inativo">Inativo</option>
                                        </select>
                                    </div>

                                    <div class="flex items-center gap-2">
                                        <a href="/perfil/novo"
                                            class="btn bg-primary shrink-0 text-white hover:bg-primary-deep btn-novo-perfil">
                                            <span class="icon-[lucide--plus] text-lg me-1"></span>
                                            Novo Perfil
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <table id="table_perfis" class="table-default w-full">
                                <thead>
                                    <tr>
                                        <th class="text-nowrap">
                                            <div class="flex items-center">Nome do Perfil</div>
                                        </th>
                                        <th class="text-nowrap">
                                            <div class="flex items-center">Descrição</div>
                                        </th>
                                        <th class="text-nowrap text-center">
                                            <div class="flex items-center justify-center">Usuários Ativos</div>
                                        </th>
                                        <th class="text-nowrap text-center">
                                            <div class="flex items-center justify-center">Status</div>
                                        </th>
                                        <th class="text-nowrap text-end" data-orderable="false">Ações</th>
                                    </tr>
                                </thead>
                                <tbody id="tableBody"></tbody>
                            </table>

                        </div>
                    </div>
                </div>

                <%- include('../partials/footer') %>

        </main>

        <div id="dados-perfis-json" style="display: none;"><%- perfisJson %></div>

        <div id="permissoes-user" style="display: none;">
            <%- JSON.stringify(user.permissoes || {}) %>
        </div>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>
        <script src="https://cdn.datatables.net/2.3.3/js/dataTables.js"></script>
        <script src="/vendor/js/sweetalert2.all.min.js"></script>

        <script>
            // Variáveis Globais
            const userEmail = "<%= user.email %>";
            const userPerfilNome = "<%= user.nome_perfil %>";

            // 1. LER PERMISSÕES
            let permPerfil = {};
            try {
                const divPerm = document.getElementById('permissoes-user');
                const todasPermissoes = JSON.parse(divPerm.innerText);
                // Tenta pegar 'perfis' (plural) ou 'perfil' (singular)
                permPerfil = todasPermissoes['perfis'] || todasPermissoes['perfil'] || {};
            } catch (e) { console.error(e); }

            let canEdit = false;
            let canCreate = false;
            let canInactivate = false;

            // Admin Bypass
            if (userEmail === 'admin@admin.com' || userPerfilNome === 'Administrador' || userPerfilNome === 'Super Admin') {
                canEdit = true;
                canCreate = true;
                canInactivate = true;
            } else {
                // Checa permissão "tudo" ou específica
                // Suporta tanto 'pode_editar' quanto 'editar' para garantir compatibilidade
                const podeTudo = (permPerfil.tudo == 1 || permPerfil.tudo === true);

                if (podeTudo || permPerfil.editar == 1 || permPerfil.editar === true || permPerfil.pode_editar == 1) {
                    canEdit = true;
                }
                if (podeTudo || permPerfil.criar == 1 || permPerfil.criar === true || permPerfil.pode_criar == 1) {
                    canCreate = true;
                }
                if (podeTudo || permPerfil.inativar == 1 || permPerfil.inativar === true || permPerfil.pode_inativar == 1) {
                    canInactivate = true;
                }
            }
        </script>

        <script>
            document.addEventListener('DOMContentLoaded', () => {

                // 2. LER DADOS JSON
                let listaPerfis = [];
                try {
                    const divJson = document.getElementById('dados-perfis-json');
                    if (divJson && divJson.innerText) {
                        listaPerfis = JSON.parse(divJson.innerText);
                    }
                } catch (e) { console.error("Erro ao ler JSON:", e); }

                // 3. POPULAR TABELA
                const tbody = document.getElementById('tableBody');
                if (listaPerfis.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4">Nenhum perfil encontrado.</td></tr>';
                } else {
                    listaPerfis.forEach((p, index) => {
                        const tr = document.createElement('tr');
                        tr.setAttribute('data-index', index);
                        const statusHtml = (Number(p.ativo) === 1)
                            ? '<span class="badge bg-green-500/10 text-green-500 status-badge">Ativo</span>'
                            : '<span class="badge bg-zinc-500/10 text-zinc-500 status-badge">Inativo</span>';

                        tr.innerHTML = `
                            <td class="font-semibold text-zinc-900 whitespace-nowrap dark:text-white">${p.nome_perfil}</td>
                            <td><span class="text-sm text-zinc-500 truncate max-w-[220px] block">${p.descricao || 'Sem descrição'}</span></td>
                            <td class="text-center"><span class="badge bg-zinc-100 text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">${p.total_usuarios} usuários</span></td>
                            <td class="text-center">${statusHtml}</td>
                            <td class="text-end">
                                <div class="flex items-center  gap-1 relative z-[1]">
                                    <a href="/perfil/editar/${p.id_perfil}" class="btn !p-1.5 text-zinc-500 hover:text-primary transition-colors btn-editar-link" title="Editar">
                                        <span class="icon-[lucide--edit] text-lg"></span>
                                    </a>
                                    <button type="button" class="btn !p-1.5 text-zinc-500 hover:text-red-500 transition-colors btn-inativar" data-id="${p.id_perfil}" data-status="${p.ativo}" data-nome="${p.nome_perfil}" title="Inativar">
                                        <span class="icon-[lucide--trash] text-lg pointer-events-none"></span>
                                    </button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                }

                // 4. DATATABLE
                const table = new DataTable('#table_perfis', {
                    lengthChange: false,
                    pageLength: 10,
                    scrollX: false,
                    dom: 'lrtip',
                    columnDefs: [
                        { targets: [2, 3], className: "text-center" }
                    ],
                    order: [[0, 'asc']],
                    language: {
                        emptyTable: "Nenhum perfil encontrado.",
                        info: "Mostrando _START_ até _END_ de _TOTAL_ registros",
                        paginate: { first: "Primeiro", last: "Último", next: "Próximo", previous: "Anterior" }
                    }
                });

                document.getElementById('perfilSearch').addEventListener('input', e => table.search(e.target.value).draw());

                // Correção do Filtro (O índice do Status agora é 3)
                document.getElementById('statusFilter').addEventListener('change', function () {
                    const val = this.value;
                    if (val) {
                        table.column(3).search('^' + val + '$', true, false).draw();
                    } else {
                        table.column(3).search('').draw();
                    }
                });

                // 5. INTERCEPTADOR DE CLIQUES (EDITAR, NOVO, INATIVAR)
                document.body.addEventListener('click', function (e) {
                    // Editar
                    const linkEditar = e.target.closest('a[href^="/perfil/editar/"]');
                    if (linkEditar && !canEdit) {
                        e.preventDefault();
                        Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para acessar a tela de edição.', icon: 'warning', confirmButtonColor: '#f59e0b', confirmButtonText: 'Entendido' });
                    }

                    // Novo
                    const linkNovo = e.target.closest('a[href="/perfil/novo"]');
                    if (linkNovo && !canCreate) {
                        e.preventDefault();
                        Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para criar novos perfis.', icon: 'warning', confirmButtonColor: '#f59e0b', confirmButtonText: 'Entendido' });
                    }

                    // Inativar (Lixeira individual)
                    const btnInativar = e.target.closest('.btn-inativar');
                    if (btnInativar) {
                        e.preventDefault();

                        const perfilId = btnInativar.getAttribute('data-id');
                        const perfilStatus = btnInativar.getAttribute('data-status');
                        const perfilNome = btnInativar.getAttribute('data-nome');

                        // Bloqueia se já estiver inativo
                        if (perfilStatus === '0' || perfilStatus === 'false') {
                            Swal.fire({
                                title: 'Aviso',
                                text: `O perfil "${perfilNome}" já encontra-se inativo.`,
                                icon: 'info',
                                confirmButtonColor: '#3b82f6'
                            });
                            return;
                        }

                        // Verifica permissão
                        if (!canInactivate) {
                            Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para inativar perfis.', icon: 'warning', confirmButtonColor: '#f59e0b', confirmButtonText: 'Entendido' });
                            return;
                        }

                        Swal.fire({
                            title: 'Tem certeza?',
                            text: `Deseja inativar o perfil "${perfilNome}"?`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'Sim, inativar',
                            cancelButtonText: 'Cancelar',
                            confirmButtonColor: '#ef4444',
                            cancelButtonColor: '#3f3f46'
                        }).then(async (result) => {
                            if (!result.isConfirmed) return;
                            try {
                                const response = await fetch('/perfil/inativar-multiplos', {
                                    method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                                    body: JSON.stringify({ ids: [perfilId] })
                                });

                                // Bloqueio Backend
                                if (response.status === 403) {
                                    Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para inativar perfis.', icon: 'warning', confirmButtonColor: '#f59e0b' });
                                    return;
                                }

                                const data = await response.json();
                                if (data.success) Swal.fire('Sucesso', data.message, 'success').then(() => window.location.reload());
                                else Swal.fire('Erro', data.message, 'error');
                            } catch (error) { Swal.fire('Erro', 'Erro de conexão.', 'error'); }
                        });
                    }
                });
            });
        </script>

        <script src="/vendor/js/tom-select.complete.min.js"></script>
        <style>
            .ts-wrapper .ts-control,
            .ts-wrapper .ts-control *,
            .ts-wrapper .ts-control input {
                cursor: pointer !important;
            }
        </style>
        <script>
            document.querySelectorAll('.js-select').forEach(select => {
                new TomSelect(select, {
                    create: false,
                    allowEmptyOption: true,
                    controlInput: null,
                    onInitialize: function () {
                    }
                });
            });
        </script>
</body>

</html>