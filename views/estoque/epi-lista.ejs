<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProS - EPI</title>

    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&amp;display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.3/css/dataTables.dataTables.css">
    <link rel="stylesheet" href="/vendor/css/tom-select.min.css">
</head>

<body
    class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300 text-left rtl:text-right">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content">

            <%- include('../partials/header') %>

                <div class="px-4 lg:px-8 py-4">
                    <h2 class="text-xl mb-2">EPI</h2>

                    <ol class="flex gap-1 items-center text-sm">
                        <li class="flex items-center">
                            <a href="/dashboard" class="text-zinc-400 hover:text-zinc-700 dark:hover:text-white">
                                Dashboard</a>
                        </li>
                        <li class="flex items-center opacity-30 leading-none">
                            <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
                        </li>
                        <li class="flex items-center">
                            <span class="text-zinc-400">Cadastros</span>
                        </li>
                        <li class="flex items-center opacity-30 leading-none">
                            <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
                        </li>
                        <li class="flex items-center"><span class="pointer-events-none">EPI</span></li>
                    </ol>
                </div>

                <div class="content flex-grow lg:px-4">
                    <div class="grid grid-cols-1 px-4">
                        <div class="rounded-xl bg-white dark:bg-zinc-900 shadow-card mb-4">

                            <div
                                class="flex flex-wrap gap-2 items-center p-4 border-b border-zinc-500/10 dark:border-zinc-800">
                                <div class="flex-grow">
                                    <div class="relative">
                                        <input type="search" class="input !ps-9" name="epiSearch" id="epiSearch"
                                            placeholder="Buscar EPI (nome ou CA)">
                                        <span
                                            class="iconify icon-[lucide--search] pointer-events-none absolute start-0 top-0 h-full flex items-center justify-center ms-3 text-muted"></span>
                                    </div>
                                </div>

                                <div class="flex items-center flex-wrap justify-end gap-2">

                                    <div class="flex-grow w-56 sm:w-auto">
                                        <select id="statusFilter" class="js-select w-full sm:w-56">
                                            <option value="">Todos os Status</option>
                                            <option value="Ativo" selected>Ativo</option>
                                            <option value="Inativo">Inativo</option>
                                        </select>
                                    </div>

                                    <div class="flex items-center gap-2">
                                        <a href="/epi/novo"
                                            class="btn bg-primary shrink-0 text-white hover:bg-primary-deep">
                                            <span class="icon-[lucide--plus] text-lg me-1"></span>
                                            Criar Novo
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="overflow-x-auto">
                                <table id="table_epi" class="table-default w-full">
                                    <thead>
                                        <tr>
                                            <th class="text-nowrap">
                                                <div class="flex items-center">Nome</div>
                                            </th>
                                            <th class="text-nowrap">
                                                <div class="flex items-center">CA</div>
                                            </th>
                                            <th class="text-nowrap">
                                                <div class="flex items-center">Validade (Banco)</div>
                                            </th>
                                            <th class="text-nowrap text-center">Status</th>
                                            <th class="text-nowrap text-end" data-orderable="false">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableBody"></tbody>
                                </table>
                            </div>

                            <div class="p-4 text-sm text-zinc-400">
                                Fonte de consulta do CA:
                                <a class="text-sky-600 hover:text-sky-700"
                                    href="https://caepi.mte.gov.br/internet/ConsultaCAInternet.aspx" target="_blank"
                                    rel="noopener">
                                    Consulta CA Internet (MTE)
                                </a>
                            </div>

                        </div>
                    </div>
                </div>

                <%- include('../partials/footer') %>

        </main>

        <div id="epi-data" class="hidden"><%- episJson %></div>

        <div id="permissoes-user" style="display: none;">
            <%- JSON.stringify(user.permissoes || {}) %>
        </div>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>
        <script src="/vendor/js/sweetalert2.all.min.js"></script>
        <script src="https://cdn.datatables.net/2.3.3/js/dataTables.js"></script>
        <script src="/vendor/js/tom-select.complete.min.js"></script>

        <style>
            .ts-wrapper .ts-control,
            .ts-wrapper .ts-control *,
            .ts-wrapper .ts-control input {
                cursor: pointer !important;
            }
        </style>

        <script>
            // Variáveis globais de usuário
            const userEmail = "<%= user.email %>";
            const userPerfil = "<%= user.nome_perfil %>";

            // 1. LER PERMISSÕES DO JSON OCULTO
            let permissoesUsuario = {};
            try {
                const divPerm = document.getElementById('permissoes-user');
                if (divPerm && divPerm.innerText.trim()) {
                    permissoesUsuario = JSON.parse(divPerm.innerText);
                }
            } catch (e) { console.error("Erro ao ler permissões", e); }

            // 2. DEFINIR AS FLAGS
            let canCreate = false;
            let canEdit = false;
            let canInactivate = false;

            if (userEmail === 'admin@admin.com' || userPerfil === 'Administrador' || userPerfil === 'Super Admin') {
                canCreate = true;
                canEdit = true;
                canInactivate = true;
            } else {
                const permEpi = permissoesUsuario['epis'] || permissoesUsuario['epi'] || {};

                if (permEpi.criar == 1 || permEpi.criar === true) canCreate = true;
                if (permEpi.editar == 1 || permEpi.editar === true) canEdit = true;
                if (permEpi.inativar == 1 || permEpi.inativar === true) canInactivate = true;

                if (permEpi.tudo == 1 || permEpi.tudo === true) {
                    canCreate = true; canEdit = true; canInactivate = true;
                }
            }

            document.addEventListener('DOMContentLoaded', () => {

                // =================================================================
                // 3. INTERCEPTADOR DE CLIQUES (BLOQUEIO FRONT-END) E EXCLUSÃO
                // =================================================================
                document.body.addEventListener('click', function (e) {

                    // Novo
                    const linkNovo = e.target.closest('a[href="/epi/novo"]');
                    if (linkNovo && !canCreate) {
                        e.preventDefault();
                        Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para criar novos EPIs.', icon: 'warning', confirmButtonColor: '#f59e0b' });
                    }

                    // Editar
                    const linkEditar = e.target.closest('a[href^="/epi/editar/"]');
                    if (linkEditar && !canEdit) {
                        e.preventDefault();
                        Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para editar este EPI.', icon: 'warning', confirmButtonColor: '#f59e0b' });
                    }

                    // Inativar (Lixeira individual)
                    const btnInativar = e.target.closest('.btn-inativar');
                    if (btnInativar) {
                        e.preventDefault();

                        const epiId = btnInativar.getAttribute('data-id');
                        const epiStatus = btnInativar.getAttribute('data-status');
                        const epiNome = btnInativar.getAttribute('data-nome');

                        if (epiStatus === '0' || epiStatus === 'false') {
                            Swal.fire({ title: 'Aviso', text: `O EPI "${epiNome}" já encontra-se inativo.`, icon: 'info', confirmButtonColor: '#3b82f6' });
                            return;
                        }

                        if (!canInactivate) {
                            Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para inativar EPIs.', icon: 'warning', confirmButtonColor: '#f59e0b' });
                            return;
                        }

                        Swal.fire({
                            title: 'Tem certeza?',
                            text: `Deseja inativar o EPI "${epiNome}"?`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'Sim, inativar',
                            cancelButtonText: 'Cancelar',
                            confirmButtonColor: '#ef4444',
                            cancelButtonColor: '#3f3f46'
                        }).then(async (result) => {
                            if (result.isConfirmed) {
                                try {
                                    const response = await fetch('/epi/inativar-multiplos', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                                        body: JSON.stringify({ ids: [epiId] })
                                    });

                                    if (response.status === 403) {
                                        Swal.fire({ title: 'Acesso Negado', text: 'Permissão negada pelo servidor (403).', icon: 'warning', confirmButtonColor: '#f59e0b' });
                                        return;
                                    }

                                    const data = await response.json();
                                    if (data.success) {
                                        Swal.fire('Sucesso', data.message, 'success').then(() => window.location.reload());
                                    } else {
                                        Swal.fire('Erro', data.message, 'error');
                                    }
                                } catch (err) {
                                    Swal.fire('Erro no Servidor', 'Falha na comunicação.', 'error');
                                }
                            }
                        });
                    }
                });

                // ============================================================
                // 4. RENDERIZAR TABELA
                // ============================================================
                let listaEpis = [];
                try {
                    const divJson = document.getElementById('epi-data');
                    if (divJson && divJson.innerText.trim()) {
                        listaEpis = JSON.parse(divJson.innerText);
                    }
                } catch (e) { console.error("Erro ao ler JSON de EPIs:", e); }

                const tbody = document.getElementById('tableBody');
                tbody.innerHTML = '';

                const formatDate = (dateString) => {
                    if (!dateString) return '-';
                    const dataPart = dateString.split('T')[0];
                    const [ano, mes, dia] = dataPart.split('-');
                    return `${dia}/${mes}/${ano}`;
                };

                listaEpis.forEach((epi, index) => {
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-index', index);

                    const statusHtml = (Number(epi.ativo) === 1)
                        ? '<span class="badge bg-green-500/10 text-green-500 status-badge">Ativo</span>'
                        : '<span class="badge bg-zinc-500/10 text-zinc-500 status-badge">Inativo</span>';

                    // Linha reestruturada sem a coluna de checkbox
                    tr.innerHTML = `
                        <td class="font-semibold text-zinc-900 whitespace-nowrap dark:text-white">${epi.nome_equipamento || epi.nome || '-'}</td>
                        <td class="whitespace-nowrap">
                            <div class="flex items-center gap-2">
                                <span class="ca-value font-mono">${epi.ca || '-'}</span>
                                ${epi.ca ? `
                                <button type="button" class="btn !p-1.5 text-zinc-500 hover:!text-primary btn-consultar-ca" data-ca="${epi.ca}" title="Verificar validade atual na API">
                                    <span class="icon-[lucide--refresh-cw] text-lg"></span>
                                </button>
                                ` : ''}
                            </div>
                        </td>
                        <td class="whitespace-nowrap validade-cell">
                            <span class="validade-text">${formatDate(epi.validade_ca)}</span>
                            <span class="status-api text-xs ms-1 font-bold"></span>
                        </td>
                        <td class="text-center">${statusHtml}</td>
                        <td class="text-end pr-6">
                            <div class="flex items-center justify-end gap-1 relative z-[1]">
                                <a href="/epi/editar/${epi.id_epi}" class="btn !p-1.5 text-zinc-500 hover:text-primary transition-colors" title="Editar">
                                    <span class="icon-[lucide--edit] text-lg"></span>
                                </a>
                                <button type="button" class="btn !p-1.5 text-zinc-500 hover:text-red-500 transition-colors btn-inativar" data-id="${epi.id_epi}" data-status="${epi.ativo}" data-nome="${epi.nome_equipamento || epi.nome}" title="Inativar">
                                    <span class="icon-[lucide--trash] text-lg pointer-events-none"></span>
                                </button>
                            </div>
                        </td>
                    `;

                    // Opacidade se inativo
                    if (epi.ativo == 0 || epi.ativo == false) tr.classList.add('opacity-50');

                    tbody.appendChild(tr);
                });

                const table = new DataTable('#table_epi', {
                    lengthChange: false,
                    pageLength: 10,
                    scrollX: false,
                    dom: 'lrtip',
                    columnDefs: [
                        { orderable: false, targets: 4 } // Ações
                    ],
                    order: [[0, 'asc']], // Ordena pelo Nome (Coluna 0)
                    language: {
                        emptyTable: "Nenhum EPI cadastrado",
                        info: "Mostrando _START_ até _END_ de _TOTAL_ registros",
                        paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    }
                });

                // Pesquisa Global
                document.getElementById('epiSearch').addEventListener('input', e => table.search(e.target.value).draw());

                // Filtro Exato no Status (Coluna 3)
                const statusFilter = document.getElementById('statusFilter');
                statusFilter.addEventListener('change', function () {
                    const val = this.value;
                    if (val) {
                        table.column(3).search('^' + val + '$', true, false).draw();
                    } else {
                        table.column(3).search('').draw();
                    }
                });

                if (statusFilter.value) {
                    table.column(3).search('^' + statusFilter.value + '$', true, false).draw();
                }

                // =========================================================================
                // 5. API CONSULTA DE C.A.
                // =========================================================================
                document.querySelector('#table_epi').addEventListener('click', async (e) => {
                    const btn = e.target.closest('.btn-consultar-ca');
                    if (!btn) return;

                    const ca = btn.getAttribute('data-ca');
                    const tdValidade = btn.closest('tr').querySelector('.validade-cell');
                    const spanStatus = tdValidade.querySelector('.status-api');

                    btn.disabled = true;
                    btn.classList.add('opacity-50', 'animate-spin');
                    spanStatus.textContent = ' Checando...';
                    spanStatus.className = 'status-api text-xs ms-1 text-sky-500';

                    try {
                        const response = await fetch(`/epi/consulta-ca/${ca}`);
                        if (!response.ok) throw new Error();
                        const data = await response.json();

                        const hoje = new Date();
                        const [d, m, y] = data.validade.split('/');
                        const dataValidade = new Date(`${y}-${m}-${d}`);

                        let classeCor = 'text-green-600';
                        let textoStatus = '(Válido)';

                        if (dataValidade < hoje) {
                            classeCor = 'text-red-500';
                            textoStatus = '(Vencido)';
                        }

                        tdValidade.innerHTML = `
                            <span class="validade-text font-bold ${classeCor}">${data.validade}</span>
                            <span class="text-xs ${classeCor}">${textoStatus}</span>
                        `;

                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 3000
                        });
                        Toast.fire({ icon: 'success', title: `CA ${ca} atualizado.` });

                    } catch (err) {
                        spanStatus.textContent = ' Falha API';
                        spanStatus.className = 'status-api text-xs ms-1 text-red-500';
                    } finally {
                        btn.disabled = false;
                        btn.classList.remove('opacity-50', 'animate-spin');
                    }
                });

            });

            document.querySelectorAll('.js-select').forEach(select => {
                new TomSelect(select, {
                    create: false,
                    allowEmptyOption: true,
                    controlInput: null,
                    onInitialize: function () {
                        this.control.classList.add('!cursor-pointer', 'select-none');
                    }
                });
            });
        </script>
</body>

</html>