<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProS - EPC</title>

    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&amp;display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.3/css/dataTables.dataTables.css">
    <link rel="stylesheet" href="/vendor/css/tom-select.min.css">
</head>

<body
    class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300 text-left rtl:text-right">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content">

            <%- include('../partials/header') %>

                <div class="px-4 lg:px-8 py-4">
                    <h2 class="text-xl mb-2">EPC</h2>
                    <ol class="flex gap-1 items-center text-sm">
                        <li class="flex items-center">
                            <a href="/dashboard" class="text-zinc-400 hover:text-zinc-700 dark:hover:text-white">
                                Dashboard</a>
                        </li>
                        <li class="flex items-center opacity-30 leading-none">
                            <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
                        </li>
                        <li class="flex items-center">
                            <span class="text-zinc-400">Cadastros</span>
                        </li>
                        <li class="flex items-center opacity-30 leading-none">
                            <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
                        </li>
                        <li class="flex items-center"><span class="pointer-events-none">EPC</span></li>
                    </ol>
                </div>

                <div class="content flex-grow lg:px-4">
                    <div class="grid grid-cols-1 px-4">
                        <div class="rounded-xl bg-white dark:bg-zinc-900 shadow-card mb-4">

                            <div
                                class="flex flex-wrap gap-2 items-center p-4 border-b border-zinc-500/10 dark:border-zinc-800">
                                <div class="flex-grow">
                                    <div class="relative">
                                        <input type="search" class="input !ps-9" name="epcSearch" id="epcSearch"
                                            placeholder="Buscar EPC (nome ou observação)">
                                        <span
                                            class="iconify icon-[lucide--search] pointer-events-none absolute start-0 top-0 h-full flex items-center justify-center ms-3 text-muted"></span>
                                    </div>
                                </div>

                                <div class="flex items-center flex-wrap justify-end gap-2">

                                    <div class="flex-grow w-56 sm:w-auto">
                                        <select id="statusFilter" class="js-select w-full sm:w-56">
                                            <option value="">Todos</option>
                                            <option value="Ativo" selected>Ativo</option>
                                            <option value="Inativo">Inativo</option>
                                        </select>
                                    </div>

                                    <div class="flex items-center gap-2">
                                        <a href="/epc/novo"
                                            class="btn bg-primary shrink-0 text-white hover:bg-primary-deep">
                                            <span class="icon-[lucide--plus] text-lg me-1"></span>
                                            Criar Novo
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="overflow-x-auto">
                                <table id="table_epc" class="table-default w-full">
                                    <thead>
                                        <tr>
                                            <th class="text-nowrap">
                                                <div class="flex items-center">Nome</div>
                                            </th>
                                            <th class="text-nowrap">
                                                <div class="flex items-center">Observações</div>
                                            </th>
                                            <th class="text-nowrap">Status</th>
                                            <th class="text-nowrap" data-orderable="false">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableBody"></tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>

                <%- include('../partials/footer') %>

        </main>

        <div id="epc-data" style="display: none;"><%- epcsJson %></div>

        <div id="permissoes-user" style="display: none;">
            <%- JSON.stringify(user.permissoes || {}) %>
        </div>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>
        <script src="/vendor/js/sweetalert2.all.min.js"></script>
        <script src="https://cdn.datatables.net/2.3.3/js/dataTables.js"></script>
        <script src="/vendor/js/tom-select.complete.min.js"></script>

        <style>
            .ts-wrapper .ts-control,
            .ts-wrapper .ts-control *,
            .ts-wrapper .ts-control input {
                cursor: pointer !important;
            }
        </style>

        <script>
            // Variáveis globais de usuário
            const userEmail = "<%= user.email %>";
            const userPerfil = "<%= user.nome_perfil %>";

            // 1. LER PERMISSÕES DO JSON OCULTO
            let permissoesUsuario = {};
            try {
                const divPerm = document.getElementById('permissoes-user');
                if (divPerm && divPerm.innerText.trim()) {
                    permissoesUsuario = JSON.parse(divPerm.innerText);
                }
            } catch (e) { console.error("Erro ao ler permissões", e); }

            // 2. DEFINIR AS FLAGS (Pode Criar? Pode Editar?)
            let canCreate = false;
            let canEdit = false;
            let canInactivate = false;

            // Lógica de Super Admin
            if (userEmail === 'admin@admin.com' || userPerfil === 'Administrador' || userPerfil === 'Super Admin') {
                canCreate = true;
                canEdit = true;
                canInactivate = true;
            } else {
                // Verifica se tem permissão no módulo 'epcs' (ou 'epc' dependendo de como salvou no banco)
                const permEpc = permissoesUsuario['epcs'] || permissoesUsuario['epc'] || {};

                if (permEpc.criar == 1 || permEpc.criar === true) canCreate = true;
                if (permEpc.editar == 1 || permEpc.editar === true) canEdit = true;
                if (permEpc.inativar == 1 || permEpc.inativar === true) canInactivate = true;

                // Se tiver permissão 'tudo', libera
                if (permEpc.tudo == 1 || permEpc.tudo === true) {
                    canCreate = true; canEdit = true; canInactivate = true;
                }
            }

            // =================================================================
            // 3. INTERCEPTADOR DE CLIQUES E RENDERIZAÇÃO
            // =================================================================
            document.addEventListener('DOMContentLoaded', () => {

                // Monitora cliques no corpo da página (Event Delegation)
                document.body.addEventListener('click', function (e) {

                    // A) Clicou em "Criar Novo"?
                    const linkNovo = e.target.closest('a[href="/epc/novo"]');
                    if (linkNovo && !canCreate) {
                        e.preventDefault();
                        Swal.fire({
                            title: 'Acesso Negado',
                            text: 'Você não tem permissão para criar novos EPCs.',
                            icon: 'warning',
                            confirmButtonColor: '#f59e0b',
                            confirmButtonText: 'Entendido'
                        });
                    }

                    // B) Clicou em "Editar"?
                    const linkEditar = e.target.closest('a[href^="/epc/editar/"]');
                    if (linkEditar && !canEdit) {
                        e.preventDefault();
                        Swal.fire({
                            title: 'Acesso Negado',
                            text: 'Você não tem permissão para editar este EPC.',
                            icon: 'warning',
                            confirmButtonColor: '#f59e0b',
                            confirmButtonText: 'Entendido'
                        });
                    }

                    // C) Clicou em "Inativar" (Lixeira individual)?
                    const btnInativar = e.target.closest('.btn-inativar');
                    if (btnInativar) {
                        e.preventDefault();

                        const epcId = btnInativar.getAttribute('data-id');
                        const epcStatus = btnInativar.getAttribute('data-status');
                        const epcNome = btnInativar.getAttribute('data-nome');

                        // Bloqueia se já estiver inativo
                        if (epcStatus === '0' || epcStatus === 'false') {
                            Swal.fire({
                                title: 'Aviso',
                                text: `O EPC "${epcNome}" já encontra-se inativo.`,
                                icon: 'info',
                                confirmButtonColor: '#3b82f6'
                            });
                            return;
                        }

                        // Verifica Permissão
                        if (!canInactivate) {
                            Swal.fire({
                                title: 'Acesso Negado',
                                text: 'Você não tem permissão para inativar EPCs.',
                                icon: 'warning',
                                confirmButtonColor: '#f59e0b',
                                confirmButtonText: 'Entendido'
                            });
                            return;
                        }

                        Swal.fire({
                            title: 'Tem certeza?',
                            text: `Deseja inativar o EPC "${epcNome}"?`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'Sim, inativar',
                            cancelButtonText: 'Cancelar',
                            confirmButtonColor: '#ef4444',
                            cancelButtonColor: '#3f3f46'
                        }).then(async (result) => {
                            if (result.isConfirmed) {
                                try {
                                    const response = await fetch('/epc/inativar-multiplos', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                                        body: JSON.stringify({ ids: [epcId] })
                                    });

                                    if (response.status === 403) {
                                        Swal.fire({ title: 'Acesso Negado', text: 'Permissão negada pelo servidor (403).', icon: 'warning', confirmButtonColor: '#f59e0b' });
                                        return;
                                    }

                                    const data = await response.json();
                                    if (data.success) {
                                        Swal.fire('Sucesso', data.message, 'success').then(() => window.location.reload());
                                    } else {
                                        Swal.fire('Erro', data.message, 'error');
                                    }
                                } catch (err) {
                                    Swal.fire('Erro no Servidor', err.message, 'error');
                                }
                            }
                        });
                    }
                });

                // ============================================================
                // 4. RESTANTE DA LÓGICA (TABELA)
                // ============================================================

                // Ler JSON da Tabela
                let listaEpcs = [];
                try {
                    const divJson = document.getElementById('epc-data');
                    if (divJson && divJson.innerText.trim()) {
                        listaEpcs = JSON.parse(divJson.innerText);
                    }
                } catch (e) { }

                const tbody = document.getElementById('tableBody');
                tbody.innerHTML = '';

                listaEpcs.forEach((epc, index) => {
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-index', index);

                    const statusHtml = (Number(epc.ativo) === 1)
                        ? '<span class="badge bg-green-500/10 text-green-500 status-badge">Ativo</span>'
                        : '<span class="badge bg-zinc-500/10 text-zinc-500 status-badge">Inativo</span>';

                    tr.innerHTML = `
                        <td class="font-semibold text-zinc-900 whitespace-nowrap dark:text-white">${epc.nome}</td>
                        <td class="whitespace-nowrap">${epc.observacoes || '-'}</td>
                        <td>${statusHtml}</td>
                        <td>
                            <div class="flex items-center gap-1 relative z-[1]">
                                <a href="/epc/editar/${epc.id_epc}" class="btn !p-1.5 text-zinc-500 hover:text-primary transition-colors" title="Editar">
                                    <span class="icon-[lucide--edit] text-lg"></span>
                                </a>
                                <button type="button" class="btn !p-1.5 text-zinc-500 hover:text-red-500 transition-colors btn-inativar" data-id="${epc.id_epc}" data-status="${epc.ativo}" data-nome="${epc.nome}" title="Inativar">
                                    <span class="icon-[lucide--trash] text-lg pointer-events-none"></span>
                                </button>
                            </div>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });

                // Inicializar DataTables
                const table = new DataTable('#table_epc', {
                    lengthChange: false,
                    pageLength: 10,
                    scrollX: false,
                    dom: 'lrtip',
                    columnDefs: [
                        { orderable: false, targets: 3 } // Coluna Ações não é ordenável
                    ],
                    order: [[0, 'asc']], // Ordena alfabeticamente pela primeira coluna (Nome)
                    language: {
                        emptyTable: "Nenhum EPC cadastrado",
                        info: "Mostrando _START_ até _END_ de _TOTAL_ registros",
                        paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    }
                });

                // Filtro de Pesquisa Global
                document.getElementById('epcSearch').addEventListener('input', e => table.search(e.target.value).draw());

                // Filtro de Status (Usando Regex Exato na coluna 2)
                const statusFilter = document.getElementById('statusFilter');
                statusFilter.addEventListener('change', function () {
                    const val = this.value;
                    if (val) {
                        table.column(2).search('^' + val + '$', true, false).draw();
                    } else {
                        table.column(2).search('').draw();
                    }
                });

                // Aplicar filtro inicial de status (se houver)
                if (statusFilter.value) {
                    table.column(2).search('^' + statusFilter.value + '$', true, false).draw();
                }
            });

            document.querySelectorAll('.js-select').forEach(select => {
                new TomSelect(select, {
                    create: false,
                    allowEmptyOption: true,
                    controlInput: null,
                    onInitialize: function () {
                        this.control.classList.add('!cursor-pointer', 'select-none');
                    }
                });
            });
        </script>
</body>

</html>