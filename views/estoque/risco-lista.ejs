<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProS - Riscos</title>

    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&amp;display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.3/css/dataTables.dataTables.css">
    <link rel="stylesheet" href="/vendor/css/tom-select.min.css">
</head>

<body
    class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300 text-left rtl:text-right">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content">

            <%- include('../partials/header') %>

                <div class="px-4 lg:px-8 py-4">
                    <h2 class="text-xl mb-2">Riscos</h2>

                    <ol class="flex gap-1 items-center text-sm">
                        <li class="flex items-center">
                            <a href="/dashboard"
                                class="text-zinc-400 hover:text-zinc-700 dark:hover:text-white">Dashboard</a>
                        </li>
                        <li class="flex items-center opacity-30 leading-none">
                            <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
                        </li>
                        <li class="flex items-center">
                            <span class="text-zinc-400">Cadastros</span>
                        </li>
                        <li class="flex items-center opacity-30 leading-none">
                            <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
                        </li>
                        <li class="flex items-center"><span class="pointer-events-none">Riscos</span></li>
                    </ol>
                </div>

                <div class="content flex-grow lg:px-4">
                    <div class="grid grid-cols-1 px-4">
                        <div class="rounded-xl bg-white dark:bg-zinc-900 shadow-card mb-4">

                            <div
                                class="flex flex-wrap gap-2 items-center p-4 border-b border-zinc-500/10 dark:border-zinc-800">
                                <div class="flex-grow">
                                    <div class="relative">
                                        <input type="search" class="input !ps-9" name="riscoSearch" id="riscoSearch"
                                            placeholder="Buscar risco (nome, tipo ou código eSocial)">
                                        <span
                                            class="iconify icon-[lucide--search] pointer-events-none absolute start-0 top-0 h-full flex items-center justify-center ms-3 text-muted"></span>
                                    </div>
                                </div>

                                <div class="flex items-center flex-wrap justify-end gap-2">

                                    <div class="flex-grow w-56 sm:w-auto">
                                        <select id="tipoFilter" class="js-select w-full sm:w-56">
                                            <option value="" selected>Todos os tipos</option>
                                            <option value="Físicos">Físicos</option>
                                            <option value="Químicos">Químicos</option>
                                            <option value="Biológicos">Biológicos</option>
                                            <option value="Ergonômicos">Ergonômicos</option>
                                            <option value="Mecânicos">Mecânicos</option>
                                            <option value="Inespecífico">Inespecífico</option>
                                            <option value="Associações">Associações</option>
                                            <option value="Outros">Outros</option>
                                            <option value="Ausência de Riscos">Ausência de Riscos</option>
                                        </select>
                                    </div>

                                    <div class="flex items-center gap-2">
                                        <a href="/risco/novo"
                                            class="btn bg-primary shrink-0 text-white hover:bg-primary-deep">
                                            <span class="icon-[lucide--plus] text-lg me-1"></span>
                                            Criar Novo
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="overflow-x-auto">
                                <table id="table_riscos" class="table-default w-full">
                                    <thead>
                                        <tr>
                                            <th class="text-nowrap">Tipo</th>
                                            <th class="text-nowrap">Nome do risco</th>
                                            <th class="text-nowrap">Código eSocial</th>
                                            <th class="text-nowrap" data-orderable="false">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableBody"></tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>

                <%- include('../partials/footer') %>

        </main>

        <div id="riscos-data" class="hidden"><%- riscosJson %></div>

        <div id="permissoes-user" style="display: none;">
            <%- JSON.stringify(user.permissoes || {}) %>
        </div>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>
        <script src="/vendor/js/sweetalert2.all.min.js"></script>

        <script src="https://cdn.datatables.net/2.3.3/js/dataTables.js"></script>
        <script src="/vendor/js/tom-select.complete.min.js"></script>
        <style>
            .ts-wrapper .ts-control,
            .ts-wrapper .ts-control *,
            .ts-wrapper .ts-control input {
                cursor: pointer !important;
            }
        </style>
        <script>
            // Variáveis globais de usuário
            const userEmail = "<%= user.email %>";
            const userPerfil = "<%= user.nome_perfil %>";

            // 1. LER PERMISSÕES DO JSON OCULTO
            let permissoesUsuario = {};
            try {
                const divPerm = document.getElementById('permissoes-user');
                if (divPerm && divPerm.innerText.trim()) {
                    permissoesUsuario = JSON.parse(divPerm.innerText);
                }
            } catch (e) { console.error("Erro ao ler permissões", e); }

            // 2. DEFINIR AS FLAGS (Pode Criar? Pode Editar?)
            let canCreate = false;
            let canEdit = false;
            let canInactivate = false;

            // Lógica de Super Admin
            if (userEmail === 'admin@admin.com' || userPerfil === 'Administrador' || userPerfil === 'Super Admin') {
                canCreate = true;
                canEdit = true;
                canInactivate = true;
            } else {
                const permRisco = permissoesUsuario['riscos'] || permissoesUsuario['risco'] || {};

                if (permRisco.criar == 1 || permRisco.criar === true) canCreate = true;
                if (permRisco.editar == 1 || permRisco.editar === true) canEdit = true;
                if (permRisco.inativar == 1 || permRisco.inativar === true) canInactivate = true;

                if (permRisco.tudo == 1 || permRisco.tudo === true) {
                    canCreate = true; canEdit = true; canInactivate = true;
                }
            }

            document.addEventListener('DOMContentLoaded', () => {

                // ============================================================
                // 1. LÓGICA DE ALERTA DE PERMISSÃO (Query String)
                // ============================================================
                const urlParams = new URLSearchParams(window.location.search);
                const alertType = urlParams.get('alert');

                if (alertType === 'sem_permissao') {
                    Swal.fire({
                        title: 'Acesso Negado',
                        text: 'Você não tem permissão para acessar a tela de edição.',
                        icon: 'warning',
                        confirmButtonColor: '#f59e0b',
                        confirmButtonText: 'Entendido'
                    });
                    window.history.replaceState(null, '', window.location.pathname);
                }

                // ============================================================
                // 2. INTERCEPTADOR DE CLIQUES E RENDERIZAÇÃO
                // ============================================================
                document.body.addEventListener('click', function (e) {

                    // A) Clicou em "Criar Novo"?
                    const linkNovo = e.target.closest('a[href="/risco/novo"]');
                    if (linkNovo && !canCreate) {
                        e.preventDefault();
                        Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para criar novos riscos.', icon: 'warning', confirmButtonColor: '#f59e0b' });
                    }

                    // B) Clicou em "Editar"?
                    const linkEditar = e.target.closest('a[href^="/risco/editar/"]');
                    if (linkEditar && !canEdit) {
                        e.preventDefault();
                        Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para editar este risco.', icon: 'warning', confirmButtonColor: '#f59e0b' });
                    }

                    // C) Clicou em "Inativar" (Lixeira individual)?
                    const btnInativar = e.target.closest('.btn-inativar');
                    if (btnInativar) {
                        e.preventDefault();

                        const riscoId = btnInativar.getAttribute('data-id');
                        const riscoStatus = btnInativar.getAttribute('data-status');
                        const riscoNome = btnInativar.getAttribute('data-nome');

                        // Bloqueia se já estiver inativo
                        if (riscoStatus === '0' || riscoStatus === 'false') {
                            Swal.fire({
                                title: 'Aviso',
                                text: `O risco "${riscoNome}" já encontra-se inativo.`,
                                icon: 'info',
                                confirmButtonColor: '#3b82f6'
                            });
                            return;
                        }

                        // Verifica Permissão
                        if (!canInactivate) {
                            Swal.fire({ title: 'Acesso Negado', text: 'Você não tem permissão para inativar riscos.', icon: 'warning', confirmButtonColor: '#f59e0b' });
                            return;
                        }

                        Swal.fire({
                            title: 'Tem certeza?',
                            text: `Deseja inativar o risco "${riscoNome}"?`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'Sim, inativar',
                            cancelButtonText: 'Cancelar',
                            confirmButtonColor: '#ef4444',
                            cancelButtonColor: '#3f3f46'
                        }).then(async (result) => {
                            if (result.isConfirmed) {
                                try {
                                    const response = await fetch('/risco/inativar-multiplos', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                                        body: JSON.stringify({ ids: [riscoId] })
                                    });

                                    if (response.status === 403) {
                                        Swal.fire({ title: 'Acesso Negado', text: 'Permissão negada pelo servidor (403).', icon: 'warning', confirmButtonColor: '#f59e0b' });
                                        return;
                                    }

                                    const data = await response.json();
                                    if (data.success) {
                                        Swal.fire('Sucesso', data.message, 'success').then(() => window.location.reload());
                                    } else {
                                        Swal.fire('Erro', data.message, 'error');
                                    }
                                } catch (err) {
                                    Swal.fire('Erro no Servidor', err.message, 'error');
                                }
                            }
                        });
                    }
                });

                // ============================================================
                // 3. CONSTRUÇÃO DA TABELA DATATABLES
                // ============================================================
                let listaRiscos = [];
                try {
                    const divJson = document.getElementById('riscos-data');
                    if (divJson && divJson.innerText.trim()) {
                        listaRiscos = JSON.parse(divJson.innerText);
                    }
                } catch (e) { console.error("Erro ao ler JSON de riscos:", e); }

                const getRiskBadge = (tipo) => {
                    switch (tipo) {
                        case 'Físicos': return '<span class="badge bg-green-500/10 text-green-500">Físicos</span>';
                        case 'Químicos': return '<span class="badge bg-red-500/10 text-red-500">Químicos</span>';
                        case 'Biológicos': return '<span class="badge bg-yellow-600/10 text-yellow-600">Biológicos</span>';
                        case 'Ergonômicos': return '<span class="badge bg-yellow-500/10 text-yellow-500">Ergonômicos</span>';
                        case 'Mecânicos': return '<span class="badge bg-sky-500/10 text-sky-500">Mecânicos</span>';
                        case 'Inespecífico': return '<span class="badge bg-purple-500/10 text-purple-500">Inespecífico</span>';
                        case 'Associações': return '<span class="badge bg-zinc-500/10 text-zinc-500">Associações</span>';
                        case 'Outros': return '<span class="badge bg-zinc-500/10 text-zinc-500">Outros</span>';
                        case 'Ausência de Risco': return '<span class="badge bg-slate-500/10 text-slate-500">Ausência de Riscos</span>';
                        default: return `<span class="badge bg-zinc-100 text-zinc-500">${tipo || '-'}</span>`;
                    }
                };

                const table = new DataTable('#table_riscos', {
                    data: listaRiscos,
                    columns: [
                        {
                            data: 'tipo_risco',
                            className: 'whitespace-nowrap',
                            render: function (data) {
                                return getRiskBadge(data);
                            }
                        },
                        {
                            data: 'nome_risco',
                            className: 'font-semibold text-zinc-900 whitespace-nowrap dark:text-white'
                        },
                        {
                            data: 'codigo_esocial',
                            className: 'whitespace-nowrap',
                            render: function (data) {
                                return data || '-';
                            }
                        },
                        {
                            data: null,
                            orderable: false,
                            render: function (data, type, row) {
                                return `
                                <div class="flex items-center gap-1 relative z-[1]">
                                    <a href="/risco/editar/${row.id_risco}" class="btn !p-1.5 hover:!text-primary" title="Editar">
                                        <span class="icon-[lucide--edit] text-lg"></span>
                                    </a>
                                    <button type="button" class="btn !p-1.5 text-zinc-500 hover:text-red-500 transition-colors btn-inativar" data-id="${row.id_risco}" data-status="${row.ativo}" data-nome="${row.nome_risco}" title="Inativar">
                                        <span class="icon-[lucide--trash] text-lg pointer-events-none"></span>
                                    </button>
                                </div>
                                `;
                            }
                        }
                    ],
                    createdRow: function (row, data, dataIndex) {
                        $(row).attr('data-index', dataIndex);

                        // Opacidade visual para riscos inativos na tabela (Opcional, mas fica legal!)
                        if (data.ativo == 0 || data.ativo == false) {
                            $(row).addClass('opacity-50');
                        }
                    },
                    lengthChange: false,
                    pageLength: 10,
                    scrollX: false,
                    dom: 'lrtip',
                    language: {
                        emptyTable: "Nenhum risco cadastrado",
                        info: "Mostrando _START_ até _END_ de _TOTAL_ registros",
                        paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    },
                    order: [[1, 'asc']] // Ordena pelo Nome do Risco (Coluna 1 agora)
                });

                // Busca e Filtros
                document.getElementById('riscoSearch').addEventListener('input', e => table.search(e.target.value).draw());

                // Filtro Exato no TomSelect (A coluna "Tipo" agora é a 0)
                document.getElementById('tipoFilter').addEventListener('change', function () {
                    const val = this.value;
                    if (val) {
                        table.columns(0).search('^' + val + '$', true, false).draw();
                    } else {
                        table.columns(0).search('').draw();
                    }
                });

            });

            // Inicializa o TomSelect
            document.querySelectorAll('.js-select').forEach(select => {
                new TomSelect(select, {
                    create: false,
                    allowEmptyOption: true,
                    controlInput: null,
                    onInitialize: function () {
                        this.control.classList.add('!cursor-pointer', 'select-none');
                    }
                });
            });
        </script>
</body>

</html>