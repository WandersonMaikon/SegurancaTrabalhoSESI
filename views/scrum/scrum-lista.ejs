<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProS - Meus Projetos Scrum</title>
    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="stylesheet" href="/vendor/css/simplebar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body
    class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300">

    <%- include('../partials/sidebar') %>

        <main class="flex-1 lg:ms-64 flex flex-col app-content">
            <%- include('../partials/header') %>

                <div class="px-4 lg:px-8 py-6 flex-grow">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
                        <div>
                            <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">Acompanhar serviços</h2>
                            <p class="text-muted text-sm mt-1">Gerencie os quadros de tarefas ativos.
                            </p>
                        </div>
                    </div>

                    <div class="mb-6 flex flex-col sm:flex-row gap-4 items-start sm:items-center">
                        <div class="relative max-w-sm w-full">
                            <input type="search" id="inputPesquisaProjetos"
                                class="input !ps-9 w-full bg-white dark:bg-zinc-900"
                                placeholder="Buscar por cliente ou contrato...">
                            <span
                                class="iconify icon-[lucide--search] absolute start-3 top-1/2 -translate-y-1/2 text-muted pointer-events-none"></span>
                        </div>

                        <div class="relative">
                            <button data-bs-auto-close="outside" data-bs-toggle="dropdown" type="button"
                                class="btn border border-zinc-200 dark:border-zinc-800 hover:bg-zinc-50 dark:hover:bg-zinc-800 h-10 px-4 bg-white dark:bg-zinc-900">
                                <span class="icon-[lucide--sliders-horizontal] me-2 text-lg"></span> Filtros
                            </button>
                            <div
                                class="dropdown-menu absolute !start-0 sm:!start-auto sm:!end-0 top-full min-w-48 !p-4 !mt-1 z-50">
                                <div class="flex flex-col gap-y-3">
                                    <label class="flex items-center cursor-pointer gap-2">
                                        <input type="checkbox" class="input-checkbox filter-checkbox" value="Aberta"
                                            checked>
                                        <span class="font-medium">Aberta</span>
                                    </label>
                                    <label class="flex items-center cursor-pointer gap-2">
                                        <input type="checkbox" class="input-checkbox filter-checkbox"
                                            value="Em Andamento" checked>
                                        <span class="font-medium">Em Andamento</span>
                                    </label>
                                    <label class="flex items-center cursor-pointer gap-2">
                                        <input type="checkbox" class="input-checkbox filter-checkbox" value="Concluída">
                                        <span class="font-medium">Concluída</span>
                                    </label>
                                    <label class="flex items-center cursor-pointer gap-2">
                                        <input type="checkbox" class="input-checkbox filter-checkbox" value="Atrasado">
                                        <span class="font-bold">Apenas Atrasados</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-4" id="gridProjetos">

                        <% if (projetos.length===0) { %>
                            <div
                                class="col-span-full flex flex-col items-center justify-center p-10 bg-white dark:bg-zinc-900 rounded-2xl shadow-card border border-dashed border-zinc-300 dark:border-zinc-700">
                                <span
                                    class="icon-[lucide--folder-open] text-6xl text-zinc-300 dark:text-zinc-700 mb-4"></span>
                                <h4 class="text-xl font-bold text-zinc-700 dark:text-zinc-300">Nenhum projeto em
                                    andamento</h4>
                                <p class="text-muted mt-2 text-center max-w-md">Você não possui Ordens de Serviço ativas
                                    com tarefas atribuídas a você neste momento.</p>
                            </div>
                            <% } %>

                                <% projetos.forEach(function(projeto) { %>
                                    <% let badgeClass="bg-zinc-500/10 text-zinc-500" ; let badgeText=projeto.status
                                        || "Aberta" ; let progressTrack="bg-zinc-200 dark:bg-zinc-700" ; let
                                        progressFill="bg-zinc-500" ; if (badgeText==='Aberta' ) {
                                        badgeClass="bg-blue-500/10 text-blue-500 border border-blue-500/20" ;
                                        progressTrack="bg-blue-500/20" ; progressFill="bg-blue-500" ; } else if
                                        (badgeText==='Em Andamento' ) {
                                        badgeClass="bg-amber-500/10 text-amber-500 border border-amber-500/20" ;
                                        progressTrack="bg-amber-500/20" ; progressFill="bg-amber-500" ; } else if
                                        (badgeText==='Concluída' ) {
                                        badgeClass="bg-green-500/10 text-green-500 border border-green-500/20" ;
                                        progressTrack="bg-green-500/20" ; progressFill="bg-green-500" ; } else if
                                        (badgeText==='Cancelada' ) {
                                        badgeClass="bg-red-500/10 text-red-500 border border-red-500/20" ;
                                        progressTrack="bg-red-500/20" ; progressFill="bg-red-500" ; } let
                                        badgePriColor="bg-sky-500/10 text-sky-500" ; let badgePriText="Baixa prioridade"
                                        ; if (projeto.dias_restantes <=20) { badgePriColor="bg-red-500/10 text-red-500"
                                        ; badgePriText="Alta prioridade" ; } else if (projeto.dias_restantes <=30) {
                                        badgePriColor="bg-amber-500/10 text-amber-500" ; badgePriText="Média prioridade"
                                        ; } if (badgeText==='Concluída' || projeto.progresso===100) {
                                        badgePriColor="bg-green-500/10 text-green-500" ; badgePriText="Finalizado" ; }
                                        let nomeTarefa=projeto.proxima_tarefa || 'Tarefa pendente' ; let
                                        nomeTarefaCurto=nomeTarefa.length> 20 ? nomeTarefa.substring(0, 20) + '...' :
                                        nomeTarefa;
                                        let isAtrasado = projeto.dias_restantes < 0 && badgeText !=='Concluída' ; %>

                                            <div class="projeto-card rounded-xl bg-white dark:bg-zinc-900 shadow-card relative flex flex-col h-full border border-zinc-100 dark:border-zinc-800/50 hover:border-primary/50 transition-colors"
                                                data-status="<%= badgeText %>" data-atrasado="<%= isAtrasado %>">

                                                <div class="px-4 pt-4 flex items-center justify-between">
                                                    <div
                                                        class="shrink-0 flex items-center justify-center size-10 rounded-lg bg-zinc-50 dark:bg-zinc-800 text-zinc-400">
                                                        <span class="icon-[lucide--building-2] text-2xl"></span>
                                                    </div>
                                                    <span class="badge shrink-0 <%= badgeClass %>">
                                                        <%= badgeText %>
                                                    </span>
                                                </div>

                                                <div class="p-4 flex flex-col flex-grow">
                                                    <a href="/scrum/quadro/<%= projeto.id_contrato %>"
                                                        class="text-lg truncate hover:!text-primary font-bold text-zinc-900 dark:text-white mb-1 block"
                                                        title="<%= projeto.nome_empresa %>">
                                                        <%= projeto.nome_empresa %>
                                                    </a>
                                                    <p class="text-sm text-muted mb-2">
                                                        Contrato: <span
                                                            class="font-semibold text-zinc-700 dark:text-zinc-300">
                                                            <%= projeto.numero_contrato %>
                                                        </span>
                                                    </p>

                                                    <div class="mb-3">
                                                        <span class="badge <%= badgePriColor %> font-semibold w-max">
                                                            <%= badgePriText %>
                                                        </span>
                                                    </div>

                                                    <div class="flex items-center gap-2 mb-4">
                                                        <span
                                                            class="icon-[lucide--calendar-clock] text-muted text-lg shrink-0"></span>

                                                        <% if (badgeText==='Concluída' || projeto.progresso===100) { %>
                                                            <span class="text-sm font-bold text-green-500">Projeto
                                                                Finalizado</span>
                                                            <% } else if (badgeText==='Cancelada' ) { %>
                                                                <span class="text-sm font-bold text-red-500">OS
                                                                    Cancelada</span>
                                                                <% } else if (projeto.dias_restantes < 0) { %>
                                                                    <span
                                                                        class="text-sm text-zinc-600 dark:text-zinc-300 truncate"
                                                                        title="<%= nomeTarefa %>">
                                                                        <span
                                                                            class="font-semibold text-zinc-800 dark:text-zinc-100">
                                                                            <%= nomeTarefaCurto %>
                                                                        </span> <span
                                                                            class="font-bold text-red-500">atrasado <%=
                                                                                Math.abs(projeto.dias_restantes) %>
                                                                                d!</span>
                                                                    </span>
                                                                    <% } else if (projeto.dias_restantes===0) { %>
                                                                        <span
                                                                            class="text-sm text-zinc-600 dark:text-zinc-300 truncate"
                                                                            title="<%= nomeTarefa %>">
                                                                            <span
                                                                                class="font-semibold text-zinc-800 dark:text-zinc-100">
                                                                                <%= nomeTarefaCurto %>
                                                                            </span> <span
                                                                                class="font-bold text-amber-500">vence
                                                                                hoje!</span>
                                                                        </span>
                                                                        <% } else if (projeto.dias_restantes <=5) { %>
                                                                            <span
                                                                                class="text-sm text-zinc-600 dark:text-zinc-300 truncate"
                                                                                title="<%= nomeTarefa %>">
                                                                                <span
                                                                                    class="font-semibold text-zinc-800 dark:text-zinc-100">
                                                                                    <%= nomeTarefaCurto %>
                                                                                </span> em <span
                                                                                    class="font-bold text-red-500">
                                                                                    <%= projeto.dias_restantes %> dias
                                                                                </span>
                                                                            </span>
                                                                            <% } else { %>
                                                                                <span
                                                                                    class="text-sm text-zinc-600 dark:text-zinc-300 truncate"
                                                                                    title="<%= nomeTarefa %>">
                                                                                    <span
                                                                                        class="font-semibold text-zinc-800 dark:text-zinc-100">
                                                                                        <%= nomeTarefaCurto %>
                                                                                    </span> em <span
                                                                                        class="font-bold text-primary">
                                                                                        <%= projeto.dias_restantes %>
                                                                                            dias
                                                                                    </span>
                                                                                </span>
                                                                                <% } %>
                                                    </div>

                                                    <div class="mt-auto">

                                                        <div class="flex items-center justify-between mb-2">
                                                            <span
                                                                class="text-sm font-semibold text-zinc-700 dark:text-zinc-300">
                                                                <%= projeto.progresso %>%
                                                            </span>
                                                        </div>
                                                        <div class="h-1 rounded-full <%= progressTrack %>"
                                                            role="progressbar" aria-valuenow="<%= projeto.progresso %>"
                                                            aria-valuemin="0" aria-valuemax="100">
                                                            <div class="h-1 rounded-full <%= progressFill %> transition-all duration-500"
                                                                <%- `style="width: ${projeto.progresso}%" ` %>></div>
                                                        </div>

                                                        <div class="pt-4 flex items-center justify-between mb-4">
                                                            <div class="flex items-center shrink-0">
                                                                <img src="/images/avatars/thumb-1.jpg"
                                                                    class="size-8 border-2 border-white dark:bg-zinc-900 rounded-full relative">
                                                                <img src="/images/avatars/thumb-2.jpg"
                                                                    class="size-8 border-2 border-white dark:bg-zinc-900 rounded-full relative -ms-3">

                                                                <% if (projeto.membros> 2) { %>
                                                                    <span
                                                                        class="size-8 flex items-center justify-center bg-zinc-500 text-white border-2 border-white dark:border-zinc-900 rounded-full relative -ms-3 text-xs font-bold">
                                                                        +<%= projeto.membros - 2 %>
                                                                    </span>
                                                                    <% } %>
                                                            </div>

                                                            <div
                                                                class="inline-flex items-center px-3 py-1 rounded-full border border-zinc-200 dark:border-zinc-800 text-sm">
                                                                <span
                                                                    class="icon-[lucide--square-check-big] text-muted me-1"></span>
                                                                <span
                                                                    class="font-medium text-zinc-700 dark:text-zinc-300">
                                                                    <%= projeto.total_tarefas %>
                                                                </span>
                                                                <span class="ms-1 hidden sm:inline-block">Tarefas</span>
                                                            </div>
                                                        </div>

                                                        <a href="/scrum/quadro/<%= projeto.id_contrato %>"
                                                            class="btn w-full border border-zinc-200 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 hover:bg-primary hover:text-white hover:border-primary transition-colors flex justify-center items-center font-semibold">
                                                            Acessar Quadro <span
                                                                class="icon-[lucide--arrow-right] ms-2"></span>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                            <% }) %>

                    </div>
                </div>

                <%- include('../partials/footer') %>
        </main>

        <script src="/js/theme.js"></script>
        <script src="/vendor/js/jquery.min.js"></script>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const inputPesquisa = document.getElementById('inputPesquisaProjetos');
                const checkboxes = document.querySelectorAll('.filter-checkbox');
                const cards = document.querySelectorAll('.projeto-card');

                function aplicarFiltros() {
                    const termo = inputPesquisa ? inputPesquisa.value.toLowerCase() : '';
                    const statusSelecionados = Array.from(document.querySelectorAll('.filter-checkbox:not([value="Atrasado"]):checked')).map(cb => cb.value);
                    const soAtrasados = document.querySelector('.filter-checkbox[value="Atrasado"]').checked;

                    cards.forEach(card => {
                        const textoCard = card.innerText.toLowerCase();
                        const statusCard = card.getAttribute('data-status');
                        const estaAtrasado = card.getAttribute('data-atrasado') === 'true';

                        const matchTexto = textoCard.includes(termo);
                        const matchStatus = statusSelecionados.includes(statusCard);
                        const matchAtraso = soAtrasados ? estaAtrasado : true;

                        if (matchTexto && matchStatus && matchAtraso) {
                            card.style.display = '';
                        } else {
                            card.style.display = 'none';
                        }
                    });
                }

                if (inputPesquisa) inputPesquisa.addEventListener('input', aplicarFiltros);
                checkboxes.forEach(cb => cb.addEventListener('change', aplicarFiltros));

                aplicarFiltros();
            });
        </script>
</body>

</html>