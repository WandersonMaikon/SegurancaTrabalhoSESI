<!DOCTYPE html>
<html lang="pt-BR" class="h-full">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ProS - Serviços</title>
  <link rel="icon" href="/images/favicon.png" type="image/png">

  <link rel="stylesheet" href="/vendor/css/simplebar.css">
  <link rel="stylesheet" href="/vendor/css/sweetalert2.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com/">
  <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&amp;display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css" />

  <link rel="stylesheet" href="https://cdn.datatables.net/2.3.3/css/dataTables.dataTables.css">
  <link rel="stylesheet" href="/vendor/css/tom-select.min.css">
</head>

<body
  class="font-theme flex flex-col h-full text-base font-normal bg-zinc-50 dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300">

  <%- include('../partials/sidebar') %>

    <main class="flex-1 lg:ms-64 flex flex-col app-content">
      <%- include('../partials/header') %>

        <div class="px-4 lg:px-8 py-4">
          <h2 class="text-xl mb-2">Serviços</h2>
          <ol class="flex gap-1 items-center text-sm">
            <li class="flex items-center">
              <a href="/dashboard" class="text-zinc-400 hover:text-zinc-700 dark:hover:text-white">Dashboard</a>
            </li>
            <li class="flex items-center opacity-30 leading-none">
              <span class="icon-[lucide--chevron-right] rtl:rotate-180"></span>
            </li>
            <li class="flex items-center"><span class="pointer-events-none">Serviços</span></li>
          </ol>
        </div>

        <div class="content flex-grow lg:px-4">
          <div class="grid grid-cols-1 px-4">
            <div class="rounded-xl bg-white dark:bg-zinc-900 shadow-card mb-4">

              <div class="flex flex-wrap gap-2 items-center p-4 border-b border-zinc-500/10 dark:border-zinc-800">
                <div class="flex-grow">
                  <div class="relative">
                    <input type="search" class="input !ps-9" name="servicoSearch" id="servicoSearch"
                      placeholder="Buscar serviço">
                    <span
                      class="iconify icon-[lucide--search] pointer-events-none absolute start-0 top-0 h-full flex items-center justify-center ms-3 text-muted"></span>
                  </div>
                </div>

                <div class="flex items-center flex-wrap justify-end gap-2">
                  <div class="flex-grow w-56 sm:w-auto">
                    <select id="statusFilter" class="js-select w-full sm:w-56">
                      <option value="">Todos</option>
                      <option value="Ativo" selected>Ativo</option>
                      <option value="Inativo">Inativo</option>
                    </select>
                  </div>

                  <div class="flex items-center gap-2">
                    <a href="/servicos/novo" class="btn bg-primary shrink-0 text-white hover:bg-primary-deep">
                      <span class="icon-[lucide--plus] text-lg me-1"></span>
                      Criar Novo
                    </a>
                  </div>
                </div>
              </div>

              <div class="overflow-x-auto">
                <table id="table_servicos" class="table-default w-full">
                  <thead>
                    <tr>
                      <th class="text-nowrap">Nome do serviço</th>
                      <th class="text-nowrap">Status</th>
                      <th class="text-nowrap" data-orderable="false">Ações</th>
                    </tr>
                  </thead>
                  <tbody id="tableBody"></tbody>
                </table>
              </div>

            </div>
          </div>
        </div>

        <%- include('../partials/footer') %>
    </main>

    <div id="dados-servicos-json" style="display: none;">
      <%= servicosJson %>
    </div>

    <div id="permissoes-servicos-json" style="display: none;">
      <%- JSON.stringify(user.permissoes && user.permissoes['servicos'] ? user.permissoes['servicos'] : {}) %>
    </div>

    <style>
      .ts-wrapper .ts-control,
      .ts-wrapper .ts-control *,
      .ts-wrapper .ts-control input {
        cursor: pointer !important;
      }
    </style>

    <script src="/js/theme.js"></script>
    <script src="/vendor/js/jquery.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.3/js/dataTables.js"></script>
    <script src="/vendor/js/sweetalert2.all.min.js"></script>
    <script src="/vendor/js/tom-select.complete.min.js"></script>

    <script>
      const userEmail = "<%= user.email %>";
      const userPerfilNome = "<%= user.nome_perfil %>";

      // LER AS PERMISSÕES DA DIV OCULTA
      let permServicos = {};
      try {
        const divPerm = document.getElementById('permissoes-servicos-json');
        if (divPerm && divPerm.innerText) {
          permServicos = JSON.parse(divPerm.innerText);
        }
      } catch (e) {
        console.error("Erro ao ler permissões:", e);
      }

      let canEdit = false;
      let canCreate = false;
      let canInactivate = false;

      // Admin Bypass
      if (userEmail === 'admin@admin.com' || userPerfilNome === 'Administrador' || userPerfilNome === 'Super Admin') {
        canEdit = true;
        canCreate = true;
        canInactivate = true;
      } else {
        if ((permServicos.pode_editar == 1 || permServicos.pode_editar === true) || (permServicos.tudo == 1 || permServicos.tudo === true)) canEdit = true;
        if ((permServicos.pode_criar == 1 || permServicos.pode_criar === true) || (permServicos.tudo == 1 || permServicos.tudo === true)) canCreate = true;
        if ((permServicos.pode_inativar == 1 || permServicos.pode_inativar === true) || (permServicos.tudo == 1 || permServicos.tudo === true)) canInactivate = true;
      }
    </script>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        let listaServicos = [];
        try {
          const divJson = document.getElementById('dados-servicos-json');
          if (divJson && divJson.innerText.trim()) {
            listaServicos = JSON.parse(divJson.innerText);
          }
        } catch (e) { console.error(e); }

        const tbody = document.getElementById('tableBody');
        tbody.innerHTML = '';

        listaServicos.forEach((s, index) => {
          const tr = document.createElement('tr');

          const statusHtml = s.ativo
            ? '<span class="badge bg-green-500/10 text-green-500">Ativo</span>'
            : '<span class="badge bg-zinc-500/10 text-zinc-500">Inativo</span>';

          tr.innerHTML = `
                        <td class="font-semibold text-zinc-900 whitespace-nowrap dark:text-white align-middle">${s.nome_servico}</td>
                        <td class="align-middle">${statusHtml}</td>
                        <td class="align-middle">
                            <div class="flex items-center gap-1 relative z-[1]">
                                <a href="/servicos/ver/${s.id_servico}" class="btn !p-1.5 hover:!text-primary" title="Ver">
                                    <span class="icon-[lucide--eye] text-lg"></span>
                                </a>
                                <a href="/servicos/editar/${s.id_servico}" class="btn !p-1.5 hover:!text-primary" title="Editar">
                                    <span class="icon-[lucide--edit] text-lg"></span>
                                </a>
                                <button type="button" class="btn !p-1.5 text-zinc-500 hover:text-red-500 transition-colors btn-inativar" data-id="${s.id_servico}" title="Inativar">
                                    <span class="icon-[lucide--trash] text-lg pointer-events-none"></span>
                                </button>
                            </div>
                        </td>
                    `;
          tbody.appendChild(tr);
        });

        const table = new DataTable('#table_servicos', {
          lengthChange: false,
          pageLength: 10,
          dom: 'lrtip', // scrollX removido
          language: {
            emptyTable: "Nenhum serviço encontrado",
            info: "Mostrando _START_ até _END_ de _TOTAL_ registros",
            paginate: { first: "Primeiro", last: "Último", next: "Próximo", previous: "Anterior" }
          },
          order: [[0, 'asc']] // Checkbox sumiu, então ordena pela primeira coluna (0)
        });

        // Busca
        document.getElementById('servicoSearch').addEventListener('input', e => {
          table.search(e.target.value).draw();
        });

        // Filtro Status (Corrigido para busca EXATA e atualizado para a coluna 1)
        const statusFilter = document.getElementById('statusFilter');
        statusFilter.addEventListener('change', function () {
          const val = $.fn.dataTable.util.escapeRegex(this.value);
          // Como apagamos o checkbox, o status é a coluna 1
          table.columns(1).search(val ? '^' + val + '$' : '', true, false).draw();
        });

        // Dispara o filtro inicial caso o "Ativo" já esteja selecionado no HTML
        if (statusFilter.value) {
          const val = $.fn.dataTable.util.escapeRegex(statusFilter.value);
          table.columns(1).search(val ? '^' + val + '$' : '', true, false).draw();
        }

        // =========================================================================
        // INTERCEPTADOR DE CLIQUES (EDITAR, NOVO E INATIVAR)
        // =========================================================================
        document.body.addEventListener('click', function (e) {

          // LINK EDITAR
          const linkEditar = e.target.closest('a[href^="/servicos/editar/"]');
          if (linkEditar && !canEdit) {
            e.preventDefault();
            Swal.fire({
              title: 'Acesso Negado',
              text: 'Você não tem permissão para editar serviços.',
              icon: 'warning',
              confirmButtonColor: '#f59e0b',
              confirmButtonText: 'Entendido'
            });
          }

          // LINK NOVO
          const linkNovo = e.target.closest('a[href="/servicos/novo"]');
          if (linkNovo && !canCreate) {
            e.preventDefault();
            Swal.fire({
              title: 'Acesso Negado',
              text: 'Você não tem permissão para criar novos serviços.',
              icon: 'warning',
              confirmButtonColor: '#f59e0b',
              confirmButtonText: 'Entendido'
            });
          }

          // BOTÃO INATIVAR (LIXEIRA)
          const btnInativar = e.target.closest('.btn-inativar');
          if (btnInativar) {
            e.preventDefault();

            if (!canInactivate) {
              Swal.fire({
                title: 'Acesso Negado',
                text: 'Você não tem permissão para inativar serviços.',
                icon: 'warning',
                confirmButtonColor: '#f59e0b',
                confirmButtonText: 'Entendido'
              });
              return;
            }

            const servicoId = btnInativar.getAttribute('data-id');

            Swal.fire({
              title: 'Inativar Serviço?',
              text: `Tem certeza que deseja inativar este serviço?`,
              icon: 'warning',
              showCancelButton: true,
              confirmButtonText: 'Sim, inativar',
              cancelButtonText: 'Cancelar'
            }).then(async (result) => {
              if (result.isConfirmed) {
                try {
                  // Continua mandando pra rota múltipla, mas passando um array com 1 ID
                  const response = await fetch('/servicos/inativar-multiplos', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json',
                      'Accept': 'application/json'
                    },
                    body: JSON.stringify({ ids: [servicoId] })
                  });

                  if (!response.ok) {
                    if (response.status === 403) {
                      Swal.fire({ title: 'Acesso Negado', text: 'Permissão negada pelo servidor (403).', icon: 'warning', confirmButtonColor: '#f59e0b' });
                      return;
                    }
                    throw new Error(`Erro de comunicação com o servidor.`);
                  }

                  const data = await response.json();
                  if (data.success) {
                    Swal.fire('Sucesso!', data.message, 'success').then(() => location.reload());
                  } else {
                    Swal.fire('Erro', data.message, 'error');
                  }
                } catch (error) {
                  console.error(error);
                  Swal.fire('Erro', error.message || 'Falha na comunicação.', 'error');
                }
              }
            });
          }
        });
      });

      document.querySelectorAll('.js-select').forEach(select => {
        new TomSelect(select, {
          create: false,
          allowEmptyOption: true,
          controlInput: null, // Desliga o teclado
          onInitialize: function () {
            this.control.classList.add('!cursor-pointer', 'select-none');
          }
        });
      });
    </script>
</body>

</html>